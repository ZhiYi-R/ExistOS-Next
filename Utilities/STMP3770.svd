    </peripheral>
    <peripheral>
      <name>DCP</name>
      <description>数据协处理器(DCP,硬件 AES/SHA 加解密与哈希,支持内存拷贝/校验)</description>
      <groupName>Crypto</groupName>
      <baseAddress>0x80028000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x440</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>DCP_VMI</name>
        <value>53</value>
      </interrupt>
      <interrupt>
        <name>DCP</name>
        <value>54</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL</name>
          <description>DCP Control Register 0</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>CHANNEL_INTERRUPT_ENABLE</name>
              <description>Per-channel interrupt enable. CH0=0x01, CH1=0x02, CH2=0x04, CH3=0x08. CH0 routed to dcp_vmi_irq, others to dcp_irq.</description><bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>CH0</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH1</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH2</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH3</name>
                  <value>8</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CSC_INTERRUPT_ENABLE</name>
              <description>Interrupt enable bit for the CSC. Combined with channels 1-3 interrupts to form dcp_irq.</description><bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE_CONTEXT_SWITCHING</name>
              <description>Enable automatic context switching for channels. Set if more than one channel does hashing/cipher requiring context save (e.g. CBC mode).</description><bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE_CONTEXT_CACHING</name>
              <description>Enable caching of contexts between operations. If only one channel used for encryption/hashing, context not reloaded if channel was last used.</description><bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>GATHER_RESIDUAL_WRITES</name>
              <description>Enable ragged writes to unaligned buffers to be gathered between multiple write operations. Improves performance.</description><bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PRESENT_CSC</name>
              <description>Indicates whether the CSC function is present. Present=0x1, Absent=0x0.</description><bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>Present</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>Absent</name>
                  <value>0</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>PRESENT_CRYPTO</name>
              <description>Indicates whether the crypto (cipher/hash) functions are present. Present=0x1, Absent=0x0.</description><bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>Present</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>Absent</name>
                  <value>0</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>Must be cleared to 0 for normal operation. When set to 1, gates off the clocks to the block.</description><bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SFTRST</name>
              <description>Clear to 0 to enable normal DCP operation. Set to 1 (default) to disable clocking and hold in reset (lowest power) state.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STAT</name>
          <description>DCP Status Register</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>IRQ</name>
              <description>Indicates channels with pending interrupts. CH0 on dcp_vmi_irq, others on dcp_irq.</description><bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>CSCIRQ</name>
              <description>Indicates CSC has a pending interrupt request. Appears on dcp_irq line.</description><bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>READY_CHANNELS</name>
              <description>Indicates which channels are ready to proceed with a transfer. One-hot per channel.</description><bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>CH0</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH1</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH2</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH3</name>
                  <value>8</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CUR_CHANNEL</name>
              <description>Current (active) channel encoded. None=0x0, CH0=0x1, CH1=0x2, CH2=0x3, CH3=0x4, CSC=0x8.</description><bitOffset>24</bitOffset>
              <bitWidth>4</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>None</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH0</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH1</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH2</name>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH3</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CSC</name>
                  <value>8</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>OTP_KEY_READY</name>
              <description>When set, indicates the OTP key has been shifted from the fuse block and is ready for use.</description><bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CHANNELCTRL</name>
          <description>DCP Channel Control Register</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>ENABLE_CHANNEL</name>
              <description>Setting a bit enables the DMA channel. CH0=0x01, CH1=0x02, CH2=0x04, CH3=0x08.</description><bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>CH0</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH1</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH2</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH3</name>
                  <value>8</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>HIGH_PRIORITY_CHANNEL</name>
              <description>Setting a bit marks the channel for high-priority arbitration. Round-robin among them. CH0=0x01, CH1=0x02, CH2=0x04, CH3=0x08.</description><bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>CH0</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH1</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH2</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH3</name>
                  <value>8</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CH0_IRQ_MERGED</name>
              <description>通道0中断合并，置位时CH0中断并入共享dcp_irq。</description><bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CSC_PRIORITY</name>
              <description>Sets CSC priority: HIGH=0x3, MED=0x2, LOW=0x1, BACKGROUND=0x0.</description><bitOffset>17</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>HIGH</name>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MED</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LOW</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BACKGROUND</name>
                  <value>0</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>CAPABILITY0</name>
          <description>DCP Capability 0 Register</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>NUM_KEYS</name>
              <description>Encoded value indicating the number of key storage locations.</description><bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>NUM_CHANNELS</name>
              <description>Encoded value indicating the number of channels implemented.</description><bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>ENABLE_TZONE</name>
              <description>信任区使能标志。</description><bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DISABLE_DECRYPT</name>
              <description>解密禁用标志。</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CAPABILITY1</name>
          <description>DCP Capability 1 Register</description>
          <addressOffset>0x40</addressOffset>
          <fields>
            <field>
              <name>CIPHER_ALGORITHMS</name>
              <description>One-hot field indicating cipher algorithms available. AES128=0x0001.</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>AES128</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>HASH_ALGORITHMS</name>
              <description>One-hot field indicating hashing algorithms available. SHA1=0x0001, CRC32=0x0002.</description><bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SHA1</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CRC32</name>
                  <value>2</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>CONTEXT</name>
          <description>DCP Context Buffer Pointer</description>
          <addressOffset>0x50</addressOffset>
          <fields>
            <field>
              <name>ADDR</name>
              <description>Context pointer address. Should be in system RAM and word-aligned for optimal performance.</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>KEY</name>
          <description>DCP Key Index</description>
          <addressOffset>0x60</addressOffset>
          <fields>
            <field>
              <name>SUBWORD</name>
              <description>Key subword pointer. Valid indices 0-3. Auto-increments after each key data write.</description><bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>RSVD_SUBWORD</name>
              <description>保留关键字子字域。</description><bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>INDEX</name>
              <description>Key index pointer. Valid indices are 0-[number_keys].</description><bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>RSVD_INDEX</name>
              <description>保留关键字索引导。</description><bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>KEYDATA</name>
          <description>DCP Key Data</description>
          <addressOffset>0x70</addressOffset>
          <fields>
            <field>
              <name>DATA</name>
              <description>Word 0 data for key. This is the least-significant word.</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PACKET0</name>
          <description>DCP Work Packet 0 Status Register</description>
          <addressOffset>0x80</addressOffset>
          <fields>
            <field>
              <name>ADDR</name>
              <description>Next Pointer Register.</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PACKET1</name>
          <description>DCP Work Packet 1 Status Register</description>
          <addressOffset>0x90</addressOffset>
          <fields>
            <field>
              <name>INTERRUPT</name>
              <description>Reflects whether channel should issue interrupt upon packet completion.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DECR_SEMAPHORE</name>
              <description>Reflects whether channel semaphore decremented at end of current operation.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CHAIN</name>
              <description>Reflects whether next command pointer should be loaded into channel's descriptor pointer.</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CHAIN_CONTIGUOUS</name>
              <description>Reflects whether next packet's address is located following this packet's payload.</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE_MEMCOPY</name>
              <description>Reflects whether memcopy function is enabled for this operation.</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE_CIPHER</name>
              <description>Reflects whether cipher function is enabled for this operation.</description><bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE_HASH</name>
              <description>Reflects whether hashing function is enabled for this operation.</description><bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE_BLIT</name>
              <description>Reflects whether DCP performs blit. BUFFER_SIZE treated as two 16-bit X-Y extents.</description><bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CIPHER_ENCRYPT</name>
              <description>Indicates encryption or decryption. ENCRYPT=0x01, DECRYPT=0x00.</description><bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ENCRYPT</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DECRYPT</name>
                  <value>0</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CIPHER_INIT</name>
              <description>Reflects whether the cipher block should load IV from payload.</description><bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OTP_KEY</name>
              <description>Reflects whether a hardware-based key should be used. KEY_SELECT selects key.</description><bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAYLOAD_KEY</name>
              <description>When set, payload contains the key. Takes precedence over OTP_KEY.</description><bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HASH_INIT</name>
              <description>Reflects whether current hashing block is initial block; hash registers initialized before operation.</description><bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HASH_TERM</name>
              <description>Reflects whether current hashing block is the final block; hash padding applied by hardware.</description><bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CHECK_HASH</name>
              <description>Reflects whether the calculated hash should be compared against payload hash.</description><bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HASH_OUTPUT</name>
              <description>Controls whether input or output data is hashed. INPUT=0x00, OUTPUT=0x01.</description><bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>INPUT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OUTPUT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CONSTANT_FILL</name>
              <description>When set (MEMCOPY/BLIT modes), DCP fills destination buffer with value from Source Address field.</description><bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEST_SEMA_IRQ</name>
              <description>Used to test the channel semaphore transition to 0. FOR TEST USE ONLY!</description><bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>KEY_BYTESWAP</name>
              <description>Reflects whether the DCP engine swaps key bytes (big-endian key).</description><bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>KEY_WORDSWAP</name>
              <description>Reflects whether the DCP engine swaps key words (big-endian key).</description><bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>INPUT_BYTESWAP</name>
              <description>Reflects whether the DCP engine byte-swaps input data (big-endian).</description><bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>INPUT_WORDSWAP</name>
              <description>Reflects whether the DCP engine word-swaps input data (big-endian).</description><bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OUTPUT_BYTESWAP</name>
              <description>Reflects whether the DCP engine byte-swaps output data (big-endian).</description><bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OUTPUT_WORDSWAP</name>
              <description>Reflects whether the DCP engine word-swaps output data (big-endian).</description><bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TAG</name>
              <description>Packet Tag.</description><bitOffset>24</bitOffset>
