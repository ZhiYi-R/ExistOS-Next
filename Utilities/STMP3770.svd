            </field>
            <field>
              <name>NO_SLAVE_ACK_IRQ</name>
              <description>无从机应答中断状态：0=无请求，1=有请求。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_REQUEST</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>REQUEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DATA_ENGINE_CMPLT_IRQ</name>
