              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_REQUEST</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>REQUEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>BUS_FREE_IRQ_SUMMARY</name>
              <description>总线空闲中断汇总：0=无请求，1=有请求。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_REQUEST</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>REQUEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SLAVE_BUSY</name>
              <description>从机引擎忙状态：0=空闲，1=忙。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUSY</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DATA_ENGINE_BUSY</name>
              <description>数据引擎忙状态：0=空闲，1=忙。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUSY</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CLK_GEN_BUSY</name>
              <description>时钟生成器忙状态：0=空闲，1=忙。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUSY</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>BUS_BUSY</name>
              <description>总线忙状态：0=空闲，1=忙。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUSY</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DATA_ENGINE_DMA_WAIT</name>
              <description>数据引擎 DMA 等待状态：0=继续，1=等待 DMA。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>CONTINUE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>WAITING</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SLAVE_SEARCHING</name>
              <description>从机地址搜索状态：0=空闲，1=正在搜索。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ACTIVE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SLAVE_FOUND</name>
              <description>从机地址匹配结果：0=空闲，1=已匹配并等待。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>WAITING</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SLAVE_ADDR_EQ_ZERO</name>
              <description>接收到的从机地址是否为 0：0=未匹配到 0，1=地址为 0。</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ZERO_NOT_MATCHED</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>WAS_ZERO</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>RCVD_SLAVE_ADDR</name>
              <description>接收到的从机地址字节（8 位）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>GOT_A_NAK</name>
              <description>检测到 NAK 标志：0=未检测到，1=检测到 NAK。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_NAK</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DETECTED_NAK</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>ANY_ENABLED_IRQ</name>
              <description>任意已使能中断请求：0=无请求，1=至少有一个中断请求。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_REQUESTS</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>AT_LEAST_ONE_REQUEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SLAVE_PRESENT</name>
              <description>从机功能存在标志：0=不可用，1=可用。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>UNAVAILABLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>AVAILABLE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>MASTER_PRESENT</name>
              <description>主机功能存在标志：0=不可用，1=可用。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>UNAVAILABLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>AVAILABLE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
          <description>I2C 数据寄存器，用于 PIO 模式下读写传输数据，或作为 DMA 数据接口。</description>
          <addressOffset>0x60</addressOffset>
          <fields>
            <field>
              <name>DATA</name>
              <description>PIO/DMA 数据读写端口（32 位），写操作发送数据，读操作接收数据。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG0</name>
          <description>I2C 调试寄存器 0，提供从机状态机、DMA 状态机、各类事件翻转位及 DMA 控制信号的调试可见性。</description>
          <addressOffset>0x70</addressOffset>
          <fields>
            <field>
              <name>SLAVE_STATE</name>
              <description>从机状态机当前状态（10 位）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>SLAVE_HOLD_CLK</name>
              <description>从机时钟保持状态：0=未保持，1=正在保持 SCL 低电平。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TESTMODE</name>
              <description>测试模式使能，用于芯片测试时的特殊模式。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CHANGE_TOGGLE</name>
              <description>CHANGE 事件翻转位，用于调试时观察状态变化事件。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>GRAB_TOGGLE</name>
              <description>GRAB 事件翻转位，用于调试时观察总线占用事件。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>STOP_TOGGLE</name>
              <description>STOP 事件翻转位，用于调试时观察 STOP 条件事件。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>START_TOGGLE</name>
              <description>START 事件翻转位，用于调试时观察 START 条件事件。</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMA_STATE</name>
              <description>DMA 状态机当前状态（10 位）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>TBD</name>
              <description>保留位（2 位），供未来扩展或内部测试使用。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DMATERMINATE</name>
              <description>DMA 终止信号，用于调试时观察 DMA 传输终止状态。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAKICK</name>
              <description>DMA 启动信号，用于调试时观察 DMA 传输启动状态。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAENDCMD</name>
              <description>DMA 结束命令信号，用于调试时观察 DMA 命令结束状态。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAREQ</name>
              <description>DMA 请求信号，用于调试时观察 DMA 请求状态。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG1</name>
          <description>I2C 调试寄存器 1，提供强制信号注入、从机测试模式、时钟生成器状态、DMA 字节使能及 I2C 引脚输入状态的调试可见性。</description>
          <addressOffset>0x80</addressOffset>
          <fields>
            <field>
              <name>FORCE_I2C_CLK_OE</name>
              <description>强制 I2C 时钟输出使能，用于调试时手动控制 SCL 输出。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FORCE_I2C_DATA_OE</name>
              <description>强制 I2C 数据输出使能，用于调试时手动控制 SDA 输出。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FORCE_RCV_ACK</name>
              <description>强制接收 ACK，用于调试时手动注入 ACK 信号。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FORCE_ARB_LOSS</name>
              <description>强制仲裁丢失，用于调试时模拟仲裁丢失场景。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FORCE_CLK_ON</name>
              <description>强制时钟开启，用于调试时强制使能时钟生成器。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LOCAL_SLAVE_TEST</name>
              <description>本地从机测试模式使能，用于芯片测试时启用内部从机测试逻辑。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LST_MODE</name>
              <description>从机监听传输模式：0=广播，1=本机写，2=本机读，3=非本机。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BCAST</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MY_WRITE</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MY_READ</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NOT_ME</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CLK_GEN_STATE</name>
              <description>时钟生成器状态机当前状态（8 位）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>DMA_BYTE_ENABLES</name>
              <description>DMA 字节使能掩码（4 位），指示当前 DMA 传输中哪些字节有效。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>I2C_DATA_IN</name>
              <description>I2C 数据输入引脚（SDA）的当前电平状态。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>I2C_CLK_IN</name>
              <description>I2C 时钟输入引脚（SCL）的当前电平状态。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>I2C 版本寄存器，记录 IP 核的主版本、次版本和步进版本号。</description>
          <addressOffset>0x90</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>步进版本号（16 位），标识当前 IP 的修订步进。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>次版本号（8 位）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>主版本号（8 位）。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>RTC</name>
      <description>STMP3770 RTC (Real-Time Clock) 外设寄存器与位域中文描述</description>
      <groupName>Timer</groupName>
      <baseAddress>0x8005C000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0xE0</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>RTC_ALARM</name>
        <value>22</value>
      </interrupt>
      <interrupt>
        <name>RTC_1MSEC</name>
        <value>48</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL</name>
          <description>实时时钟控制寄存器，用于配置中断使能、看门狗、强制更新及模块时钟/复位控制。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>ALARM_IRQ_EN</name>
              <description>闹钟中断使能，置位后允许 ALARM 匹配时产生中断。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ONEMSEC_IRQ_EN</name>
              <description>1毫秒中断使能，置位后允许每 1ms 产生一次中断。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ALARM_IRQ</name>
              <description>闹钟中断状态标志，硬件在 ALARM 匹配时置位，写 1 清除。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ONEMSEC_IRQ</name>
              <description>1毫秒中断状态标志，硬件每 1ms 置位一次，写 1 清除。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WATCHDOGEN</name>
              <description>看门狗使能，置位后启动 WATCHDOG 计数器。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FORCE_UPDATE</name>
              <description>强制更新，置位后强制将数字域寄存器值写入模拟域。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SUPPRESS_COPY2ANALOG</name>
              <description>抑制写回模拟域，置位后阻止数字域寄存器值拷贝到模拟域。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>时钟门控，置位后关闭 RTC 模块时钟以节能。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SFTRST</name>
              <description>软复位，置位后对 RTC 模块执行软件复位。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STAT</name>
          <description>实时时钟状态寄存器，反映寄存器同步状态及硬件功能存在性标志。</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>NEW_REGS</name>
              <description>新值待生效标志，位图中置 1 的位表示对应寄存器有新值尚未同步到模拟域。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>STALE_REGS</name>
              <description>写入未完成标志，位图中置 1 的位表示对应寄存器写入模拟域尚未完成。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>XTAL32768_PRESENT</name>
              <description>32.768kHz 晶振存在标志，置位表示该晶振已连接并可用。</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>XTAL32000_PRESENT</name>
              <description>32.000kHz 晶振存在标志，置位表示该晶振已连接并可用。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WATCHDOG_PRESENT</name>
              <description>看门狗功能存在标志，置位表示 RTC 集成看门狗硬件。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ALARM_PRESENT</name>
              <description>闹钟功能存在标志，置位表示 RTC 集成闹钟硬件。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RTC_PRESENT</name>
              <description>RTC 模块存在标志，置位表示 RTC 硬件存在。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MILLISECONDS</name>
          <description>实时时钟毫秒计数器，32 位自由运行毫秒计数。</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>COUNT</name>
              <description>毫秒计数值，32 位自由运行计数器，每 1ms 递增。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SECONDS</name>
          <description>实时时钟秒计数器，32 位自由运行秒计数。</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>COUNT</name>
              <description>秒计数值，32 位自由运行计数器，每 1 秒递增。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ALARM</name>
          <description>实时时钟闹钟寄存器，用于设置秒级闹钟比较值。</description>
          <addressOffset>0x40</addressOffset>
          <fields>
            <field>
              <name>VALUE</name>
              <description>闹钟比较值，当 SECONDS.COUNT 等于该值时触发闹钟事件。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>WATCHDOG</name>
          <description>看门狗定时器寄存器，用于配置看门狗倒计数初值。</description>
          <addressOffset>0x50</addressOffset>
          <fields>
            <field>
              <name>COUNT</name>
              <description>看门狗倒计数值，写入后递减，减至 0 时触发看门狗复位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PERSISTENT0</name>
          <description>掉电保持状态寄存器 0，保存系统级持久控制位，掉电后由备用电源维持。</description>
          <addressOffset>0x60</addressOffset>
          <fields>
            <field>
              <name>CLOCKSOURCE</name>
              <description>RTC 时钟源选择，0 表示 32.768kHz 晶振，1 表示 32.000kHz 晶振。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ALARM_WAKE_EN</name>
              <description>闹钟唤醒使能，置位后允许闹钟事件将系统从低功耗状态唤醒。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ALARM_EN</name>
              <description>闹钟功能使能，置位后启用 RTC 闹钟比较功能。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LCK_SECS</name>
              <description>秒计数器锁定，置位后锁定 SECONDS 寄存器防止误写。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>XTAL24MHZ_PWRUP</name>
              <description>24MHz 晶振上电控制，置位后给 24MHz 晶振电路上电。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>XTAL32KHZ_PWRUP</name>
              <description>32kHz 晶振上电控制，置位后给 32kHz 晶振电路上电。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>XTAL32_FREQ</name>
              <description>32kHz 晶振频率选择，0 表示 32.768kHz，1 表示 32.000kHz。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ALARM_WAKE</name>
              <description>闹钟唤醒标志，置位表示系统由闹钟事件唤醒。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MSEC_RES</name>
              <description>毫秒分辨率配置，5 位字段用于设置毫秒计数器的分辨率。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>DISABLE_XTALOK</name>
              <description>禁用 XTAL 正常指示，置位后关闭晶振起振 OK 检测。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LOWERBIAS</name>
              <description>降低偏置电流配置，2 位字段用于调节模拟偏置电流以降低功耗。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DISABLE_PSWITCH</name>
              <description>禁用 PSWITCH 功能，置位后关闭电源开关检测。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AUTO_RESTART</name>
              <description>自动重启使能，置位后系统在特定条件下自动重新启动。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SPARE_ANALOG</name>
              <description>模拟域备用位，14 位保留给模拟电路使用的备用配置字段。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>14</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PERSISTENT1</name>
          <description>掉电保持状态寄存器 1，32 位通用持久存储，可用于保存系统标志。</description>
          <addressOffset>0x70</addressOffset>
          <fields>
            <field>
              <name>GENERAL</name>
              <description>通用 32 位持久数据，掉电保持，可存储系统标志(如 USB 启动模式、OTG 角色等)。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <enumeratedValues>
