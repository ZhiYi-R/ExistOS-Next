              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WLEN</name>
              <description>字长选择（Word Length），00=5 位、01=6 位、10=7 位、11=8 位。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>2</bitWidth>
