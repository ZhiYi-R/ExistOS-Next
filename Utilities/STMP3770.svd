    </peripheral>
    <peripheral>
      <name>I2C</name>
      <description>I2C 总线控制器，支持主从模式、PIO/DMA 数据传输、可编程时序与多主机仲裁。</description>
      <groupName>I2C</groupName>
      <baseAddress>0x80058000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0xA0</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>I2C_DMA</name>
        <value>26</value>
      </interrupt>
      <interrupt>
        <name>I2C_ERROR</name>
        <value>27</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL0</name>
          <description>I2C 控制寄存器 0，配置传输方向、主从模式、字节数、START/STOP 条件、PIO 模式、时钟门控与软复位等核心参数。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>XFER_COUNT</name>
              <description>本次传输的字节数（16 位）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DIRECTION</name>
              <description>传输方向：0=接收，1=发送。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RECEIVE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TRANSMIT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>MASTER_MODE</name>
              <description>主从模式选择：0=从机，1=主机。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SLAVE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MASTER</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SLAVE_ADDRESS_ENABLE</name>
              <description>从机地址匹配使能：0=禁用，1=使能。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>PRE_SEND_START</name>
              <description>传输前是否发送 START 条件：0=不发，1=发送 START。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_START</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SEND_START</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>POST_SEND_STOP</name>
              <description>传输后是否发送 STOP 条件：0=不发，1=发送 STOP。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_STOP</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SEND_STOP</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>RETAIN_CLOCK</name>
              <description>保持 SCL 低电平：0=释放，1=保持低电平。</description>
              <bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RELEASE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>HOLD_LOW</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CLOCK_HELD</name>
              <description>时钟保持状态：0=释放，1=保持低电平。</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RELEASE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>HELD_LOW</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>MULTI_MASTER</name>
              <description>多主机模式：0=单主机，1=多主机。</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SINGLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MULTIPLE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>PIO_MODE</name>
              <description>PIO 模式使能，用于软件直接控制数据读写。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SEND_NAK_ON_LAST</name>
              <description>最后一字节是否发送 NAK：0=ACK，1=NAK。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ACK_IT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NAK_IT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>ACKNOWLEDGE</name>
              <description>应答控制：0=发送 NAK，1=发送 ACK。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SNAK</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ACK</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>PRE_ACK</name>
              <description>预应答控制，用于在时钟保持前提前产生 ACK。</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RUN</name>
              <description>控制器运行控制：0=停止，1=运行。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>HALT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RUN</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>时钟门控：0=正常时钟，1=关闭时钟以节能。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RUN</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NO_CLKS</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SFTRST</name>
              <description>软复位：0=正常运行，1=复位整个 I2C 模块。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RUN</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RESET</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>TIMING0</name>
          <description>I2C 时序寄存器 0，配置 SCL 高电平周期与接收采样计数。</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>RCV_COUNT</name>
              <description>接收采样计数，用于控制接收数据位的采样时序。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>HIGH_COUNT</name>
              <description>SCL 高电平周期计数，决定 SCL 保持高电平的时钟周期数。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TIMING1</name>
          <description>I2C 时序寄存器 1，配置 SCL 低电平周期与发送采样计数。</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>XMIT_COUNT</name>
              <description>发送采样计数，用于控制发送数据位的时序。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>LOW_COUNT</name>
              <description>SCL 低电平周期计数，决定 SCL 保持低电平的时钟周期数。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TIMING2</name>
          <description>I2C 时序寄存器 2，配置引导计数与总线空闲时间。</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>LEADIN_COUNT</name>
              <description>引导计数，用于 START 条件前的引导时序。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>BUS_FREE</name>
              <description>总线空闲时间计数，定义两次传输之间总线必须保持空闲的最小时钟周期数。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL1</name>
          <description>I2C 控制寄存器 1，配置各类中断状态/使能、从机地址、广播监听、ACK 模式及清除 NAK 标志。</description>
          <addressOffset>0x40</addressOffset>
          <fields>
