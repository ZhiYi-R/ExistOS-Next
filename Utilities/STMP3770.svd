              <description>Bank 0 引脚 10 的复用功能选择（2 位，0~3）。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>BANK0_PIN11</name>
              <description>Bank 0 引脚 11 的复用功能选择（2 位，0~3）。</description>
              <bitOffset>22</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>BANK0_PIN12</name>
              <description>Bank 0 引脚 12 的复用功能选择（2 位，0~3）。</description>
              <bitOffset>24</bitOffset>
