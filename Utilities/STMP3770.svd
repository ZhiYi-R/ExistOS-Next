        <register>
          <name>CTRL3</name>
          <description>LRADC 控制寄存器 3，配置 ADC 采样时钟相位、采样高电平时间、转换周期、模拟电源强制状态及初始丢弃样本数。</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>INVERT_CLOCK</name>
              <description>ADC 采样时钟相位反转控制，INVERT 时翻转采样时钟极性。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NORMAL</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>INVERT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DELAY_CLOCK</name>
              <description>ADC 采样时钟延迟控制，DELAYED 时引入额外时钟延迟以调整采样相位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NORMAL</name>
                  <value>0</value>
