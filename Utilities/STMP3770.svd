      </registers>
    </peripheral>
    <peripheral>
      <name>SSP1</name>
      <description>同步串行端口 1(SSP,支持 SD/MMC 卡与 SPI 主/从模式)</description>
      <groupName>SSP</groupName>
      <baseAddress>0x80010000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x120</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>SSP1_DMA</name>
        <value>14</value>
      </interrupt>
      <interrupt>
        <name>SSP1_ERROR</name>
        <value>15</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL0</name>
          <description>SSP Control Register 0</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>XFER_COUNT</name>
              <description>Number of words to transfer per WORD_LENGTH in CTRL1. Run bit and DMA request clear after transfer. SD/MMC: multiple of block size. Bits[15:0] RW Reset=0x1</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>ENABLE</name>
              <description>SD/MMC/MS Command Transmit Enable. 0=commands disabled, 1=data in Command registers will be sent. Bits[16] RW Reset=0x0</description><bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>GET_RESP</name>
              <description>SD/MMC/MS: 0=do not wait for card response, 1=command expects response from card. Bits[17] RW Reset=0x0</description><bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CHECK_RESP</name>
              <description>SD/MMC/MS: XOR response with REFERENCE, mask with MASK. Mismatch sets RESP_ERR and optionally RESP_ERR_IRQ. Bits[18] RW Reset=0x0</description><bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LONG_RESP</name>
              <description>SD/MMC: 0=short response, 1=136-bit long response. Only valid if GET_RESP set. Bits[19] RW Reset=0x0</description><bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WAIT_FOR_CMD</name>
              <description>SD/MMC: 0=send commands immediately, 1=wait until CRC-checking of data transfer completes. Used to send STOP during multi-block read. Bits[20] RW Reset=0x0</description><bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WAIT_FOR_IRQ</name>
              <description>MS: wait for card IRQ before TPC. SD/MMC: wait for MMC ready before sending command. Bits[21] RW Reset=0x0</description><bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BUS_WIDTH</name>
              <description>Data Bus Width. ONE_BIT=0x0, FOUR_BIT=0x1, EIGHT_BIT=0x2. SD/MMC/CE_ATA support all; MS 1/4-bit; SPI 1-bit. Bits[23:22] RW Reset=0x0</description><bitOffset>22</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ONE_BIT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FOUR_BIT</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>EIGHT_BIT</name>
                  <value>2</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DATA_XFER</name>
              <description>Data Transfer Mode. When set, transfers XFER_COUNT bytes of data. MS mode: 1=use FIFOs, 0=use Resp0/Cmd1 registers. Bits[24] RW Reset=0x0</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>READ</name>
              <description>Read Mode. When set with DATA_XFER, SSP reads from device. Otherwise SSP writes to device. Bits[25] RW Reset=0x0</description><bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>IGNORE_CRC</name>
              <description>Ignore Response CRC in SD/MMC and MS modes. Bits[26] RW Reset=0x0</description><bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LOCK_CS</name>
              <description>SPI: 0=deassert CS, 1=hold CS. SD/MMC: 0=check CRC status, 1=ignore CRC. CE_ATA: disable CCS. If set, DATA_XFER must also be set. Bits[27] RW Reset=0x0</description><bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SDIO_IRQ_CHECK</name>
              <description>SD/MMC: enable SDIO IRQ. CE_ATA: 0=ignore CCS, 1=wait for CCS. Must not be 1 if LOCK_CS=1. Bits[28] RW Reset=0x0</description><bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RUN</name>
              <description>SSP Run. 0=not running, 1=running. Automatically set during DMA operation. Bits[29] RW Reset=0x0</description><bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>Gate SSP Clocks. 0=clocks not gated, 1=clocks gated. Set to save power while SSP not actively used. Bits[30] RW Reset=0x1</description><bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SFTRST</name>
              <description>SSP Reset. 0=not reset, 1=held in reset. Registers returned to reset state. Min reset time = max(6 APBCLK, 2 SSPCLK) cycles. Bits[31] RW Reset=0x1</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CMD0</name>
          <description>SD/MMC and MS Command Register 0</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>CMD</name>
              <description>SD/MMC Command Index (bits 5:0) or MS TPC[7:0] to send to card. Also SPI control word[7:0]. Includes all standard MMC/SD commands. Bits[7:0] RW Reset=0x0</description><bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <enumeratedValues>
