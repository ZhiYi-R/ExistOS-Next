              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>USER_DATA</name>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AUTO_MUTE</name>
