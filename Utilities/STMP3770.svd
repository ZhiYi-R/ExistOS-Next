            <field>
              <name>BLOCK_COUNT</name>
              <description>SD/MMC block count minus one. Equation: XFER_COUNT = (1&lt;&lt;BLOCK_SIZE)*(BLOCK_COUNT+1). Also SPI control word[15:8]. Bits[15:8] RW Reset=0x0</description><bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>BLOCK_SIZE</name>
              <description>SD/MMC block size encode. When BLOCK_COUNT!=0, size = (1&lt;&lt;BLOCK_SIZE). When BLOCK_COUNT=0, ignored. Bits[19:16] RW Reset=0x0</description><bitOffset>16</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>APPEND_8CYC</name>
              <description>SD/MMC/CE_ATA: 0=SCK toggles up to 4 cycles idle, 1=8 more cycles. Set to 1 at end of block transfer. Bits[20] RW Reset=0x0</description><bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CONT_CLKING_EN</name>
              <description>CONT_CLKING_EN。注：PDF第16.11.2节Table 752将bit 31:21标记为RSVD，此字段可能来自后续芯片修订。</description><bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLOW_CLKING_EN</name>
              <description>SLOW_CLKING_EN。注：PDF第16.11.2节Table 752将bit 31:21标记为RSVD，此字段可能来自后续芯片修订。</description><bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CMD1</name>
          <description>SD/MMC Command Register 1</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>CMD_ARG</name>
              <description>SD/MMC or MS Command Argument. Bits[31:0] RW Reset=0x0</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>COMPREF</name>
          <description>SD/MMC and MS Compare Reference</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>REFERENCE</name>
              <description>SD/MMC/MS compare reference. XOR'd with response when CHECK_RESP set, masked by MASK. Differences indicate error to DMA. Bits[31:0] RW Reset=0x0</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>COMPMASK</name>
          <description>SD/MMC and MS compare mask</description>
          <addressOffset>0x40</addressOffset>
          <fields>
            <field>
              <name>MASK</name>
              <description>SD/MMC/MS Compare Mode Mask. Masks result of response vs REFERENCE comparison when CHECK_RESP set. Bits[31:0] RW Reset=0x0</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TIMING</name>
          <description>SSP Timing Register</description>
          <addressOffset>0x50</addressOffset>
          <fields>
            <field>
              <name>CLOCK_RATE</name>
              <description>Serial Clock Rate. Bit rate = SSPCLK / (CLOCK_DIVIDE * (1+CLOCK_RATE)). Value from 0 to 255. Bits[7:0] RW Reset=0x0</description><bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>CLOCK_DIVIDE</name>
              <description>Clock Pre-Divider. Must be even value from 2 to 254. Bits[15:8] RW Reset=0x0</description><bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>TIMEOUT</name>
              <description>Time-Out Counter. SCK cycles * 4096 before asserting DATA TIMEOUT IRQ. Used for SD/MMC and MS data transfer time-out. Bits[31:16] RW Reset=0x0</description><bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL1</name>
          <description>SSP Control Register 1</description>
          <addressOffset>0x60</addressOffset>
          <fields>
            <field>
              <name>SSP_MODE</name>
              <description>Operating Mode. 0x0=SPI, 0x1=TI SSI, 0x3=SD/MMC, 0x4=MS, 0x7=CE_ATA. Soft reset before changing. Bits[3:0] RW Reset=0x0</description><bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SPI</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SSI</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SD_MMC</name>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MS</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CE_ATA</name>
                  <value>7</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>WORD_LENGTH</name>
              <description>Word Length in bits. 0x0-0x2 reserved, 0x3=4b, 0x7=8b, 0xF=16b. Always 8b in SD/MMC/CE_ATA and MS. Bits[7:4] RW Reset=0x8</description><bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RESERVED0</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RESERVED1</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RESERVED2</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FOUR_BITS</name>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>EIGHT_BITS</name>
                  <value>7</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SIXTEEN_BITS</name>
                  <value>15</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SLAVE_MODE</name>
              <description>Slave Mode. 0=master, 1=slave. Clear to 0 for SD/MMC and MS modes. Bits[8] RW Reset=0x0</description><bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>POLARITY</name>
              <description>Serial Clock Polarity. SD/MMC/MS: CMD/TX edge select. MS 1-bit=1, 4-bit=0. SPI: 0=steady 0, 1=steady 1 when idle. Bits[9] RW Reset=0x0</description><bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PHASE</name>
              <description>Serial Clock Phase. For SPI mode only. Bits[10] RW Reset=0x0</description><bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLAVE_OUT_DISABLE</name>
              <description>Slave Output Disable. 0=SSP drives MISO in slave mode, 1=does not drive MISO. Bits[11] RW Reset=0x0</description><bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CEATA_CCS_ERR_EN</name>
              <description>CE-ATA unexpected CCS error enable. Enables error generation for unexpected CCS. Bits[12] RW Reset=0x0</description><bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMA_ENABLE</name>
              <description>DMA Enable. Enables DMA request and command end signals. Bits[13] RW Reset=0x0</description><bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_OVERRUN_IRQ_EN</name>
              <description>FIFO Overrun Interrupt Enable. IRQ if FIFO written while full. Bits[14] RW Reset=0x0</description><bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_OVERRUN_IRQ</name>
              <description>FIFO Overrun Interrupt. Written while full. Write 1 to SET clear address to reset. Bits[15] RW Reset=0x0</description><bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RECV_TIMEOUT_IRQ_EN</name>
              <description>Receive Time-Out IRQ Enable. IRQ if RX FIFO not empty and no read for 128 HCLK cycles. Bits[16] RW Reset=0x0</description><bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RECV_TIMEOUT_IRQ</name>
              <description>Data Time-Out Interrupt. RX FIFO not empty but not read for 128 HCLK cycles. SPI modes only. Write 1 to SET clear to reset. Bits[17] RW Reset=0x0</description><bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CEATA_CCS_ERR_IRQ_EN</name>
              <description>CE-ATA Unexpected CCS Error Interrupt Enable. 0=disable, 1=enable. Bits[18] RW Reset=0x0</description><bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CEATA_CCS_ERR_IRQ</name>
              <description>CE-ATA unexpected CCS error interrupt. Write 1 to SET clear address to reset. Bits[19] RW Reset=0x0</description><bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_UNDERRUN_EN</name>
              <description>FIFO Underrun IRQ Enable. IRQ generated if set and FIFO_UNDERRUN_IRQ asserted. Bits[20] RW Reset=0x0</description><bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_UNDERRUN_IRQ</name>
              <description>FIFO Underrun Interrupt. Set when FIFO read while empty. Write 1 to SET clear address to reset. Bits[21] RW Reset=0x1</description><bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DATA_CRC_IRQ_EN</name>
              <description>Data CRC Error IRQ Enable. For SD/MMC and MS modes only. Bits[22] RW Reset=0x0</description><bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DATA_CRC_IRQ</name>
              <description>Data CRC Error IRQ. For SD/MMC and MS modes only. Write 1 to SET clear address to reset. Bits[23] RW Reset=0x0</description><bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DATA_TIMEOUT_IRQ_EN</name>
              <description>Data Time-Out Error IRQ Enable. For SD/MMC and MS modes only. Bits[24] RW Reset=0x0</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DATA_TIMEOUT_IRQ</name>
              <description>Data transmit/receive time-out error IRQ. Counter expired before data bus ready. SD/MMC and MS only. Bits[25] RW Reset=0x0</description><bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RESP_TIMEOUT_IRQ_EN</name>
              <description>Response Time-Out IRQ Enable. 0=masked, 1=enabled. Asserts when no SD/MMC response in 64 cycles or MS not ready in 16 cycles. Bits[26] RW Reset=0x0</description><bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RESP_TIMEOUT_IRQ</name>
              <description>Command response time-out occurred. SD/MMC and MS handshake. Write 1 to SET clear address to reset. Bits[27] RW Reset=0x0</description><bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RESP_ERR_IRQ_EN</name>
              <description>Card Error IRQ Enable. 0=masked, 1=enabled. Asserts CPU IRQ when card error bit set in both Error Mask and R1 response. Bits[28] RW Reset=0x0</description><bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RESP_ERR_IRQ</name>
              <description>Unexpected response/CRC when CHECK_RESP set. Write 1 to SET clear address to reset. Bits[29] RW Reset=0x0</description><bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SDIO_IRQ_EN</name>
              <description>SDIO Card Interrupt IRQ Enable. 0=masked, 1=IRQs sent to ICOLL. Bits[30] RW Reset=0x0</description><bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SDIO_IRQ</name>
              <description>SDIO card interrupt occurred. Write 1 to SET clear address to reset. Bits[31] RW Reset=0x0</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
          <description>SSP Data Register</description>
          <addressOffset>0x70</addressOffset>
          <fields>
            <field>
              <name>DATA</name>
              <description>Data Register. Holds 1-4 words per WORD_LENGTH. Right-justified. Read increments RX FIFO; write increments TX FIFO. Bits[31:0] RW Reset=0x0</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SDRESP0</name>
          <description>SD/MMC Card Response Register 0</description>
          <addressOffset>0x80</addressOffset>
          <fields>
            <field>
              <name>RESP0</name>
              <description>SD/MMC Response Status Bits[31:0]. MS mode: device read data. Bits[31:0] RO Reset=0x0</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SDRESP1</name>
          <description>SD/MMC Card Response Register 1</description>
          <addressOffset>0x90</addressOffset>
          <fields>
            <field>
              <name>RESP1</name>
              <description>SD/MMC Short Response Command Index[37:32] or Long Response[63:32]. Bits[31:0] RO Reset=0x0</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SDRESP2</name>
          <description>SD/MMC Card Response Register 2</description>
          <addressOffset>0xA0</addressOffset>
          <fields>
            <field>
              <name>RESP2</name>
              <description>SD/MMC Long Response[95:64]. Bits[31:0] RO Reset=0x0</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SDRESP3</name>
          <description>SD/MMC Card Response Register 3</description>
          <addressOffset>0xB0</addressOffset>
          <fields>
            <field>
              <name>RESP3</name>
              <description>SD/MMC Long Response[127:96]. Bits[31:0] RO Reset=0x0</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STATUS</name>
          <description>SSP Status Register</description>
          <addressOffset>0xC0</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>BUSY</name>
              <description>SSP state machines are busy. Bits[0] RO Reset=0x0</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DATA_BUSY</name>
              <description>Command controller busy transferring data. Bits[2] RO Reset=0x0</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_BUSY</name>
