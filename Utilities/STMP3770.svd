                <enumeratedValue>
                  <name>NOT_EMPTY</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ONE_QUARTER</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ONE_HALF</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>THREE_QUARTERS</name>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
