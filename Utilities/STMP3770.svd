                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CH7</name>
              <description>Ch7，2位读写字段。</description><bitOffset>14</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
