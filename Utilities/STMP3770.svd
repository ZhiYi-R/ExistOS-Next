            <field>
              <name>PETB</name>
              <description>TX 端点 PRIME（5 位，每 bit 对应一个端点，写 1 请求硬件准备发送缓冲区）</description>
              <bitOffset>16</bitOffset>
              <bitWidth>5</bitWidth>
