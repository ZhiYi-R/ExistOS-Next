    <peripheral>
      <name>APBX</name>
      <description>AHB-to-APBX 桥 DMA 控制器(为音频、UARTAPP、I2C、LRADC 等低速外设提供 DMA 通道)</description>
      <groupName>DMA</groupName>
      <baseAddress>0x80024000</baseAddress>
