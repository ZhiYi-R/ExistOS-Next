                </enumeratedValue>
                <enumeratedValue>
                  <name>_250NS</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CYCLE_TIME</name>
              <description>ADC 转换周期时间选择，决定采样速率对应的时钟频率(6/4/3/2 MHz)。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>_6MHZ</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_4MHZ</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_3MHZ</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_2MHZ</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>FORCE_ANALOG_PWDN</name>
              <description>强制模拟电路掉电控制，ON 时强制关闭模拟部分电源。</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ON</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OFF</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>FORCE_ANALOG_PWUP</name>
              <description>强制模拟电路上电控制，ON 时强制开启模拟部分电源。</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>OFF</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ON</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DISCARD</name>
              <description>初始丢弃样本数选择，启动后自动丢弃前 1/2/3 个样本以稳定 ADC 结果。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>_1_SAMPLE</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_2_SAMPLES</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_3_SAMPLES</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>STATUS</name>
          <description>LRADC 状态寄存器，反映触摸检测原始状态、各通道及外设的存在性标志。</description>
          <addressOffset>0x40</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>TOUCH_DETECT_RAW</name>
              <description>触摸检测原始状态，OPEN 表示未触摸，HIT 表示面板被触摸。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>OPEN</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>HIT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CHANNEL0_PRESENT</name>
              <description>通道 0 存在性标志，置位表示该物理通道可用。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CHANNEL1_PRESENT</name>
              <description>通道 1 存在性标志，置位表示该物理通道可用。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CHANNEL2_PRESENT</name>
              <description>通道 2 存在性标志，置位表示该物理通道可用。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CHANNEL3_PRESENT</name>
              <description>通道 3 存在性标志，置位表示该物理通道可用。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CHANNEL4_PRESENT</name>
              <description>通道 4 存在性标志，置位表示该物理通道可用。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CHANNEL5_PRESENT</name>
              <description>通道 5 存在性标志，置位表示该物理通道可用。</description>
              <bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CHANNEL6_PRESENT</name>
              <description>通道 6 存在性标志，置位表示该物理通道可用。</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CHANNEL7_PRESENT</name>
              <description>通道 7 存在性标志，置位表示该物理通道可用。</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TOUCH_PANEL_PRESENT</name>
              <description>触摸屏面板存在性标志，置位表示触摸面板已连接。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMP0_PRESENT</name>
              <description>温度传感器 0 存在性标志，置位表示 TEMP0 通道可用。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMP1_PRESENT</name>
              <description>温度传感器 1 存在性标志，置位表示 TEMP1 通道可用。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>6</dim>
          <dimIncrement>0x10</dimIncrement>
          <dimIndex>0-5</dimIndex>
          <name>CH%s</name>
          <description>LRADC 通道结果寄存器(数组 CH0~CH5)，存储 ADC 转换结果并控制累加模式。</description>
          <addressOffset>0x50</addressOffset>
          <fields>
            <field>
              <name>VALUE</name>
              <description>18 位 ADC 转换结果值，存放该通道最近一次或累加后的采样数据。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>18</bitWidth>
            </field>
            <field>
              <name>NUM_SAMPLES</name>
              <description>累加样本数配置，指定一次累加转换中需采样的次数(0~31 对应 1~32 次)。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>ACCUMULATE</name>
              <description>累加使能，置位时启用多次采样累加模式以提高分辨率/抑制噪声。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TOGGLE</name>
              <description>通道结果翻转标志，硬件在每次更新结果时自动翻转，软件可用于判断新数据是否就绪。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CH6</name>
          <description>LRADC 通道 6 结果寄存器(VddIO)，存储 VddIO 电压采样结果并支持累加模式。</description>
          <addressOffset>0xB0</addressOffset>
          <fields>
            <field>
              <name>VALUE</name>
              <description>18 位 ADC 转换结果值，存放 VddIO 通道最近一次或累加后的采样数据。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>18</bitWidth>
            </field>
            <field>
              <name>NUM_SAMPLES</name>
              <description>累加样本数配置，指定一次累加转换中需采样的次数。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>ACCUMULATE</name>
              <description>累加使能，置位时启用多次采样累加模式以提高分辨率/抑制噪声。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TOGGLE</name>
              <description>通道结果翻转标志，硬件在每次更新结果时自动翻转，软件可用于判断新数据是否就绪。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CH7</name>
          <description>LRADC 通道 7 结果寄存器(BATT)，存储电池电压采样结果并支持累加与测试模式。</description>
          <addressOffset>0xC0</addressOffset>
          <fields>
            <field>
              <name>VALUE</name>
              <description>18 位 ADC 转换结果值，存放电池通道最近一次或累加后的采样数据。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>18</bitWidth>
            </field>
            <field>
              <name>NUM_SAMPLES</name>
              <description>累加样本数配置，指定一次累加转换中需采样的次数。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>ACCUMULATE</name>
              <description>累加使能，置位时启用多次采样累加模式以提高分辨率/抑制噪声。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TESTMODE_TOGGLE</name>
              <description>测试模式翻转控制，用于调试时手动翻转通道 7 的测试状态位。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TOGGLE</name>
              <description>通道结果翻转标志，硬件在每次更新结果时自动翻转，软件可用于判断新数据是否就绪。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>4</dim>
          <dimIncrement>0x10</dimIncrement>
          <dimIndex>0-3</dimIndex>
          <name>DELAY%s</name>
          <description>LRADC 延迟触发寄存器(数组 DELAY0~DELAY3)，配置定时延迟、循环计数及触发链。</description>
          <addressOffset>0xD0</addressOffset>
          <fields>
            <field>
              <name>DELAY</name>
              <description>延迟计数值，指定该延迟槽的定时长度，用于控制采样触发的时间间隔。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>11</bitWidth>
            </field>
            <field>
              <name>LOOP_COUNT</name>
              <description>循环次数配置，指定该延迟序列需重复执行的次数。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>TRIGGER_DELAYS</name>
              <description>延迟链触发掩码，4 位按位选择该延迟到期后触发哪些其他 DELAY 槽。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>KICK</name>
              <description>延迟启动触发位，写 1 立即启动该延迟槽的计数器。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TRIGGER_LRADCS</name>
              <description>LRADC 通道触发掩码，8 位按位选择该延迟到期后触发哪些 LRADC 通道开始转换。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG0</name>
          <description>LRADC 调试寄存器 0，提供状态机状态及只读调试信息。</description>
          <addressOffset>0x110</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STATE</name>
              <description>LRADC 内部状态机当前状态值，12 位用于调试跟踪控制器运行阶段。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
            <field>
              <name>READONLY</name>
              <description>只读调试数据，16 位硬件内部调试信号供分析使用。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG1</name>
          <description>LRADC 调试寄存器 1，提供测试模式控制、测试计数及请求信号调试。</description>
          <addressOffset>0x120</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>TESTMODE</name>
              <description>测试模式总开关，TEST 时启用 LRADC 整体测试模式。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NORMAL</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>TESTMODE5</name>
              <description>测试模式 5 控制，TEST 时启用通道 5 相关测试逻辑。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NORMAL</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>TESTMODE6</name>
              <description>测试模式 6 控制，TEST 时启用通道 6 相关测试逻辑。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NORMAL</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>TESTMODE_COUNT</name>
              <description>测试模式计数配置，指定测试序列的计数长度。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>REQUEST</name>
              <description>8 位请求调试信号，反映内部各通道的转换请求状态。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CONVERSION</name>
          <description>LRADC 电池转换寄存器，配置电池类型缩放系数及自动转换使能。</description>
          <addressOffset>0x130</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>SCALED_BATT_VOLTAGE</name>
              <description>10 位电池电压缩放后值，反映经 SCALE_FACTOR 缩放后的电池电压读数。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>SCALE_FACTOR</name>
              <description>电池类型缩放系数选择，决定电池电压到 ADC 量程的映射关系(NiMH/双 NiMH/Li-Ion/替代 Li-Ion)。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NIMH</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DUAL_NIMH</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LI_ION</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ALT_LI_ION</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>AUTOMATIC</name>
              <description>电池自动转换使能，ENABLE 时启用硬件自动电池电压采样与转换。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
