                <enumeratedValue>
                  <name>DELAYED</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>HIGH_TIME</name>
              <description>ADC 采样高电平保持时间选择，决定采样开关导通时长(42/83/125/250 ns)。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>_42NS</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_83NS</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_125NS</name>
