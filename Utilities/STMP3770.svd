              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TIMEOUT</name>
              <description>SD/MMC: time-out before data bus ready. MS: time-out waiting for IRQ. Cleared by soft reset or CTRL0_RUN. Bits[12] RO Reset=0x0</description><bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
