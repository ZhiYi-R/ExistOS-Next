    </peripheral>
    <peripheral>
      <name>PINCTRL</name>
      <description>STMP3770 PINCTRL 引脚复用与 GPIO 控制器。提供 4 组物理引脚 Bank（Bank0~Bank3）的复用选择（MUXSEL）、驱动强度（DRIVE）、上拉电阻使能（PULL）、GPIO 输出数据（DOUT）、输入数据（DIN）、输出使能（DOE）以及中断配置（PIN2IRQ/IRQEN/IRQLEVEL/IRQPOL/IRQSTAT）。每引脚通过 2 位 MUXSEL 选择 0~3 共 4 种复用功能，值 3 通常映射为 GPIO 模式。DRIVE 寄存器按引脚配置输出驱动电流档位（_MA）与 I/O 电压域（_V）。PULL0/1/2 控制对应 Bank 的上拉电阻使能，PULL3 用于 Bank3 的 Pad Keeper 禁用。DOUT/DIN/DOE 以位掩码方式控制各 Bank 的 GPIO 输出值、输入采样值与方向。中断相关寄存器以位掩码逐引脚配置中断源选择、使能、电平/边沿触发、极性及状态。CTRL 寄存器提供模块级软复位（SFTRST）、时钟门控（CLKGATE）、Bank 存在标志（PRESENT）及中断输出路由（IRQOUT）。</description>
      <groupName>GPIO</groupName>
      <baseAddress>0x80018000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0xB30</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>GPIO0</name>
        <value>16</value>
      </interrupt>
      <interrupt>
        <name>GPIO1</name>
        <value>17</value>
      </interrupt>
      <interrupt>
        <name>GPIO2</name>
        <value>18</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL</name>
          <description>PINCTRL 模块控制寄存器，包含中断输出路由、Bank 存在标志、时钟门控与软复位。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>IRQOUT0</name>
              <description>Bank 0 中断输出路由使能，置 1 时将 Bank 0 的 GPIO 中断路由至 IRQ0 输出。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>IRQOUT1</name>
              <description>Bank 1 中断输出路由使能，置 1 时将 Bank 1 的 GPIO 中断路由至 IRQ1 输出。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>IRQOUT2</name>
              <description>Bank 2 中断输出路由使能，置 1 时将 Bank 2 的 GPIO 中断路由至 IRQ2 输出。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PRESENT0</name>
              <description>Bank 0 存在标志，只读，为 1 表示 Bank 0 引脚在芯片中物理存在。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PRESENT1</name>
              <description>Bank 1 存在标志，只读，为 1 表示 Bank 1 引脚在芯片中物理存在。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PRESENT2</name>
              <description>Bank 2 存在标志，只读，为 1 表示 Bank 2 引脚在芯片中物理存在。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PRESENT3</name>
              <description>Bank 3 存在标志，只读，为 1 表示 Bank 3 引脚在芯片中物理存在。</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>时钟门控控制，置 1 时关闭 PINCTRL 模块时钟以节省功耗，置 0 时使能时钟。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SFTRST</name>
              <description>软复位控制，置 1 时对 PINCTRL 模块执行软复位，置 0 时正常工作。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MUXSEL0</name>
          <description>Bank 0 引脚复用选择寄存器 0，配置 Pin00~Pin15 的复用功能（每引脚 2 位，0~3 对应 4 种功能，值 3 通常为 GPIO 模式）。</description>
          <addressOffset>0x100</addressOffset>
          <fields>
            <field>
              <name>BANK0_PIN00</name>
              <description>Bank 0 引脚 0 的复用功能选择（2 位，0~3）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
