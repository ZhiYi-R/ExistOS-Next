          <name>FRAC1</name>
          <description>分数时钟控制寄存器 1，控制视频分数分频器稳定与门控。</description>
          <addressOffset>0x100</addressOffset>
          <fields>
            <field>
              <name>VID_STABLE</name>
              <description>VID 视频分数分频稳定标志，为 1 表示视频分数分频已稳定。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLKGATEVID</name>
              <description>VID 视频分数时钟门控，置位后关闭视频分数时钟输出。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STATUS</name>
          <description>时钟控制状态寄存器，反映时钟单元运行状态。</description>
          <addressOffset>0x130</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>CPU_LIMIT</name>
              <description>CPU 时钟限制状态，指示当前 CPU 频率是否受到限制。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>时钟控制单元版本寄存器，反映 IP 核版本信息。</description>
          <addressOffset>0x140</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>IP 核步进版本号。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>IP 核次版本号。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>IP 核主版本号。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>SAIF1</name>
      <description>串行音频接口 1(SAIF,I2S 风格音频数据收发)</description>
      <groupName>Audio</groupName>
      <baseAddress>0x80042000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x40</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>SAIF1_IRQ</name>
        <value>10</value>
      </interrupt>
      <interrupt>
        <name>SAIF1_DMA</name>
        <value>19</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL</name>
          <description>SAIF Control Register</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>RUN</name>
              <description>运行使能位，写1启动模块运行，写0停止。DMA操作时硬件自动置位。</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>READ_MODE</name>
              <description>I2S 读模式选择，置位时 SAIF 从外部读取数据（接收模式），清零时发送数据（发送模式）。</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLAVE_MODE</name>
              <description>主从模式选择，0=主机模式（SAIF 产生位时钟和帧时钟），1=从机模式（外部提供时钟）。</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BITCLK_48XFS_ENABLE</name>
              <description>位时钟 48x 帧同步使能，置位时位时钟频率为帧同步的 48 倍。</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WORD_LENGTH</name>
              <description>数据字长选择，0=16位，1=20位，2=24位，3=32位。</description><bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>BITCLK_EDGE</name>
              <description>位时钟边沿选择，决定数据在哪个时钟边沿驱动和采样。</description><bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LRCLK_POLARITY</name>
              <description>左右声道时钟极性控制，定义帧同步信号的极性。</description><bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>JUSTIFY</name>
              <description>数据对齐方式选择，控制数据在帧内的对齐位置（左对齐/右对齐/I2S）。</description><bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DELAY</name>
              <description>数据延迟控制，配置数据相对于帧同步信号的延迟周期数。</description><bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BIT_ORDER</name>
              <description>位顺序控制，0=MSB 先发送，1=LSB 先发送。</description><bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CHANNEL_NUM_SELECT</name>
              <description>声道数选择，配置 I2S 接口的音频声道数量。</description><bitOffset>14</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DMAWAIT_COUNT</name>
              <description>DMA 等待计数值，DMA 请求的等待周期数。</description><bitOffset>16</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>FIFO_SERVICE_IRQ_EN</name>
              <description>FIFO 服务中断使能，置位时允许 FIFO 触发服务请求中断。</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_ERROR_IRQ_EN</name>
              <description>FIFO 错误中断使能，置位时允许 FIFO 上溢/下溢触发中断。</description><bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BITCLK_BASE_RATE</name>
              <description>位时钟基准速率选择，配置 SAIF 位时钟的基准分频值。</description><bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BITCLK_MULT_RATE</name>
              <description>位时钟倍频速率选择，在基准速率上配置倍频系数。</description><bitOffset>27</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>时钟门控控制位，写1关闭模块时钟以节省功耗，配置状态保持。写0恢复正常时钟供应。</description><bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SFTRST</name>
              <description>软复位控制位，写1复位本模块，写0恢复正常运行。复位后所有寄存器回到默认值。</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STAT</name>
          <description>SAIF Status Register</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>BUSY</name>
              <description>SAIF 忙状态指示，置位表示 SAIF 正在数据发送或接收中。</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_SERVICE_IRQ</name>
              <description>FIFO 服务中断状态，置位表示 FIFO 需要服务（可从 DATA 读写数据）。写 1 清零。</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_OVERFLOW_IRQ</name>
              <description>FIFO 上溢中断状态，置位表示接收 FIFO 发生上溢。写 1 清零。</description><bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_UNDERFLOW_IRQ</name>
              <description>FIFO 下溢中断状态，置位表示发送 FIFO 发生下溢。写 1 清零。</description><bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMA_PREQ</name>
              <description>DMA 请求状态，反映当前 DMA 请求线的状态。只读。</description><bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PRESENT</name>
              <description>SAIF 模块存在标志，只读。1=SAIF 模块在本芯片中存在。</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
          <description>SAIF Data Register</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>PCM_LEFT</name>
              <description>左声道 PCM 数据，存放 I2S 左声道音频采样数据（高 16 位）。</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>PCM_RIGHT</name>
              <description>右声道 PCM 数据，存放 I2S 右声道音频采样数据（低 16 位）。</description><bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>SAIF Version Register</description>
          <addressOffset>0x30</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>SAIF 模块修订步进号，只读。</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>SAIF 模块次版本号，只读。</description><bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>SAIF 模块主版本号，只读。</description><bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>POWER</name>
      <description>STMP3770 电源管理单元(POWER)寄存器与位域中文描述。涵盖电源控制、5V控制、低功耗、电池充电、各电源域(VDDD/VDDA/VDDIO)控制、DC-DC多输出转换、占空比限制、反馈环路、状态、晶体管速度、电池监测、复位、调试、测试及版本寄存器。注：VDD5V_DROOP(64)和DCDC4P2_BO(65)为POWER模块内部中断，不路由至ICOLL。</description>
      <groupName>Power</groupName>
      <baseAddress>0x80044000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x140</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>VDD5V</name>
        <value>3</value>
      </interrupt>
      <interrupt>
        <name>BATT_BRNOUT</name>
        <value>32</value>
      </interrupt>
      <interrupt>
        <name>VDDD_BRNOUT</name>
        <value>33</value>
      </interrupt>
      <interrupt>
        <name>VDDIO_BRNOUT</name>
        <value>34</value>
      </interrupt>
      <interrupt>
        <name>VDD18_BRNOUT</name>
        <value>35</value>
      </interrupt>
      <interrupt>
        <name>VDD5V_DROOP</name>
        <value>64</value>
      </interrupt>
      <interrupt>
        <name>DCDC4P2_BO</name>
        <value>65</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL</name>
          <description>电源控制寄存器，集中管理各电源事件的中断使能、中断状态、极性配置及模块时钟门控。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>ENIRQ_VDD5V_GT_VDDIO</name>
              <description>VDD5V 高于 VDDIO 中断使能。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VDD5V_GT_VDDIO_IRQ</name>
              <description>VDD5V 高于 VDDIO 中断状态(写1清零)。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>POLARITY_VDD5V_GT_VDDIO</name>
              <description>VDD5V 高于 VDDIO 中断极性选择。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENIRQ_VBUS_VALID</name>
              <description>VBUS 有效中断使能。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VBUSVALID_IRQ</name>
              <description>VBUS 有效中断状态(写1清零)。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>POLARITY_VBUSVALID</name>
              <description>VBUS 有效中断极性选择。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENIRQ_VDDD_BO</name>
              <description>VDDD 欠压中断使能。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VDDD_BO_IRQ</name>
              <description>VDDD 欠压中断状态(写1清零)。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENIRQ_VDDA_BO</name>
              <description>VDDA 欠压中断使能。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VDDA_BO_IRQ</name>
              <description>VDDA 欠压中断状态(写1清零)。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENIRQ_VDDIO_BO</name>
              <description>VDDIO 欠压中断使能。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VDDIO_BO_IRQ</name>
              <description>VDDIO 欠压中断状态(写1清零)。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENIRQBATT_BO</name>
              <description>电池欠压中断使能。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BATT_BO_IRQ</name>
              <description>电池欠压中断状态(写1清零)。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENIRQ_DC_OK</name>
              <description>DC-DC 正常中断使能。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DC_OK_IRQ</name>
              <description>DC-DC 正常中断状态(写1清零)。</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENIRQ_LINREG_OK</name>
              <description>线性稳压器正常中断使能。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LINREG_OK_IRQ</name>
              <description>线性稳压器正常中断状态(写1清零)。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>POLARITY_LINREG_OK</name>
              <description>线性稳压器正常中断极性选择。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENIRQ_PSWITCH</name>
              <description>PSWITCH 中断使能。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>POLARITY_PSWITCH</name>
              <description>PSWITCH 中断极性选择。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PSWITCH_IRQ_SRC</name>
              <description>PSWITCH 中断源选择。</description>
              <bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PSWITCH_IRQ</name>
              <description>PSWITCH 中断状态(写1清零)。</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>POWER 模块时钟门控，置1关闭时钟以节能。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>_5VCTRL</name>
          <description>DC-DC 5V 控制寄存器，管理 DCDC 使能、VBUS 检测、电流限制及 5V 欠压保护。</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>ENABLE_DCDC</name>
              <description>使能 DC-DC 转换器。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OTG_PWRUP_CMPS</name>
              <description>OTG 比较器上电控制。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ILIMIT_EQ_ZERO</name>
              <description>电流限制置零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VBUSVALID_TO_B</name>
              <description>VBUS 有效信号路由到 B 端。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VBUSVALID_5VDETECT</name>
              <description>VBUS 有效检测来自 5V 检测电路。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EN_BATT_PULLDN</name>
              <description>使能电池下拉。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DCDC_XFER</name>
              <description>DC-DC 转换模式切换。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE_ILIMIT</name>
              <description>使能电流限制功能。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PWDN_5VBRNOUT</name>
              <description>5V 欠压掉电控制。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VBUSVALID_TRSH</name>
              <description>VBUS 有效检测阈值选择。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MINPWR</name>
          <description>DC-DC 最小功耗及杂项控制寄存器，用于降低功耗、控制振荡器及 FET 驱动。</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>DC_HALFCLK</name>
              <description>DC-DC 时钟减半以降低功耗。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EN_DC_PFM</name>
              <description>使能 DC-DC PFM(脉冲频率调制)模式。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DC_STOPCLK</name>
              <description>停止 DC-DC 时钟。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PWD_XTAL24</name>
              <description>24MHz 晶振掉电控制。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LESSANA_I</name>
              <description>减小模拟偏置电流。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HALF_FETS</name>
              <description>FET 驱动能力减半。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DOUBLE_FETS</name>
              <description>FET 驱动能力加倍。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VBG_OFF</name>
              <description>带隙基准关闭。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SELECT_OSC</name>
              <description>选择内部振荡器作为 DC-DC 时钟源。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE_OSC</name>
              <description>使能内部振荡器。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
