              <bitOffset>16</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PORTSC1</name>
          <description>Port Status and Control 1 Register</description>
          <addressOffset>0x184</addressOffset>
          <fields>
            <field>
              <name>CCS</name>
              <description>当前连接状态（1=设备已连接，只读）</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CSC</name>
              <description>连接状态变化（写 1 清零）</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PE</name>
              <description>端口使能（1=端口已使能）</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PEC</name>
              <description>端口使能变化（写 1 清零）</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OCA</name>
              <description>过流状态（1=检测到过流，只读）</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OCC</name>
              <description>过流变化（写 1 清零）</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FPR</name>
              <description>强制端口恢复（写 1 从挂起恢复）</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SUSP</name>
              <description>挂起状态（1=端口已挂起）</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PR</name>
              <description>端口复位（写 1 启动端口复位，10ms 后硬件清零）</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HSP</name>
              <description>高速端口（1=端口工作于高速，只读）</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LS</name>
              <description>线路状态（SE0/K_STATE/J_STATE/UNDEF，反映 D+/D- 电平）</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SE0</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>K_STATE</name>
                  <value>1</value>
