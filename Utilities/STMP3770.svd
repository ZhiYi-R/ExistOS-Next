    <peripheral>
      <name>AUDIOOUT</name>
      <description>音频 DAC 输出(耳机/线路输出的音量、滤波与 DMA 控制)</description>
      <groupName>Audio</groupName>
      <baseAddress>0x80048000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x210</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>HEADPHONE_SHORT</name>
        <value>4</value>
      </interrupt>
      <interrupt>
        <name>DAC_DMA</name>
        <value>5</value>
      </interrupt>
      <interrupt>
        <name>DAC_ERROR</name>
        <value>6</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL</name>
          <description>AUDIOOUT Control Register</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>RUN</name>
              <description>AUDIOOUT Enable. Set to 1 to start operation with DMA request. Clear to 0 stops conversion and sets CLKGATE.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_ERROR_IRQ_EN</name>
              <description>FIFO Error Interrupt Enable. Enables interrupt when overflow or underflow status bits are set.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_OVERFLOW_IRQ</name>
              <description>FIFO Overflow Interrupt Status. Set by hardware on FIFO overflow. Clear by writing 1 to CLR register.</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_UNDERFLOW_IRQ</name>
              <description>FIFO Underflow Interrupt Status. Set by hardware on FIFO underflow. Clear by writing 1 to CLR register.</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LOOPBACK</name>
              <description>AUDIOIN-to-AUDIOOUT Loopback Enable. Routes AUDIOIN FIFO data to AUDIOOUT FIFO for test.</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DAC_ZERO_ENABLE</name>
              <description>Quiet Output Enable. Causes SDM to transmit alternating ones and zeros for pop-suppression. Reset by power-on reset only.</description><bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WORD_LENGTH</name>
              <description>PCM Audio Bit Size Select. 0=32-bit PCM samples, 1=16-bit samples.</description><bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SS3D_EFFECT</name>
              <description>Virtual 3D Effect Enable. Subtracts opposite channel content. 00=Off, 01=Low (3dB), 10=Medium (4.5dB), 11=High (6dB).</description><bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>INVERT_1BIT</name>
              <description>Invert Serial Audio Output Enable. Inverts the 1-bit serial output of both channels to the sigma-delta modulator.</description><bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EDGE_SYNC</name>
              <description>Serial Output Clock Edge Sync Select. 0=Rising edge, 1=Falling edge for SDM synchronization.</description><bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LR_SWAP</name>
              <description>Left/Right Output Channel Swap Enable. When set, swaps left and right serial audio outputs from SDM to analog DAC.</description><bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAWAIT_COUNT</name>
              <description>DMA Request Delay Count. Specifies number of APBX clock cycles (0 to 31) to delay before each DMA request. Acts as a bandwidth throttle.</description><bitOffset>16</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>Clock Gate Enable. When set to 1, gates off clocks to DIGFILT portions controlling only output audio functions. Clear to 0 for normal operation.</description><bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SFTRST</name>
              <description>Module Soft Reset. Set to 1 to force reset to portions of DIGFILT controlling AUDIOOUT, then gates clocks off. Clear to 0 for normal operation.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STAT</name>
          <description>AUDIOOUT Status Register</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>DAC_PRESENT</name>
              <description>AUDIOOUT Functionality Present. Set to 1 if DAC is present. 0 means permanently disabled.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DACSRR</name>
          <description>AUDIOOUT Sample Rate Register</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>SRC_FRAC</name>
              <description>Sample Rate Conversion Fraction Factor. Fractional portion of divide term for sample rate conversion.</description><bitOffset>0</bitOffset>
              <bitWidth>13</bitWidth>
            </field>
            <field>
              <name>SRC_INT</name>
              <description>Sample Rate Conversion Integer Factor. Integer portion of divide term for sample rate conversion.</description><bitOffset>16</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>SRC_HOLD</name>
              <description>Sample Rate Conversion Hold Factor. Used to generate half/quarter sample rates.</description><bitOffset>24</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>BASEMULT</name>
              <description>Base Sample Rate Multiplier. 0x1=Single (48/44.1/32 kHz), 0x2=Double (96/88.2/64 kHz), 0x4=Quad (192/176.4/128 kHz).</description><bitOffset>28</bitOffset>
              <bitWidth>3</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SINGLE_RATE</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DOUBLE_RATE</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>QUAD_RATE</name>
                  <value>4</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>OSR</name>
              <description>Oversample Rate. Fixed at 6 MHz for STMP3770. 0x0=6 MHz, 0x1=12 MHz.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>OSR6</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OSR12</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>DACVOLUME</name>
          <description>AUDIOOUT Volume Register</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>VOLUME_RIGHT</name>
              <description>Right Channel Volume Setting. -0.5dB (0xFE) to -100dB (0x37). Each increment = +0.5dB.</description><bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MUTE_RIGHT</name>
              <description>Mute Right Channel. 0=Unmute, 1=Mute. Applied immediately.</description><bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VOLUME_UPDATE_RIGHT</name>
              <description>Right Channel Volume Update Pending. Set by hardware when volume update pending on right channel zero-crossing.</description><bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VOLUME_LEFT</name>
              <description>Left Channel Volume Setting. -0.5dB (0xFE) to -100dB (0x37). Each increment = +0.5dB.</description><bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MUTE_LEFT</name>
              <description>Mute Left Channel. 0=unmute, 1=mute. Applied immediately.</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EN_ZCD</name>
              <description>Enable Zero-Cross Detect. When enabled, volume changes applied only at zero-crossing.</description><bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VOLUME_UPDATE_LEFT</name>
              <description>Left Channel Volume Update Pending. Set by hardware when volume update pending on left channel zero-crossing.</description><bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DACDEBUG</name>
          <description>AUDIOOUT Debug Register</description>
          <addressOffset>0x40</addressOffset>
          <fields>
            <field>
              <name>FIFO_STATUS</name>
              <description>FIFO Status. Set when FIFO has empty entries, cleared when full.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMA_PREQ</name>
              <description>DMA Request Status. Current state of AUDIOOUT DMA request signal. Can be polled for manual FIFO filling.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SET_INTERRUPT0_HAND_SHAKE</name>
              <description>Interrupt[0] Status. State of APBX interface state machine interrupt[0] signal. Test only.</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SET_INTERRUPT1_HAND_SHAKE</name>
              <description>Interrupt[1] Status. State of APBX interface state machine interrupt[1] signal. Test only.</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SET_INTERRUPT0_CLK_CROSS</name>
              <description>Interrupt[0] Sync Status. State of sync flop chain for interrupt[0] signal. Test only.</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SET_INTERRUPT1_CLK_CROSS</name>
              <description>Interrupt[1] Sync Status. State of sync flop chain for interrupt[1] signal. Test only.</description><bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RAM_SS</name>
              <description>DIGFILT RAM Speed Select. Sense AMP timing control. Do not alter unless instructed by SigmaTel.</description><bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>ENABLE_DACDMA</name>
              <description>Digital Path Test Enable. Bypasses DAC analog for debug; transfers serial audio data via AUDIOIN DMA Channel 0.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>HPVOL</name>
          <description>Headphone Volume and Select Control Register</description>
          <addressOffset>0x50</addressOffset>
          <fields>
            <field>
              <name>VOL_RIGHT</name>
              <description>Right Headphone Volume Control. 0.5dB steps. Same ranges as VOL_LEFT. Reset=0x0C (0dB). Power-on reset only.</description><bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>VOL_LEFT</name>
              <description>Left Headphone Volume Control. 0.5dB steps. DAC mode: 0x00=+6dB to 0x7F=-57.5dB. Line1 mode: 0x00=+12dB to 0x7F=-51.5dB. Reset=0x0C (0dB). Power-on reset only.</description><bitOffset>8</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>SELECT</name>
              <description>Input Signal Select. 0=DAC, 1=Line1. Reset by power-on reset only.</description><bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MUTE</name>
              <description>Headphone Mute. Reset by power-on reset only.</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EN_MSTR_ZCD</name>
              <description>Enable Zero-Cross Detect for Headphone Amplifier.</description><bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VOLUME_UPDATE_PENDING</name>
              <description>Volume Update Pending. Set when headphone volume update waiting on zero-crossing.</description><bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RESERVED</name>
          <description>Reserved Register</description>
          <addressOffset>0x60</addressOffset>
        </register>
        <register>
          <name>PWRDN</name>
          <description>Audio Power-Down Control Register</description>
          <addressOffset>0x70</addressOffset>
          <fields>
            <field>
              <name>HEADPHONE</name>
              <description>Master (Headphone) Power Down. Reset by power-on reset only.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CAPLESS</name>
              <description>Power Down Headphone Common Amplifier for Capless Headphone. Reset by power-on reset only.</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ADC</name>
              <description>Power Down ADC and Input Mux Circuitry. ADC function; reset by ADC SFTRST.</description><bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DAC</name>
              <description>Power Down DAC Analog Circuitry. Reset by power-on reset only.</description><bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RIGHT_ADC</name>
              <description>Right ADC Power Down. Powers down ADC right channel for mono operation. ADC function; reset by ADC SFTRST.</description><bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SELFBIAS</name>
              <description>Currently does not control any logic; altering has no effect.</description><bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SPEAKER</name>
              <description>扬声器功放掉电，写1关闭以省电。</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>REFCTRL</name>
          <description>AUDIOOUT Reference Control Register</description>
          <addressOffset>0x80</addressOffset>
          <fields>
            <field>
              <name>DAC_ADJ</name>
              <description>These bits have no effect.</description><bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>VAG_VAL</name>
              <description>VAG Reference Value. When ADJ_VAG=1: 0x7=1.0V, 0x0=0.825V, 25mV steps. Affected by RAISE_REF. Power-on reset only.</description><bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>ADC_REFVAL</name>
              <description>ADC Reference Value. When ADJ_ADC=1: 0x7=1.60V, 0x0=1.425V, 25mV steps. Affected by RAISE_REF.</description><bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>ADJ_VAG</name>
              <description>VAG select. 0=VDD/2 (resistor divider). 1=controlled by VAG_VAL. Controls both DAC and ADC. Power-on reset only.</description><bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ADJ_ADC</name>
              <description>ADC Reference Voltage Adjust. 0=1.5V/1.31V fixed ref. 1=controlled by ADC_REFVAL. Must be set when both ADC and DAC enabled.</description><bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VDDXTAL_TO_VDDD</name>
              <description>Shorts XTAL oscillator supply to VDDD to reduce power. ADC function; reset by ADC SFTRST.</description><bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BIAS_CTRL</name>
              <description>Bias current control for all analog blocks. 00=Nominal, 01=-20%, 10=-10%, 11=+10%. Test/debug only. Power-on reset only.</description><bitOffset>16</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>LW_REF</name>
              <description>This bit currently does not control any logic; altering its value has no effect.</description><bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LOW_PWR</name>
              <description>Lowers bandgap amplifier power (~100uA). Useful in USB suspend/standby. Power-on reset only.</description><bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VBG_ADJ</name>
              <description>VBG adjustment. Affects ALL references. 000=Nominal, 001=+0.3%, 010=+0.6%, 011=+0.85%, 100=-0.3%, 101=-0.6%, 110=-0.9%, 111=-1.2%. Power-on reset only.</description><bitOffset>20</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>XTAL_BGR_BIAS</name>
              <description>Switch XTAL bias from self-bias to bandgap-based. Powers both DAC and ADC. Reset by power-on reset only.</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RAISE_REF</name>
              <description>Must be low when VDDA &lt; ~1.7V. When low, VAG and ADC ref voltages drop by factor 0.875.</description><bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FASTSETTLING</name>
              <description>Increases vag buffer output current by 2X to 20uA to improve startup settling time.</description><bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ANACTRL</name>
          <description>Miscellaneous Audio Controls Register</description>
          <addressOffset>0x90</addressOffset>
          <fields>
            <field>
              <name>HP_CLASSAB</name>
              <description>Headphone amplifier mode. 0=ClassA (for power-up/down and short handling). 1=ClassAB (normal operation). Power-on reset only.</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HP_HOLD_GND</name>
              <description>Hold Headphone Output to Ground. Used for power-up/power-down procedures. Power-on reset only.</description><bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SHORT_LVLADJR</name>
              <description>Adjust right headphone current short detect trip point. 000=Nominal, +/-25/50/75/100%. Power-on reset only.</description><bitOffset>8</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>SHORT_LVLADJL</name>
              <description>Adjust left headphone current short detect trip point. 000=Nominal, +/-25/50/75/100%. Power-on reset only.</description><bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>SHORTMODE_LR</name>
              <description>Headphone L/R Channel Short Control. 00=Reset latch no power-down, 01=Latch short signal with HW power-down.</description><bitOffset>17</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SHORTMODE_CM</name>
              <description>Headphone Common Mode Amplifier Short Control. 00=Reset analog latch, 01=Latch short signal and HW power down.</description><bitOffset>20</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SHORT_LR_STS</name>
              <description>Status of headphone amplifier short detection. 0=No short. Clear and rearm via SHORTMODE_LR sequence.</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SHORT_CM_STS</name>
              <description>Status of common mode amplifier short detection. 0=No short. Clear and rearm via SHORTMODE_CM sequence.</description><bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TEST</name>
          <description>Miscellaneous Test Audio Controls Register</description>
          <addressOffset>0xA0</addressOffset>
          <fields>
            <field>
              <name>DAC_DIS_RTZ</name>
              <description>Set to 1 to disable DAC RTZ mode. Test-only. Should remain cleared.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DAC_DOUBLE_I</name>
              <description>Set to 1 to double ClassA current in DAC amplifier (+360uA each DAC).</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DAC_CLASSA</name>
              <description>Set to 1 to disable ClassAB mode in DAC (+~600uA).</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ADCTODAC_LOOP</name>
              <description>ADC到DAC环回测试使能。</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VAG_DOUBLE_I</name>
              <description>Set to 1 to double ClassA current in VAG amplifier (+240uA). Power-on reset only.</description><bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VAG_CLASSA</name>
              <description>Set to 1 to disable ClassAB mode in VAG Amp (+~200uA). Controls both DAC and ADC. Power-on reset only.</description><bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HP_IALL_ADJ</name>
              <description>Adjust all bias current in headphone amplifier. 00=Nominal, 01=-50%, 10=+50%, 11=-40%. Power-on reset only.</description><bitOffset>20</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>HP_I1_ADJ</name>
              <description>Adjust bias current in first stage of headphone amplifier. 00=Nominal, 01=-50%, 10=+100%, 11=+50%. Power-on reset only.</description><bitOffset>22</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TM_HPCOMMON</name>
              <description>Testmode: use headphone common VAG in ADC Mux for analog loopback DAC-HP-ADC.</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TM_LOOP</name>
              <description>测试模式环回使能。</description><bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TM_ADCIN_TOHP</name>
              <description>Testmode: pipe ADC Mux Out to Headphone Output pins. ADC function; reset by ADC SFTRST.</description><bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HP_ANTIPOP</name>
              <description>Reserved.</description><bitOffset>28</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>BISTCTRL</name>
          <description>BIST Control and Status Register</description>
          <addressOffset>0xB0</addressOffset>
          <fields>
            <field>
              <name>START</name>
              <description>Initiate BIST of internal memory.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DONE</name>
              <description>BIST has completed.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PASS</name>
              <description>BIST has passed.</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FAIL</name>
              <description>BIST has failed.</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>BISTSTAT0</name>
          <description>Hardware BIST Status 0 Register</description>
          <addressOffset>0xC0</addressOffset>
          <fields>
            <field>
              <name>DATA</name>
              <description>Failing data at the failing address.</description><bitOffset>0</bitOffset>
              <bitWidth>24</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>BISTSTAT1</name>
          <description>Hardware AUDIOUT BIST Status 1 Register</description>
          <addressOffset>0xD0</addressOffset>
          <fields>
            <field>
              <name>ADDR</name>
              <description>Failing address from BIST.</description><bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>STATE</name>
              <description>Fail state of the BIST engine.</description><bitOffset>24</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ANACLKCTRL</name>
          <description>Analog Clock Control Register</description>
          <addressOffset>0xE0</addressOffset>
          <fields>
            <field>
              <name>DACDIV</name>
              <description>DAC Analog Clock Divider. Selects oversampling clock rate. 000=6MHz, 001=4MHz, 010/100=3MHz, 011/101=2MHz, 110=1.5MHz, 111=1MHz.</description><bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>INVERT_DACCLK</name>
              <description>DAC Clock Invert. Invert DAC_CLK for sigma-delta converter and digital filters.</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>Analog clock Gate. Gate clocks for DAC converter and digital filter. Reset by power-on reset only.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
          <description>AUDIOOUT Write Data Register</description>
          <addressOffset>0xF0</addressOffset>
          <fields>
            <field>
              <name>LOW</name>
              <description>Left Sample or Sample Low Half-Word. For 16-bit mode: left channel. For 32-bit mode: LSB 16 bits.</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>HIGH</name>
              <description>Right Sample or Sample High Half-Word. For 16-bit mode: right channel. For 32-bit mode: MSB 16 bits.</description><bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SPEAKERCTRL</name>
          <description>AUDIOOUT Speaker Control Register</description>
          <addressOffset>0x100</addressOffset>
          <fields>
            <field>
              <name>NEGDRIVER</name>
              <description>扬声器负端驱动控制。</description><bitOffset>12</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>POSDRIVER</name>
              <description>扬声器正端驱动控制。</description><bitOffset>14</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>IALL_ADJ</name>
              <description>扬声器总电流调整。</description><bitOffset>20</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>I1_ADJ</name>
              <description>扬声器段1电流调整。</description><bitOffset>22</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>MUTE</name>
              <description>扬声器静音控制。</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>AUDIOOUT Version Register</description>
          <addressOffset>0x200</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>Fixed read-only RTL version stepping field. Reset=0x0000.</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>Fixed read-only RTL version minor field. Reset=0x01.</description><bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>Fixed read-only RTL version major field. Reset=0x01.</description><bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>AUDIOIN</name>
      <description>音频 ADC 输入(麦克风/线路输入采集与 DMA 控制)</description>
      <groupName>Audio</groupName>
      <baseAddress>0x8004C000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x90</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>ADC_DMA</name>
        <value>7</value>
      </interrupt>
      <interrupt>
        <name>ADC_ERROR</name>
        <value>8</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL</name>
          <description>AUDIOIN Control Register</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>RUN</name>
              <description>AUDIOIN Enable. Setting to 1 starts data conversion; DMA request made after 8 words collected. Clearing to 0 stops conversion and sets CLKGATE.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_ERROR_IRQ_EN</name>
              <description>FIFO Error Interrupt Enable. Set to 1 to enable interrupt request when FIFO overflow or underflow status bits are set.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_OVERFLOW_IRQ</name>
              <description>FIFO Overflow Interrupt Status Bit. Set by hardware on FIFO overflow due to unserviced DMA request. Cleared by writing 1 to SET/CLR address.</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_UNDERFLOW_IRQ</name>
              <description>FIFO Underflow Interrupt Status Bit. Set by hardware on FIFO underflow. Cleared by writing 1 to SET/CLR address. IRQ issued if FIFO_ERROR_IRQ_EN=1.</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LOOPBACK</name>
              <description>AUDIOOUT-to-AUDIOIN Loopback Enable. Setting to 1 connects AUDIOOUT serial data to AUDIOIN CIC input, bypassing analog DAC and ADC.</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WORD_LENGTH</name>
              <description>PCM Audio Bit Size Select. 0 = 32-bit PCM samples, 1 = 16-bit samples. 24-bit FIR output is sign-extended to 32 or truncated to 16.</description><bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HPF_ENABLE</name>
              <description>ADC High-Pass Filter Enable. When set, enables the ADC analog high-pass filter. Used with OFFSET_ENABLE for DC offset removal.</description><bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OFFSET_ENABLE</name>
              <description>ADC Analog High-Pass Filter Offset Calculation Enable. When set, the HPF actively adjusts serial audio input removing DC offset. Requires HPF_ENABLE=1.</description><bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>INVERT_1BIT</name>
              <description>Invert Serial Audio Input Enable. When set, inverts the 1-bit serial input of both channels from the ADC sigma-delta modulator.</description><bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EDGE_SYNC</name>
              <description>Serial Input Clock Edge Sync Select. 0 = Rising edge, 1 = Falling edge for CIC filter data receive synchronization.</description><bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LR_SWAP</name>
              <description>Left/Right Input Channel Swap Enable. Setting to 1 swaps the left and right serial audio inputs from the ADC before CIC block processing.</description><bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAWAIT_COUNT</name>
              <description>DMA Request Delay Count. Specifies number of APBX clock cycles (0-31) to delay before each DMA request. Acts as bandwidth throttle for DIGFILT.</description><bitOffset>16</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>AUDIOIN Clock Gate Enable. When set to 1, gates off clocks to DIGFILT portions controlling input audio functions. Does not affect AUDIOOUT. Clear to 0 for normal operation.</description><bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SFTRST</name>
              <description>AUDIOIN Module Soft Reset. Setting to 1 forces reset to DIGFILT portions that control audio input and gates clocks off. Must be cleared to 0 for normal operation.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STAT</name>
          <description>AUDIOIN Status Register</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>ADC_PRESENT</name>
              <description>AUDIOIN Functionality Present. Set to 1 in products that include AUDIOIN/ADC. If 0, the AUDIOIN/ADC is permanently disabled.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ADCSRR</name>
          <description>AUDIOIN Sample Rate Register</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>SRC_FRAC</name>
              <description>Sample Rate Conversion Fraction Factor. Fractional portion of divide term. Reset 0x37. Used in sample rate equation.</description><bitOffset>0</bitOffset>
              <bitWidth>13</bitWidth>
            </field>
            <field>
              <name>SRC_INT</name>
              <description>Sample Rate Conversion Integer Factor. Integer portion of divide term. Reset 0x11. Used in sample rate equation.</description><bitOffset>16</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>SRC_HOLD</name>
              <description>Sample Rate Conversion Hold Factor. Used to generate half/quarter sample rates. Equation: output_sample_rate = (6e6 * BASEMULT) / (SRC_INT.SRC_FRAC * 8 * (SRC_HOLD+1)).</description><bitOffset>24</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>BASEMULT</name>
              <description>Base Sample Rate Multiplier. 0x1 = Single (48/44.1/32 kHz), 0x2 = Double (96/88.2/64 kHz), 0x4 = Quad (192/176.4/128 kHz).</description><bitOffset>28</bitOffset>
              <bitWidth>3</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SINGLE_RATE</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DOUBLE_RATE</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>QUAD_RATE</name>
                  <value>4</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>OSR</name>
              <description>AUDIOIN Oversample Rate (read-only). 0x0 = 6 MHz, 0x1 = 12 MHz. Fixed at 6 MHz for STMP3770.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>OSR6</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OSR12</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>ADCVOLUME</name>
          <description>AUDIOIN Volume Register</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>VOLUME_RIGHT</name>
              <description>Right Channel Volume Setting. Range -0.5 dB (0xFE reset) to -100 dB (0x37). Each increment = +0.5 dB. Values 0x00-0x37 = -100 dB. 0xFF reserved.</description><bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>VOLUME_UPDATE_RIGHT</name>
              <description>Right Channel Volume Update Pending. Set by hardware when volume update is pending (waiting on zero-crossing on right channel). Not used when EN_ZCD=0.</description><bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VOLUME_LEFT</name>
              <description>Left Channel Volume Setting. Range -0.5 dB (0xFE reset) to -100 dB (0x37). Each increment = +0.5 dB. Values 0x00-0x37 = -100 dB. 0xFF reserved.</description><bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>EN_ZCD</name>
              <description>Enable Zero-Cross Detect. When enabled, volume changes are applied only on zero-crossing. When disabled, changes take effect immediately.</description><bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VOLUME_UPDATE_LEFT</name>
              <description>Left Channel Volume Update Pending. Set by hardware when volume update is pending (waiting on zero-crossing on left channel). Not used when EN_ZCD=0.</description><bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ADCDEBUG</name>
          <description>AUDIOIN Debug Register</description>
          <addressOffset>0x40</addressOffset>
          <fields>
            <field>
              <name>FIFO_STATUS</name>
              <description>FIFO Status. Set when AUDIOIN FIFO contains any valid data. Cleared when FIFO is empty.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMA_PREQ</name>
              <description>DMA Request Status. Reflects AUDIOIN DMA request signal state. Can be polled to manually move samples when DMA channel not used.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SET_INTERRUPT3_HAND_SHAKE</name>
              <description>Interrupt[3] Status. Reflects APBX interface state machine internal interrupt[3] for DigFilt DMA channel priority. Test only.</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ADC_DMA_REQ_HAND_SHAKE_CLK_CROSS</name>
              <description>DMA Request Sync Status. Reflects state of second flop in the sync chain for AUDIOIN DMA request (24 MHz to APBX clock domain). Test only.</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE_ADCDMA</name>
              <description>AUDIOIN Digital Path Test Enable. For debug only. Causes serial audio data to bypass CIC block and transfer via AUDIOOUT DMA Channel 1.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ADCVOL</name>
          <description>ADC Mux Volume and Select Control Register</description>
          <addressOffset>0x50</addressOffset>
          <fields>
            <field>
              <name>GAIN_RIGHT</name>
              <description>Right Channel ADC Gain. Each increment = 1.5 dB. 0x0 = 0 dB, 0x1 = 1.5 dB, ... up to 0xF = 22.5 dB.</description><bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>SELECT_RIGHT</name>
              <description>ADC Right Channel Input Source Select. 00 = Microphone, 01 = Line1, 10 = Headphone, 11 = Reserved.</description><bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>GAIN_LEFT</name>
              <description>Left Channel ADC Gain. Each increment = 1.5 dB. 0x0 = 0 dB, 0x1 = 1.5 dB, ... up to 0xF = 22.5 dB.</description><bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>SELECT_LEFT</name>
              <description>ADC Left Channel Input Source Select. 00 = Microphone, 01 = Line1, 10 = Headphone, 11 = Reserved.</description><bitOffset>12</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>MUTE</name>
              <description>ADC Mute. 0 = Unmute, 1 = Mute. When set, mutes both left and right channel analog inputs.</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EN_ADC_ZCD</name>
              <description>Enable Zero-Cross Detect for ADC Amplifier.</description><bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VOLUME_UPDATE_PENDING</name>
              <description>Volume Update Pending. Set when ADC left or right volume update is pending (waiting on zero-crossing). Cleared when both gains are applied.</description><bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MICLINE</name>
          <description>Microphone and Line Control Register</description>
          <addressOffset>0x60</addressOffset>
          <fields>
            <field>
              <name>MIC_GAIN</name>
              <description>Microphone Gain. 00 = 0 dB, 01 = 20 dB, 10 = 30 dB, 11 = 40 dB.</description><bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>MIC_CHOPCLK</name>
              <description>Microphone Amplifier Chopping Clock. 00 = Disabled, 01 = 192 kHz, 10 = 96 kHz, 11 = 48 kHz.</description><bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>MIC_BIAS</name>
              <description>Microphone Bias Voltage Select. 0 = 1.21 V, 1 = 1.46 V, up to 7 = 2.96 V (0.25 V increments).</description><bitOffset>16</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>MIC_RESISTOR</name>
              <description>Microphone Bias Resistor Select. 00 = Off, 01 = 2 KOhm, 10 = 4 KOhm, 11 = 8 KOhm. ADC block must be powered on before Micbias.</description><bitOffset>20</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>MIC_SELECT</name>
              <description>Microphone Bias Pin Select. When MIC_RESISTOR enabled, selects Micbias voltage reference pin source. 0 = LRADC0, 1 = LRADC1.</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DIVIDE_LINE2</name>
              <description>线路输入2分压控制。</description><bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DIVIDE_LINE1</name>
              <description>Attenuate Line1 Input. With 10K external series resistor, attenuates Line1 by 9.5 dB (+/-1.5 dB) for 2-Vrms input. Affects both channels of ADC and headphone.</description><bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ANACLKCTRL</name>
          <description>Analog Clock Control Register</description>
          <addressOffset>0x70</addressOffset>
          <fields>
            <field>
              <name>ADCDIV</name>
              <description>ADC Analog Clock Divider. Selects oversampling clock rate: 000=6 MHz, 001=4 MHz, 010/100=3 MHz, 011/101=2 MHz, 110=1.5 MHz, 111=1 MHz.</description><bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>INVERT_ADCCLK</name>
              <description>ADC Clock Invert. Set to invert ADC_CLK for the sigma-delta converter and associated digital filters.</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLOW_DITHER</name>
              <description>Slow Dither. When dither enabled (DITHER_OFF=0) and this bit set, ADC input signal dithering is slowed to half rate.</description><bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DITHER_OFF</name>
              <description>ADC Dither Disable. When set, dither is disabled within the ADC.</description><bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>Analog Clock Gate. Set to gate the clocks for the ADC converter and associated digital filter.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
          <description>AUDIOIN Read Data Register</description>
          <addressOffset>0x80</addressOffset>
          <fields>
            <field>
              <name>LOW</name>
              <description>Left Sample or Sample Low Half-Word. 16-bit mode: left channel sample. 32-bit mode: least significant 16 bits of sample.</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>HIGH</name>
              <description>Right Sample or Sample High Half-Word. 16-bit mode: right channel sample. 32-bit mode: most significant 16 bits of sample.</description><bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>LRADC</name>
      <description>STMP3770 LRADC 外设寄存器与位域中文描述</description>
      <groupName>Analog</groupName>
      <baseAddress>0x80050000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x160</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>TOUCH_DETECT</name>
        <value>36</value>
      </interrupt>
      <interrupt>
        <name>LRADC_CH0</name>
        <value>37</value>
      </interrupt>
      <interrupt>
        <name>LRADC_CH1</name>
        <value>38</value>
      </interrupt>
      <interrupt>
        <name>LRADC_CH2</name>
        <value>39</value>
      </interrupt>
      <interrupt>
        <name>LRADC_CH3</name>
        <value>40</value>
      </interrupt>
      <interrupt>
        <name>LRADC_CH4</name>
        <value>41</value>
      </interrupt>
      <interrupt>
        <name>LRADC_CH5</name>
        <value>42</value>
      </interrupt>
      <interrupt>
        <name>LRADC_CH6</name>
        <value>43</value>
      </interrupt>
      <interrupt>
        <name>LRADC_CH7</name>
        <value>44</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL0</name>
          <description>LRADC 控制寄存器 0，负责通道调度、触摸屏电极使能、片内地参考及模块级时钟/复位控制。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>SCHEDULE</name>
              <description>8 位按位调度掩码，置位对应位即启动 LRADC 通道 0~7 的 ADC 转换。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>XPLUS_ENABLE</name>
              <description>触摸屏 X+ 电极驱动使能，ON 时接通 X+ 面板电极用于坐标采样。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>OFF</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ON</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>YPLUS_ENABLE</name>
              <description>触摸屏 Y+ 电极驱动使能，ON 时接通 Y+ 面板电极用于坐标采样。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>OFF</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ON</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>XMINUS_ENABLE</name>
              <description>触摸屏 X- 电极驱动使能，ON 时接通 X- 面板电极用于坐标采样。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>OFF</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ON</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>YMINUS_ENABLE</name>
              <description>触摸屏 Y- 电极驱动使能，ON 时接通 Y- 面板电极用于坐标采样。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>OFF</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ON</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>TOUCH_DETECT_ENABLE</name>
