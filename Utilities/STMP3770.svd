              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>CH9</name>
              <description>Ch9，2位读写字段。</description><bitOffset>18</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>CH10</name>
              <description>Ch10，2位读写字段。</description><bitOffset>20</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>CH11</name>
              <description>Ch11，2位读写字段。</description><bitOffset>22</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>CH12</name>
              <description>Ch12，2位读写字段。</description><bitOffset>24</bitOffset>
