    <peripheral>
      <name>GPMI</name>
      <description>NAND Flash 通用接口控制器，支持 NAND/ATA 模式，集成 ECC(BCH/ECC8) 纠错引擎，提供 DMA 数据传输、时序配置与命令执行功能。</description>
      <groupName>NAND</groupName>
      <baseAddress>0x8000C000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x100</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>GPMI_DMA</name>
        <value>13</value>
      </interrupt>
      <interrupt>
        <name>GPMI</name>
        <value>51</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL0</name>
          <description>GPMI 控制寄存器 0，配置单次命令传输的核心参数并启动执行。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>XFER_COUNT</name>
              <description>本次命令传输的字节数，0 表示 65536 字节。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>ADDRESS_INCREMENT</name>
              <description>地址自增使能：DISABLED=禁止自增；ENABLED=每传输一个字后地址自动递增。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>ADDRESS</name>
              <description>NAND 地址类型：NAND_DATA=数据寄存器；NAND_CLE=命令锁存使能；NAND_ALE=地址锁存使能。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>3</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NAND_DATA</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NAND_CLE</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NAND_ALE</name>
                  <value>2</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CS</name>
              <description>片选信号编号，选择当前操作的 NAND 设备(0~3)。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>LOCK_CS</name>
              <description>片选锁定使能：DISABLED=传输结束后自动释放 CS；ENABLED=锁定 CS 直到显式释放。</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>WORD_LENGTH</name>
              <description>数据位宽：_16_BIT=16 位；_8_BIT=8 位。</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>_16_BIT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_8_BIT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>COMMAND_MODE</name>
              <description>命令模式：WRITE=写数据；READ=读数据；READ_AND_COMPARE=读并比较；WAIT_FOR_READY=等待设备就绪。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>WRITE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>READ</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>READ_AND_COMPARE</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>WAIT_FOR_READY</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>UDMA</name>
              <description>UDMA 模式使能：DISABLED=禁用；ENABLED=启用 Ultra DMA 传输。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>TIMEOUT_IRQ_EN</name>
              <description>设备忙等待超时中断使能，置 1 允许超时中断上报。</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DEV_IRQ_EN</name>
              <description>设备就绪中断使能，置 1 允许设备就绪中断上报。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RUN</name>
              <description>命令执行状态：IDLE=空闲；BUSY=命令正在执行，写 1 启动命令。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUSY</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>时钟门控：RUN=正常运行；NO_CLKS=关闭 GPMI 时钟以节能。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RUN</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NO_CLKS</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SFTRST</name>
              <description>软复位：RUN=正常工作；RESET=复位整个 GPMI 模块。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RUN</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RESET</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>COMPARE</name>
          <description>读数据比较寄存器，用于 READ_AND_COMPARE 模式下的数据校验。</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>REFERENCE</name>
              <description>读数据比较的参考值。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MASK</name>
              <description>比较掩码，仅掩码为 1 的位参与比较。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ECCCTRL</name>
          <description>集成 ECC 控制寄存器，配置 ECC 引擎的操作模式与数据缓冲。</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>BUFFER_MASK</name>
              <description>ECC 数据缓冲掩码，选择参与 ECC 编解码的缓冲单元(BUFFER0~7、BCH_PAGE、BCH_AUXONLY)。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>9</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BCH_AUXONLY</name>
                  <value>256</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BCH_PAGE</name>
                  <value>511</value>
                </enumeratedValue>
                <enumeratedValue>
