                <enumeratedValue>
                  <name>_40</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_20</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ZERO</name>
                  <value>0</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>TEMP_SENSOR_IENABLE0</name>
