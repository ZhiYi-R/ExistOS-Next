            <field>
              <name>BM_KES_TEST_BYPASS</name>
              <description>Bus Master KES Test Bypass. RW, Reset=0x0. 1=Point synd_gen writes to dummy area for diagnostic preload of payload, parity, syndrome bytes.</description><bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NORMAL</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TEST_MODE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>KES_DEBUG_STALL</name>
              <description>KES Debug Stall. RW, Reset=0x0. Stall KES FSM after notifying Chien search but before notifying bus master. 0=proceed, 1=wait.</description><bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NORMAL</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>WAIT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>KES_DEBUG_STEP</name>
              <description>KES Debug Step. RW, Reset=0x0. Toggling skips KES FSM past stall state when in DEBUG_STALL mode and block done.</description><bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>KES_STANDALONE</name>
              <description>KES Standalone Mode. RW, Reset=0x0. Set to 1 to suppress KES_BM_DONE and CF_BM_DONE signal toggling to bus master.</description><bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NORMAL</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TEST_MODE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>KES_DEBUG_KICK</name>
              <description>KES Debug Kick. RW, Reset=0x0. Toggling starts KES engine FSM as if kicked by bus master for standalone testing.</description><bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>KES_DEBUG_MODE4K</name>
              <description>KES Debug 4K Mode. RW, Reset=0x0. Presented to KES as input mode. 4k(1)=4K NAND pages. 2k(1)=2K NAND pages.</description><bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>_4k</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>KES_DEBUG_PAYLOAD_FLAG</name>
              <description>KES Debug Payload Flag. RW, Reset=0x0. Presented to KES as input payload flag. DATA(1)=512B block. AUX(1)=65/19B auxiliary block.</description><bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DATA</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>KES_DEBUG_SHIFT_SYND</name>
              <description>KES Debug Shift Syndrome. RW, Reset=0x0. Toggling shifts KES_SYNDROME_SYMBOL into syndrome array. After 16 symbols, kick KES/CF by toggling KES_DEBUG_KICK.</description><bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>KES_DEBUG_SYNDROME_SYMBOL</name>
              <description>KES Debug Syndrome Symbol. RW, Reset=0x0. 9-bit value shifted into syndrome register array at KES input when KES_DEBUG_SHIFT_SYND toggles.</description><bitOffset>16</bitOffset>
              <bitWidth>9</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NORMAL</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TEST_MODE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>DBGKESREAD</name>
          <description>KES Debug Read Register</description>
          <addressOffset>0x40</addressOffset>
          <fields>
            <field>
              <name>VALUES</name>
              <description>Debug KES Read Values. RO, Reset=0x0. Reserved.</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DBGCSFEREAD</name>
          <description>Chien Search Forney Evaluator Debug Read Register</description>
          <addressOffset>0x50</addressOffset>
          <fields>
            <field>
              <name>VALUES</name>
              <description>Debug CSFE Read Values. RO, Reset=0x0. Reserved.</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DBGSYNDGENREAD</name>
          <description>Syndrome Generator Debug Read Register</description>
          <addressOffset>0x60</addressOffset>
          <fields>
            <field>
              <name>VALUES</name>
              <description>Debug Syndrome Generator Read Values. RO, Reset=0x0. Reserved.</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DBGAHBMREAD</name>
          <description>AHB Master and ECC8 Controller Debug Read Register</description>
          <addressOffset>0x70</addressOffset>
          <fields>
            <field>
              <name>VALUES</name>
              <description>Debug AHB Master Read Values. RO, Reset=0x0. Reserved.</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>BLOCKNAME</name>
          <description>ECC8 Block Name Register</description>
          <addressOffset>0x80</addressOffset>
          <fields>
            <field>
              <name>NAME</name>
              <description>Block Name. RO, Reset=0x38434345. ASCII '8','C','C','E' (ECC8). Readable as zero-terminated ASCII string.</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>ECC8 Version Register</description>
          <addressOffset>0xA0</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>Version Step. RO, Reset=0x0000. Fixed read-only stepping field of the RTL version.</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>Version Minor. RO, Reset=0x00. Fixed read-only MINOR field of the RTL version.</description><bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>Version Major. RO, Reset=0x01. Fixed read-only MAJOR field of the RTL version.</description><bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>GPMI</name>
      <description>NAND Flash 通用接口控制器，支持 NAND/ATA 模式，集成 ECC(BCH/ECC8) 纠错引擎，提供 DMA 数据传输、时序配置与命令执行功能。</description>
      <groupName>NAND</groupName>
      <baseAddress>0x8000C000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x100</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>GPMI_DMA</name>
        <value>13</value>
      </interrupt>
      <interrupt>
        <name>GPMI</name>
        <value>51</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL0</name>
          <description>GPMI 控制寄存器 0，配置单次命令传输的核心参数并启动执行。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>XFER_COUNT</name>
              <description>本次命令传输的字节数，0 表示 65536 字节。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>ADDRESS_INCREMENT</name>
              <description>地址自增使能：DISABLED=禁止自增；ENABLED=每传输一个字后地址自动递增。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>ADDRESS</name>
              <description>NAND 地址类型：NAND_DATA=数据寄存器；NAND_CLE=命令锁存使能；NAND_ALE=地址锁存使能。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>3</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NAND_DATA</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NAND_CLE</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NAND_ALE</name>
                  <value>2</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CS</name>
              <description>片选信号编号，选择当前操作的 NAND 设备(0~3)。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>LOCK_CS</name>
              <description>片选锁定使能：DISABLED=传输结束后自动释放 CS；ENABLED=锁定 CS 直到显式释放。</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>WORD_LENGTH</name>
              <description>数据位宽：_16_BIT=16 位；_8_BIT=8 位。</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>_16_BIT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_8_BIT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>COMMAND_MODE</name>
              <description>命令模式：WRITE=写数据；READ=读数据；READ_AND_COMPARE=读并比较；WAIT_FOR_READY=等待设备就绪。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>WRITE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>READ</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>READ_AND_COMPARE</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>WAIT_FOR_READY</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>UDMA</name>
              <description>UDMA 模式使能：DISABLED=禁用；ENABLED=启用 Ultra DMA 传输。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>TIMEOUT_IRQ_EN</name>
              <description>设备忙等待超时中断使能，置 1 允许超时中断上报。</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DEV_IRQ_EN</name>
              <description>设备就绪中断使能，置 1 允许设备就绪中断上报。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RUN</name>
              <description>命令执行状态：IDLE=空闲；BUSY=命令正在执行，写 1 启动命令。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUSY</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>时钟门控：RUN=正常运行；NO_CLKS=关闭 GPMI 时钟以节能。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RUN</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NO_CLKS</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SFTRST</name>
              <description>软复位：RUN=正常工作；RESET=复位整个 GPMI 模块。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RUN</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RESET</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>COMPARE</name>
          <description>读数据比较寄存器，用于 READ_AND_COMPARE 模式下的数据校验。</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>REFERENCE</name>
              <description>读数据比较的参考值。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MASK</name>
              <description>比较掩码，仅掩码为 1 的位参与比较。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ECCCTRL</name>
          <description>集成 ECC 控制寄存器，配置 ECC 引擎的操作模式与数据缓冲。</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>BUFFER_MASK</name>
              <description>ECC 数据缓冲掩码，选择参与 ECC 编解码的缓冲单元(BUFFER0~7、BCH_PAGE、BCH_AUXONLY)。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>9</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BCH_AUXONLY</name>
                  <value>256</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BCH_PAGE</name>
                  <value>511</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUFFER7</name>
                  <value>128</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUFFER6</name>
                  <value>64</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUFFER5</name>
                  <value>32</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUFFER4</name>
                  <value>16</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUFFER3</name>
                  <value>8</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUFFER2</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUFFER1</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUFFER0</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>ENABLE_ECC</name>
              <description>ECC 使能：ENABLE=启用 ECC 编解码(写 1)；DISABLE=关闭 ECC(写 0)。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <value>0</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>ECC_CMD</name>
              <description>ECC 命令：DECODE_4_BIT=4 位解码；ENCODE_4_BIT=4 位编码；DECODE_8_BIT=8 位解码；ENCODE_8_BIT=8 位编码。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DECODE_4_BIT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENCODE_4_BIT</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DECODE_8_BIT</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENCODE_8_BIT</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>HANDLE</name>
              <description>ECC 操作句柄标识，用于关联本次 ECC 传输的上下文。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ECCCOUNT</name>
          <description>集成 ECC 传输计数寄存器，指定 ECC 编解码的数据量。</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>COUNT</name>
              <description>ECC 编解码的字节数，0 表示 65536 字节。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PAYLOAD</name>
          <description>DMA 主数据(Payload)缓冲地址寄存器，存放 NAND 页数据(数据区)的物理地址。</description>
          <addressOffset>0x40</addressOffset>
          <fields>
            <field>
              <name>ADDRESS</name>
              <description>Payload 数据缓冲的物理地址高 30 位(bit 31:2)，低 2 位固定为 0。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>30</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>AUXILIARY</name>
          <description>DMA 辅助数据(Auxiliary)缓冲地址寄存器，存放 NAND 备用区(如 OOB/元数据)的物理地址。</description>
          <addressOffset>0x50</addressOffset>
          <fields>
            <field>
              <name>ADDRESS</name>
              <description>Auxiliary 数据缓冲的物理地址高 30 位(bit 31:2)，低 2 位固定为 0。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>30</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL1</name>
          <description>GPMI 控制寄存器 1，配置工作模式、中断、采样时序与设备复位等全局参数。</description>
          <addressOffset>0x60</addressOffset>
          <fields>
            <field>
              <name>GPMI_MODE</name>
              <description>GPMI 工作模式：NAND=NAND Flash 模式；ATA=ATA 硬盘模式。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NAND</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ATA</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CAMERA_MODE</name>
              <description>Camera 模式使能，控制 GPMI 是否工作于 Camera 接口模式。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ATA_IRQRDY_POLARITY</name>
              <description>ATA IRQ/RDY 信号极性：ACTIVELOW=低电平有效；ACTIVEHIGH=高电平有效。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ACTIVELOW</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ACTIVEHIGH</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DEV_RESET</name>
              <description>设备复位控制：ENABLED=释放复位、设备正常工作(写 0)；DISABLED=置位复位、设备被复位(写 1)。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>ABORT_WAIT_FOR_READY0</name>
              <description>强制中止设备 0 的等待就绪操作。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABORT_WAIT_FOR_READY1</name>
              <description>强制中止设备 1 的等待就绪操作。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABORT_WAIT_FOR_READY2</name>
              <description>强制中止设备 2 的等待就绪操作。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABORT_WAIT_FOR_READY3</name>
              <description>强制中止设备 3 的等待就绪操作。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BURST_EN</name>
              <description>DMA 突发传输(Burst)使能。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TIMEOUT_IRQ</name>
              <description>设备忙等待超时中断状态位，写 1 清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DEV_IRQ</name>
              <description>设备就绪中断状态位，写 1 清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMA2ECC_MODE</name>
              <description>DMA 到 ECC 直通模式使能，控制 DMA 数据是否直接送入 ECC 引擎处理。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DSAMPLE_TIME</name>
              <description>读数据采样延时，以 GPMI 时钟周期为单位调整读数据采样时刻，用于时序补偿。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TIMING0</name>
          <description>NAND 时序寄存器 0，配置 NAND 读写的基础时序参数。</description>
          <addressOffset>0x70</addressOffset>
          <fields>
            <field>
              <name>DATA_SETUP</name>
              <description>数据建立时间，控制 WE/RE 有效到数据稳定所需的 GPMI 时钟周期数。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>DATA_HOLD</name>
              <description>数据保持时间，控制数据稳定后 WE/RE 保持有效的 GPMI 时钟周期数。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>ADDRESS_SETUP</name>
              <description>地址建立时间，控制 ALE/CLE 有效到 WE/RE 有效之间的 GPMI 时钟周期数。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TIMING1</name>
          <description>NAND 时序寄存器 1，配置设备忙等待超时时间。</description>
          <addressOffset>0x80</addressOffset>
          <fields>
            <field>
              <name>DEVICE_BUSY_TIMEOUT</name>
              <description>设备忙等待超时计数，以 GPMI 时钟周期为单位设定最大等待时间。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TIMING2</name>
          <description>UDMA 时序寄存器 2，配置 Ultra DMA 模式下的专用时序参数。</description>
          <addressOffset>0x90</addressOffset>
          <fields>
            <field>
              <name>UDMA_SETUP</name>
              <description>UDMA 建立时间，控制 UDMA 传输开始前信号的建立周期数。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>UDMA_HOLD</name>
              <description>UDMA 保持时间，控制 UDMA 传输结束后信号的保持周期数。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>UDMA_ENV</name>
              <description>UDMA 包络时间，控制 UDMA 传输包络信号的宽度。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>UDMA_TRP</name>
              <description>UDMA 恢复时间，控制 UDMA 传输之间所需的最小间隔周期数。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
