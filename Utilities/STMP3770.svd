                <enumeratedValue>
                  <name>MMC_WRITE_BLOCK</name>
                  <value>24</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MMC_WRITE_MULTIPLE_BLOCK</name>
                  <value>25</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MMC_PROGRAM_CID</name>
                  <value>26</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MMC_PROGRAM_CSD</name>
                  <value>27</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MMC_SET_WRITE_PROT</name>
                  <value>28</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MMC_CLR_WRITE_PROT</name>
                  <value>29</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MMC_SEND_WRITE_PROT</name>
                  <value>30</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MMC_ERASE_GROUP_START</name>
                  <value>35</value>
                </enumeratedValue>
                <enumeratedValue>
