<?xml version='1.0' encoding='utf-8'?>
<device xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" schemaVersion="1.3" xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd">
  <vendor>Freescale Semiconductor (NXP)</vendor>
  <name>STMP3770</name>
  <series>STMP37xx</series>
  <version>1.0</version>
  <description>STMP3770 应用处理器(ARM926EJ-S),HP39GII 计算器主控。寄存器定义源自 Freescale BSP 头文件，位域布局已验证与参考手册 Rev 1.04 一致。</description>
  <cpu>
    <name>other</name>
    <revision>r0p0</revision>
    <endian>little</endian>
    <mpuPresent>false</mpuPresent>
    <fpuPresent>false</fpuPresent>
    <nvicPrioBits>2</nvicPrioBits>
    <vendorSystickConfig>false</vendorSystickConfig>
  </cpu>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <size>32</size>
  <access>read-write</access>
  <resetValue>0x00000000</resetValue>
  <resetMask>0xFFFFFFFF</resetMask>
  <peripherals>
    <peripheral>
      <name>ICOLL</name>
      <description>ICOLL 中断收集器，负责 ARM926EJ-S 中断请求(IRQ)与快速中断请求(FIQ)的优先级仲裁、向量分发及状态管理。注：SRC 1(JTAG调试)由ARM JTAG TAP控制器直接处理，不经过ICOLL。</description>
      <groupName>System</groupName>
      <baseAddress>0x80000000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x11F0</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>VECTOR</name>
          <description>中断向量地址寄存器，存储当前最高优先级中断的向量字地址，ISR 读取后可直接跳转。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>IRQVECTOR</name>
              <description>当前中断向量字地址，占 bit[31:2]，对应 4 字节对齐的中断入口地址。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>30</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>LEVELACK</name>
          <description>中断优先级确认寄存器，ISR 结束时写入对应位以清除指定优先级的中断服务状态。</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>IRQLEVELACK</name>
              <description>写 1&lt;&lt;level 确认对应优先级中断，可写 LEVEL0(0x1)、LEVEL1(0x2)、LEVEL2(0x4)、LEVEL3(0x8)。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>LEVEL0</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL1</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL2</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL3</name>
                  <value>8</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL</name>
          <description>中断收集器全局控制寄存器，配置 IRQ/FIQ 总使能、嵌套策略、向量表间距及模块复位/时钟门控。</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>ENABLE2FIQ_T0</name>
              <description>Timer 0 FIQ 路由使能，置位后 Timer 0 中断改为 FIQ 方式送达 ARM 核。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE2FIQ_T1</name>
              <description>Timer 1 FIQ 路由使能，置位后 Timer 1 中断改为 FIQ 方式送达 ARM 核。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE2FIQ_T2</name>
              <description>Timer 2 FIQ 路由使能，置位后 Timer 2 中断改为 FIQ 方式送达 ARM 核。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE2FIQ_T3</name>
              <description>Timer 3 FIQ 路由使能，置位后 Timer 3 中断改为 FIQ 方式送达 ARM 核。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE2FIQ32</name>
              <description>中断源 32(BATT_BRNOUT)FIQ 路由使能，置位后对应中断改为 FIQ 方式送达 ARM 核。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE2FIQ33</name>
              <description>中断源 33(VDDD_BRNOUT)FIQ 路由使能，置位后对应中断改为 FIQ 方式送达 ARM 核。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE2FIQ34</name>
              <description>中断源 34(VDDIO_BRNOUT)FIQ 路由使能，置位后对应中断改为 FIQ 方式送达 ARM 核。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE2FIQ35</name>
              <description>中断源 35(VDD18_BRNOUT)FIQ 路由使能，置位后对应中断改为 FIQ 方式送达 ARM 核。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>IRQ_FINAL_ENABLE</name>
              <description>IRQ 总使能开关，ENABLE 时允许向 ARM 发出 IRQ 请求。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>FIQ_FINAL_ENABLE</name>
              <description>FIQ 总使能开关，ENABLE 时允许向 ARM 发出 FIQ 请求。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>ARM_RSE_MODE</name>
              <description>ARM 读副作用模式，使能后读取 VECTOR 寄存器会触发 ICOLL 内部状态转换。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>NO_NESTING</name>
              <description>禁止中断嵌套，NO_NEST 时 ICOLL 不响应更低或同级优先级的新中断。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NORMAL</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NO_NEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>BYPASS_FSM</name>
              <description>FSM 旁路模式，BYPASS 时绕过内部向量状态机，用于调试或特殊操作模式。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NORMAL</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BYPASS</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>VECTOR_PITCH</name>
              <description>向量表项间距，枚举值 DEFAULT_BY4(默认)、BY4、BY8、BY12、BY16、BY20、BY24、BY28。</description>
              <bitOffset>21</bitOffset>
              <bitWidth>3</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DEFAULT_BY4</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BY4</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BY8</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BY12</name>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BY16</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BY20</name>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BY24</name>
                  <value>6</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BY28</name>
                  <value>7</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>时钟门控，NO_CLOCKS 时关闭 ICOLL 模块时钟以节省功耗。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RUN</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NO_CLOCKS</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SFTRST</name>
              <description>软复位，IN_RESET 时对整个 ICOLL 模块执行软件复位。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RUN</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>IN_RESET</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>STAT</name>
          <description>中断收集器状态寄存器，反映当前正在服务的中断编号。</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>VECTOR_NUMBER</name>
              <description>当前正在服务的中断向量号，取值范围对应各中断源编号。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>2</dim>
          <dimIncrement>0x10</dimIncrement>
          <dimIndex>0-1</dimIndex>
          <name>RAW%s</name>
          <description>原始中断状态寄存器数组，每位反映对应中断源的原始硬件请求状态，不受使能控制影响。</description>
          <addressOffset>0x40</addressOffset>
          <fields>
            <field>
              <name>RAW_IRQS</name>
              <description>32 位原始中断请求状态位图，1 表示对应中断源存在未处理硬件请求。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>16</dim>
          <dimIncrement>0x10</dimIncrement>
          <dimIndex>0-15</dimIndex>
          <name>PRIORITY%s</name>
          <description>中断优先级配置寄存器数组，每个寄存器管理 4 个中断源的优先级、使能及软件触发。</description>
          <addressOffset>0x60</addressOffset>
          <fields>
            <field>
              <name>PRIORITY0</name>
              <description>中断源 0 的优先级，LEVEL0 最低，LEVEL3 最高。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>LEVEL0</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL1</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL2</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL3</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>ENABLE0</name>
              <description>中断源 0 的使能开关，ENABLE 时允许该中断参与仲裁。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SOFTIRQ0</name>
              <description>中断源 0 的软件触发，FORCE_INTERRUPT 时强制产生软件中断请求。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_INTERRUPT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FORCE_INTERRUPT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>PRIORITY1</name>
              <description>中断源 1 的优先级，LEVEL0 最低，LEVEL3 最高。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>LEVEL0</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL1</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL2</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL3</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>ENABLE1</name>
              <description>中断源 1 的使能开关，ENABLE 时允许该中断参与仲裁。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SOFTIRQ1</name>
              <description>中断源 1 的软件触发，FORCE_INTERRUPT 时强制产生软件中断请求。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_INTERRUPT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FORCE_INTERRUPT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>PRIORITY2</name>
              <description>中断源 2 的优先级，LEVEL0 最低，LEVEL3 最高。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>LEVEL0</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL1</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL2</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL3</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>ENABLE2</name>
              <description>中断源 2 的使能开关，ENABLE 时允许该中断参与仲裁。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SOFTIRQ2</name>
              <description>中断源 2 的软件触发，FORCE_INTERRUPT 时强制产生软件中断请求。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_INTERRUPT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FORCE_INTERRUPT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>PRIORITY3</name>
              <description>中断源 3 的优先级，LEVEL0 最低，LEVEL3 最高。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>LEVEL0</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL1</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL2</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL3</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>ENABLE3</name>
              <description>中断源 3 的使能开关，ENABLE 时允许该中断参与仲裁。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SOFTIRQ3</name>
              <description>中断源 3 的软件触发，FORCE_INTERRUPT 时强制产生软件中断请求。</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_INTERRUPT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FORCE_INTERRUPT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>VBASE</name>
          <description>中断向量基地址寄存器，存放中断向量表的字地址，供 ICOLL 计算最终跳转地址。</description>
          <addressOffset>0x160</addressOffset>
          <fields>
            <field>
              <name>TABLE_ADDRESS</name>
              <description>中断向量表基地址的字地址，占 bit[31:2]，低 2 位固定为 0 即 4 字节对齐。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>30</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG</name>
          <description>中断收集器调试寄存器，暴露内部向量 FSM 状态、IRQ/FIQ 请求线及各优先级请求/服务状态。</description>
          <addressOffset>0x1120</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>VECTOR_FSM</name>
              <description>向量 FSM 当前状态，枚举值覆盖 IDLE、PENDING、多周期处理及 ISR 运行等阶段。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>FSM_IDLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FSM_MULTICYCLE1</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FSM_MULTICYCLE2</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FSM_PENDING</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FSM_MULTICYCLE3</name>
                  <value>8</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FSM_MULTICYCLE4</name>
                  <value>16</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FSM_ISR_RUNNING1</name>
                  <value>32</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FSM_ISR_RUNNING2</name>
                  <value>64</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FSM_ISR_RUNNING3</name>
                  <value>128</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FSM_MULTICYCLE5</name>
                  <value>256</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FSM_MULTICYCLE6</name>
                  <value>512</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>IRQ</name>
              <description>IRQ 请求状态，IRQ_REQUESTED 表示当前存在向 ARM 的 IRQ 请求。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_IRQ_REQUESTED</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>IRQ_REQUESTED</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>FIQ</name>
              <description>FIQ 请求状态，FIQ_REQUESTED 表示当前存在向 ARM 的 FIQ 请求。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_FIQ_REQUESTED</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FIQ_REQUESTED</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>REQUESTS_BY_LEVEL</name>
              <description>按优先级分类的原始中断请求位图，每位对应 LEVEL0~LEVEL3 是否有该级请求。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>4</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>LEVEL0</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL1</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL2</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL3</name>
                  <value>8</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>LEVEL_REQUESTS</name>
              <description>经门控后的每优先级中断请求汇总位图，每位表示对应 LEVEL 是否存在有效待处理请求。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>4</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>LEVEL0</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL1</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL2</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL3</name>
                  <value>8</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>INSERVICE</name>
              <description>当前正在服务的中断优先级位图，每位表示对应 LEVEL 是否处于服务中。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>4</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>LEVEL0</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL1</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL2</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEVEL3</name>
                  <value>8</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>DBGREAD0</name>
          <description>调试读镜像寄存器 0，用于调试时读取 ICOLL 内部总线或状态镜像值。</description>
          <addressOffset>0x1130</addressOffset>
          <fields>
            <field>
              <name>VALUE</name>
              <description>32 位调试镜像值，反映内部信号或总线数据的快照。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DBGREAD1</name>
          <description>调试读镜像寄存器 1，用于调试时读取 ICOLL 内部另一组总线或状态镜像值。</description>
          <addressOffset>0x1140</addressOffset>
          <fields>
            <field>
              <name>VALUE</name>
              <description>32 位调试镜像值，反映内部信号或总线数据的快照。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DBGFLAG</name>
          <description>调试标志寄存器，提供 16 位调试标志位供内部状态标记或调试使用。</description>
          <addressOffset>0x1150</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>FLAG</name>
              <description>16 位调试标志位图，用于标记或读取内部调试状态。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>2</dim>
          <dimIncrement>0x10</dimIncrement>
          <dimIndex>0-1</dimIndex>
          <name>DBGREQUEST%s</name>
          <description>调试请求寄存器数组，提供调试用的中断请求位镜像，用于观察或注入调试请求。</description>
          <addressOffset>0x1160</addressOffset>
          <fields>
            <field>
              <name>BITS</name>
              <description>32 位调试请求位图，反映或控制调试模式下的中断请求状态。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>中断收集器版本寄存器，标识当前 ICOLL 硬件版本的主次及步进号。</description>
          <addressOffset>0x11E0</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>步进版本号，标识当前硬件的步进修订。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>次版本号，标识当前硬件的次要版本。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>主版本号，标识当前硬件的主要版本。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>APBH</name>
      <description>AHB-to-APBH 桥 DMA 控制器(为 GPMI/NAND、LCDIF 等高速外设提供 DMA 通道)</description>
      <groupName>DMA</groupName>
      <baseAddress>0x80004000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x4400</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>CTRL0</name>
          <description>AHB to APBH Bridge Control and Status Register 0</description>
          <addressOffset>0x4000</addressOffset>
          <fields>
            <field>
              <name>FREEZE_CHANNEL</name>
              <description>Freeze Channel，8位读写字段。</description><bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <enumeratedValues>
                <enumeratedValue><name>LCDIF</name><value>1</value></enumeratedValue><enumeratedValue><name>SSP1</name><value>2</value></enumeratedValue><enumeratedValue><name>SSP2</name><value>4</value></enumeratedValue><enumeratedValue><name>ATA</name><value>16</value></enumeratedValue><enumeratedValue><name>NAND1</name><value>32</value></enumeratedValue><enumeratedValue><name>NAND2</name><value>64</value></enumeratedValue><enumeratedValue><name>NAND3</name><value>128</value></enumeratedValue></enumeratedValues>
            </field>
            <field>
              <name>CLKGATE_CHANNEL</name>
              <description>Clkgate Channel，8位读写字段。</description><bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
              <enumeratedValues>
                <enumeratedValue><name>LCDIF</name><value>1</value></enumeratedValue><enumeratedValue><name>SSP1</name><value>2</value></enumeratedValue><enumeratedValue><name>SSP2</name><value>4</value></enumeratedValue><enumeratedValue><name>ATA</name><value>16</value></enumeratedValue><enumeratedValue><name>NAND1</name><value>32</value></enumeratedValue><enumeratedValue><name>NAND2</name><value>64</value></enumeratedValue><enumeratedValue><name>NAND3</name><value>128</value></enumeratedValue></enumeratedValues>
            </field>
            <field>
              <name>RESET_CHANNEL</name>
              <description>Reset Channel，8位读写字段。</description><bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
              <enumeratedValues>
                <enumeratedValue><name>LCDIF</name><value>1</value></enumeratedValue><enumeratedValue><name>SSP1</name><value>2</value></enumeratedValue><enumeratedValue><name>SSP2</name><value>4</value></enumeratedValue><enumeratedValue><name>ATA</name><value>16</value></enumeratedValue><enumeratedValue><name>NAND1</name><value>32</value></enumeratedValue><enumeratedValue><name>NAND2</name><value>64</value></enumeratedValue><enumeratedValue><name>NAND3</name><value>128</value></enumeratedValue></enumeratedValues>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>时钟门控控制位，写1关闭模块时钟以节省功耗，配置状态保持。写0恢复正常时钟供应。</description><bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SFTRST</name>
              <description>软复位控制位，写1复位本模块，写0恢复正常运行。复位后所有寄存器回到默认值。</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL1</name>
          <description>AHB to APBH Bridge Control and Status Register 1</description>
          <addressOffset>0x4010</addressOffset>
          <fields>
            <field>
              <name>CH0_CMDCMPLT_IRQ</name>
              <description>Ch0 Cmdcmplt Irq，1位读写字段。</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH1_CMDCMPLT_IRQ</name>
              <description>Ch1 Cmdcmplt Irq，1位读写字段。</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH2_CMDCMPLT_IRQ</name>
              <description>Ch2 Cmdcmplt Irq，1位读写字段。</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH3_CMDCMPLT_IRQ</name>
              <description>Ch3 Cmdcmplt Irq，1位读写字段。</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH4_CMDCMPLT_IRQ</name>
              <description>Ch4 Cmdcmplt Irq，1位读写字段。</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH5_CMDCMPLT_IRQ</name>
              <description>Ch5 Cmdcmplt Irq，1位读写字段。</description><bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH6_CMDCMPLT_IRQ</name>
              <description>Ch6 Cmdcmplt Irq，1位读写字段。</description><bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH7_CMDCMPLT_IRQ</name>
              <description>Ch7 Cmdcmplt Irq，1位读写字段。</description><bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH0_CMDCMPLT_IRQ_EN</name>
              <description>Ch0 Cmdcmplt Irq En，1位读写字段。</description><bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH1_CMDCMPLT_IRQ_EN</name>
              <description>Ch1 Cmdcmplt Irq En，1位读写字段。</description><bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH2_CMDCMPLT_IRQ_EN</name>
              <description>Ch2 Cmdcmplt Irq En，1位读写字段。</description><bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH3_CMDCMPLT_IRQ_EN</name>
              <description>Ch3 Cmdcmplt Irq En，1位读写字段。</description><bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH4_CMDCMPLT_IRQ_EN</name>
              <description>Ch4 Cmdcmplt Irq En，1位读写字段。</description><bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH5_CMDCMPLT_IRQ_EN</name>
              <description>Ch5 Cmdcmplt Irq En，1位读写字段。</description><bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH6_CMDCMPLT_IRQ_EN</name>
              <description>Ch6 Cmdcmplt Irq En，1位读写字段。</description><bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH7_CMDCMPLT_IRQ_EN</name>
              <description>Ch7 Cmdcmplt Irq En，1位读写字段。</description><bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH0_AHB_ERROR_IRQ</name>
              <description>Ch0 Ahb Error Irq，1位读写字段。</description><bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH1_AHB_ERROR_IRQ</name>
              <description>Ch1 Ahb Error Irq，1位读写字段。</description><bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH2_AHB_ERROR_IRQ</name>
              <description>Ch2 Ahb Error Irq，1位读写字段。</description><bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH3_AHB_ERROR_IRQ</name>
              <description>Ch3 Ahb Error Irq，1位读写字段。</description><bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH4_AHB_ERROR_IRQ</name>
              <description>Ch4 Ahb Error Irq，1位读写字段。</description><bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH5_AHB_ERROR_IRQ</name>
              <description>Ch5 Ahb Error Irq，1位读写字段。</description><bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH6_AHB_ERROR_IRQ</name>
              <description>Ch6 Ahb Error Irq，1位读写字段。</description><bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH7_AHB_ERROR_IRQ</name>
              <description>Ch7 Ahb Error Irq，1位读写字段。</description><bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEVSEL</name>
          <description>AHB to APBH DMA Device Assignment Register</description>
          <addressOffset>0x4020</addressOffset>
          <fields>
            <field>
              <name>CH0</name>
              <description>CH0 通道设备分配只读值，反映复位固定的 DMA 通道到外设的分配关系。PDF 标记为 RO/保留。</description><bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
            <access>read-only</access></field>
            <field>
              <name>CH1</name>
              <description>CH1 通道设备分配只读值，反映复位固定的 DMA 通道到外设的分配关系。PDF 标记为 RO/保留。</description><bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
            <access>read-only</access></field>
            <field>
              <name>CH2</name>
              <description>CH2 通道设备分配只读值，反映复位固定的 DMA 通道到外设的分配关系。PDF 标记为 RO/保留。</description><bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
            <access>read-only</access></field>
            <field>
              <name>CH3</name>
              <description>CH3 通道设备分配只读值，反映复位固定的 DMA 通道到外设的分配关系。PDF 标记为 RO/保留。</description><bitOffset>12</bitOffset>
              <bitWidth>4</bitWidth>
            <access>read-only</access></field>
            <field>
              <name>CH4</name>
              <description>CH4 通道设备分配只读值，反映复位固定的 DMA 通道到外设的分配关系。PDF 标记为 RO/保留。</description><bitOffset>16</bitOffset>
              <bitWidth>4</bitWidth>
            <access>read-only</access></field>
            <field>
              <name>CH5</name>
              <description>CH5 通道设备分配只读值，反映复位固定的 DMA 通道到外设的分配关系。PDF 标记为 RO/保留。</description><bitOffset>20</bitOffset>
              <bitWidth>4</bitWidth>
            <access>read-only</access></field>
            <field>
              <name>CH6</name>
              <description>CH6 通道设备分配只读值，反映复位固定的 DMA 通道到外设的分配关系。PDF 标记为 RO/保留。</description><bitOffset>24</bitOffset>
              <bitWidth>4</bitWidth>
            <access>read-only</access></field>
            <field>
              <name>CH7</name>
              <description>CH7 通道设备分配只读值，反映复位固定的 DMA 通道到外设的分配关系。PDF 标记为 RO/保留。</description><bitOffset>28</bitOffset>
              <bitWidth>4</bitWidth>
            <access>read-only</access></field>
          </fields>
        </register>
        <register>
          <dim>8</dim>
          <dimIncrement>0x70</dimIncrement>
          <name>CH%s_CURCMDAR</name>
          <description>DMA 通道当前命令描述符物理地址(只读,DMA 引擎执行时自动更新)。</description>
          <addressOffset>0x4040</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>CMD_ADDR</name>
              <description>当前命令描述符的 32 位物理地址。</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>8</dim>
          <dimIncrement>0x70</dimIncrement>
          <name>CH%s_NXTCMDAR</name>
          <description>DMA 通道下一命令描述符物理地址(读写,软件写入待执行描述符链首地址)。</description>
          <addressOffset>0x4050</addressOffset>
          <fields>
            <field>
              <name>CMD_ADDR</name>
              <description>下一命令描述符的 32 位物理地址。</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>8</dim>
          <dimIncrement>0x70</dimIncrement>
          <name>CH%s_CMD</name>
          <description>DMA 通道当前命令字(只读,镜像正在执行描述符的 CMD 字)。</description>
          <addressOffset>0x4060</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>COMMAND</name>
              <description>传输方向：0=不传输，1=外设→内存(DMA_WRITE)，2=内存→外设(DMA_READ)，3=条件分支(DMA_SENSE)。</description><bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>CHAIN</name>
              <description>置位则完成后继续取 NEXT 指向的下一描述符。</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>IRQONCMPLT</name>
              <description>置位则描述符完成后产生通道命令完成中断。</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>NANDLOCK</name>
              <description>置位则把 GPMI 锁定给本通道直到解锁。</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>NANDWAIT4READY</name>
              <description>置位则等待 NAND R/B 就绪信号后再继续。</description><bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SEMAPHORE</name>
              <description>置位则完成后递减通道信号量。</description><bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WAIT4ENDCMD</name>
              <description>置位则等待外设结束命令握手后再推进描述符。</description><bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HALTONTERMINATE</name>
              <description>置位则在终止时停在当前描述符。</description><bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMDWORDS</name>
              <description>随描述符的 PIO 字数。</description><bitOffset>12</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>XFER_COUNT</name>
              <description>本次 DMA 传输字节数。</description><bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>8</dim>
          <dimIncrement>0x70</dimIncrement>
          <name>CH%s_BAR</name>
          <description>DMA 通道缓冲区基址(只读,镜像当前描述符的负载缓冲物理地址)。</description>
          <addressOffset>0x4070</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>ADDRESS</name>
              <description>负载缓冲的 32 位物理地址。</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>8</dim>
          <dimIncrement>0x70</dimIncrement>
          <name>CH%s_SEMA</name>
          <description>DMA 通道信号量寄存器(读写,写 INCREMENT_SEMA 踢启动传输,读 PHORE 取剩余待处理描述符数)。</description>
          <addressOffset>0x4080</addressOffset>
          <fields>
            <field>
              <name>INCREMENT_SEMA</name>
              <description>写入的值累加到通道信号量,等于排队待执行的描述符个数;非零即启动 DMA。</description><bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>PHORE</name>
              <description>当前信号量计数(只读),为剩余尚未完成的描述符个数。</description><bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
