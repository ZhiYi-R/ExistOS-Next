    <peripheral>
      <name>SPDIF</name>
      <description>S/PDIF 数字音频发送接口</description>
      <groupName>Audio</groupName>
      <baseAddress>0x80054000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x70</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>SPDIF_DMA</name>
        <value>9</value>
      </interrupt>
      <interrupt>
        <name>SPDIF_ERROR</name>
        <value>10</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL</name>
          <description>SPDIF Control Register</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>RUN</name>
              <description>Set to 1 to start SPDIF conversion. Actual conversion begins when FIFO is filled (4 or 8 words depending on sample format). Reset: 0x0.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_ERROR_IRQ_EN</name>
              <description>Enable SPDIF interrupt request on FIFO overflow or underflow status conditions. Reset: 0x0.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_OVERFLOW_IRQ</name>
              <description>Set by hardware on FIFO overflow during SPDIF transmission. Reset by writing 1 to SCT clear address space. Reset: 0x0.</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_UNDERFLOW_IRQ</name>
              <description>Set by hardware on FIFO underflow during SPDIF transmission. Reset by writing 1 to SCT clear address space. Reset: 0x0.</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WORD_LENGTH</name>
              <description>0 = 32-bit mode (24 MSBs of DATA transmitted), 1 = 16-bit mode (8 zeros appended to LSBs). SPDIF frame always transmits only 24 bits. Reset: 0x0.</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WAIT_END_XFER</name>
              <description>When set, SPDIF transmitter waits until internal FIFO is empty before halting on RUN deassertion. Use with HW_SPDIF_STAT_END_XFER. Reset: 0x1.</description><bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAWAIT_COUNT</name>
              <description>DMA Request Delay Count (0-31 APBX clock cycles). Throttles bandwidth consumed by SPDIF block. Can be loaded by DMA. Reset: 0x00.</description><bitOffset>16</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>Clock gate. Set to 1 to gate off clocks to block. Must coordinate with HW_CLKCTRL_SPDIF.CLKGATE. Clear to 0 for normal operation.</description><bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SFTRST</name>
              <description>Soft reset. Setting to 1 forces reset to entire block and gates clocks off. Must be cleared to 0 for normal operation. Reset: 0x1.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STAT</name>
          <description>SPDIF Status Register</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>END_XFER</name>
              <description>Indicates SPDIF module has completed transfer of all data including internal FIFOs. Use with HW_SPDIF_CTRL.WAIT_END_XFER. Reset: 0x0.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PRESENT</name>
              <description>Set to 1 in products where SPDIF is present. Read-only. Reset: 0x1.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>FRAMECTRL</name>
          <description>SPDIF Frame Control Register</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>PRO</name>
              <description>Channel usage: 0 = Consumer use, 1 = Professional use. Reset: 0x0.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AUDIO</name>
              <description>Audio type: 0 = PCM data, 1 = Non-PCM data. Reset: 0x0.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>COPY</name>
              <description>Copyright: 0 = Copyright NOT asserted, 1 = Copyright asserted. Reset: 0x0.</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PRE</name>
              <description>Pre-Emphasis: 0 = No Pre-Emphasis, 1 = Pre-Emphasis is 50/15 usec. Reset: 0x0.</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CC</name>
              <description>Category Code (7 bits). Defined by IEC standard or as appropriate. Reset: 0x0.</description><bitOffset>4</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>L</name>
              <description>Generation Level bit. Defined by IEC standard or as appropriate. Reset: 0x0.</description><bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>V</name>
              <description>Validity bit: 0 = Sub-frame valid (correctly transmitted/received), 1 = Sub-frame invalid. Reset: 0x0.</description><bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>USER_DATA</name>
              <description>User Data bit. Transmitted during each sub-frame. Consult IEC-60958 for additional details. Reset: 0x0.</description><bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AUTO_MUTE</name>
              <description>Auto-Mute stream on stream-suspend detect. Reset: 0x0.</description><bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>V_CONFIG</name>
              <description>SPDIF behavior on invalid frames: 0 = Do NOT tag as invalid, 1 = Tag frame as invalid. Reset: 0x1.</description><bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SRR</name>
          <description>SPDIF Sample Rate Register</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>RATE</name>
              <description>Sample-Rate Conversion Factor. Valid entries: 0x07D00 (32k), 0x0AC44 (44.1k), 0x0BB80 (48k). Reset: 0x00000.</description><bitOffset>0</bitOffset>
              <bitWidth>20</bitWidth>
            </field>
            <field>
              <name>BASEMULT</name>
              <description>Base-Rate Multiplier: 1 = Single-Rate (48 kHz), 2 = Double-Rate (96 kHz). Reset: 0x1.</description><bitOffset>28</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG</name>
          <description>SPDIF Debug Register</description>
          <addressOffset>0x40</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>FIFO_STATUS</name>
              <description>Set when FIFO has empty space, reflecting a DMA request being generated. Reset: 0x1.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMA_PREQ</name>
              <description>DMA Request Status. Reflects current DMA request signal state. Polled by software for PIO mode data movement. Reset: 0x0.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
          <description>SPDIF Write Data Register</description>
          <addressOffset>0x50</addressOffset>
          <fields>
            <field>
              <name>LOW</name>
              <description>16-bit mode: entire left channel sample. 32-bit mode: 16 LSBs of the 32-bit sample (left or right). Reset: 0x0000.</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>HIGH</name>
              <description>16-bit mode: entire right channel sample. 32-bit mode: 16 MSBs of the 32-bit sample (left or right). Reset: 0x0000.</description><bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>SPDIF Version Register</description>
          <addressOffset>0x60</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>Fixed read-only value reflecting the stepping of the RTL version. Reset: 0x0000.</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>Fixed read-only value reflecting the MINOR field of the RTL version. Reset: 0x01.</description><bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>Fixed read-only value reflecting the MAJOR field of the RTL version. Reset: 0x01.</description><bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>I2C</name>
      <description>I2C 总线控制器，支持主从模式、PIO/DMA 数据传输、可编程时序与多主机仲裁。</description>
      <groupName>I2C</groupName>
      <baseAddress>0x80058000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0xA0</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>I2C_DMA</name>
        <value>26</value>
      </interrupt>
      <interrupt>
        <name>I2C_ERROR</name>
        <value>27</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL0</name>
          <description>I2C 控制寄存器 0，配置传输方向、主从模式、字节数、START/STOP 条件、PIO 模式、时钟门控与软复位等核心参数。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>XFER_COUNT</name>
              <description>本次传输的字节数（16 位）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DIRECTION</name>
              <description>传输方向：0=接收，1=发送。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RECEIVE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TRANSMIT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>MASTER_MODE</name>
              <description>主从模式选择：0=从机，1=主机。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SLAVE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MASTER</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SLAVE_ADDRESS_ENABLE</name>
