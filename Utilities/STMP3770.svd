              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>LOW_COUNT</name>
              <description>SCL 低电平周期计数，决定 SCL 保持低电平的时钟周期数。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TIMING2</name>
