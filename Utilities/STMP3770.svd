                  <value>55</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MMC_GEN_CMD</name>
                  <value>56</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SD_ERASE_WR_BLK_START</name>
                  <value>32</value>
                </enumeratedValue>
                <enumeratedValue>
