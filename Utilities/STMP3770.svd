    <peripheral>
      <name>SPDIF</name>
      <description>S/PDIF 数字音频发送接口</description>
      <groupName>Audio</groupName>
      <baseAddress>0x80054000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x70</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>SPDIF_DMA</name>
        <value>9</value>
      </interrupt>
      <interrupt>
        <name>SPDIF_ERROR</name>
        <value>10</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL</name>
          <description>SPDIF Control Register</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>RUN</name>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
