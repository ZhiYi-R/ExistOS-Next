          <addressOffset>0xB0</addressOffset>
          <fields>
            <field>
              <name>DEV0_ERROR</name>
              <description>设备 0 错误标志，指示该设备发生错误。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DEV1_ERROR</name>
