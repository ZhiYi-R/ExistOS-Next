                <enumeratedValue>
                  <name>ISO</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BULK</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>INT</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>RXI</name>
