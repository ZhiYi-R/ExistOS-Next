            <field>
              <name>TXADD</name>
              <description>TX 缓冲区总大小（只读）</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>TXCHANADD</name>
              <description>TX 每通道缓冲区大小（只读）</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>TXLCR</name>
              <description>TX 本地上下文重排使能（只读）</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>HWRXBUF</name>
          <description>RX Buffer Hardware Parameters Register</description>
          <addressOffset>0x14</addressOffset>
          <fields>
            <field>
              <name>RXBURST</name>
              <description>RX 突发传输长度（只读）</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>RXADD</name>
              <description>RX 缓冲区总大小（只读）</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>GPTIMER0LD</name>
          <description>General-Purpose Timer 0 Load (Non-EHCI-Compliant) Register</description>
          <addressOffset>0x80</addressOffset>
          <fields>
            <field>
              <name>GPTLD</name>
              <description>通用定时器 0 加载值（24 位递减计数初值）</description>
              <bitOffset>0</bitOffset>
              <bitWidth>24</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>GPTIMER0CTRL</name>
          <description>General-Purpose Timer 0 Control (Non-EHCI-Compliant) Register</description>
          <addressOffset>0x84</addressOffset>
          <fields>
            <field>
              <name>GPTCNT</name>
              <description>通用定时器 0 当前计数值（24 位，只读）</description>
              <bitOffset>0</bitOffset>
              <bitWidth>24</bitWidth>
            </field>
            <field>
              <name>GPTMODE</name>
              <description>通用定时器 0 工作模式（0=单次 ONESHOT，1=重复 REPEAT）</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ONESHOT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>REPEAT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>GPTRST</name>
              <description>通用定时器 0 复位（0=无操作，1=加载 GPTLD 到计数器）</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOACTION</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LOADCOUNTER</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>GPTRUN</name>
              <description>通用定时器 0 运行控制（0=停止 STOP，1=运行 RUN）</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>STOP</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RUN</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>GPTIMER1LD</name>
          <description>General-Purpose Timer 1 Load (Non-EHCI-Compliant) Register</description>
          <addressOffset>0x88</addressOffset>
          <fields>
            <field>
              <name>GPTLD</name>
              <description>通用定时器 1 加载值（24 位递减计数初值）</description>
              <bitOffset>0</bitOffset>
              <bitWidth>24</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>GPTIMER1CTRL</name>
          <description>General-Purpose Timer 1 Control (Non-EHCI-Compliant) Register</description>
          <addressOffset>0x8C</addressOffset>
          <fields>
            <field>
              <name>GPTCNT</name>
              <description>通用定时器 1 当前计数值（24 位，只读）</description>
              <bitOffset>0</bitOffset>
              <bitWidth>24</bitWidth>
            </field>
            <field>
              <name>GPTMODE</name>
              <description>通用定时器 1 工作模式（0=单次 ONESHOT，1=重复 REPEAT）</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
