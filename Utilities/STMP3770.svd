          <fields>
            <field>
              <name>IRQLEVEL</name>
              <description>Bank 0 的中断触发方式位域（32 位），逐位配置引脚 0~31 为电平触发（1）或边沿触发（0）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>IRQLEVEL1</name>
          <description>Bank 1 中断电平/边沿触发寄存器，低 31 位逐位配置对应引脚的中断触发方式（1 电平触发，0 边沿触发）。</description>
          <addressOffset>0x910</addressOffset>
          <fields>
            <field>
              <name>IRQLEVEL</name>
              <description>Bank 1 的中断触发方式位域（31 位），逐位配置引脚 0~30 为电平触发（1）或边沿触发（0）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>31</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>IRQLEVEL2</name>
          <description>Bank 2 中断电平/边沿触发寄存器，32 位逐位配置对应引脚的中断触发方式（1 电平触发，0 边沿触发）。</description>
          <addressOffset>0x920</addressOffset>
          <fields>
            <field>
              <name>IRQLEVEL</name>
              <description>Bank 2 的中断触发方式位域（32 位），逐位配置引脚 0~31 为电平触发（1）或边沿触发（0）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>IRQPOL0</name>
          <description>Bank 0 中断极性寄存器，32 位逐位配置对应引脚的中断触发极性（1 高电平/上升沿有效，0 低电平/下降沿有效）。</description>
          <addressOffset>0xA00</addressOffset>
          <fields>
            <field>
              <name>IRQPOL</name>
              <description>Bank 0 的中断极性位域（32 位），逐位配置引脚 0~31 的触发极性。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>IRQPOL1</name>
          <description>Bank 1 中断极性寄存器，低 31 位逐位配置对应引脚的中断触发极性（1 高电平/上升沿有效，0 低电平/下降沿有效）。</description>
          <addressOffset>0xA10</addressOffset>
          <fields>
            <field>
              <name>IRQPOL</name>
              <description>Bank 1 的中断极性位域（31 位），逐位配置引脚 0~30 的触发极性。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>31</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>IRQPOL2</name>
          <description>Bank 2 中断极性寄存器，32 位逐位配置对应引脚的中断触发极性（1 高电平/上升沿有效，0 低电平/下降沿有效）。</description>
          <addressOffset>0xA20</addressOffset>
          <fields>
            <field>
              <name>IRQPOL</name>
              <description>Bank 2 的中断极性位域（32 位），逐位配置引脚 0~31 的触发极性。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>IRQSTAT0</name>
          <description>Bank 0 中断状态寄存器，32 位逐位反映对应引脚的中断挂起状态（1 表示有中断待处理，写 1 清除）。</description>
          <addressOffset>0xB00</addressOffset>
          <fields>
            <field>
              <name>IRQSTAT</name>
              <description>Bank 0 的中断状态位域（32 位），逐位反映引脚 0~31 的中断挂起状态。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>IRQSTAT1</name>
          <description>Bank 1 中断状态寄存器，低 31 位逐位反映对应引脚的中断挂起状态（1 表示有中断待处理，写 1 清除）。</description>
          <addressOffset>0xB10</addressOffset>
          <fields>
            <field>
              <name>IRQSTAT</name>
              <description>Bank 1 的中断状态位域（31 位），逐位反映引脚 0~30 的中断挂起状态。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>31</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>IRQSTAT2</name>
          <description>Bank 2 中断状态寄存器，32 位逐位反映对应引脚的中断挂起状态（1 表示有中断待处理，写 1 清除）。</description>
          <addressOffset>0xB20</addressOffset>
          <fields>
            <field>
              <name>IRQSTAT</name>
              <description>Bank 2 的中断状态位域（32 位），逐位反映引脚 0~31 的中断挂起状态。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>DIGCTL</name>
      <description>STMP3770 DIGCTL 外设（数字控制/杂项）寄存器与位域中文描述。覆盖 slice 中全部寄存器与位域，名称逐字一致。</description>
      <groupName>System</groupName>
      <baseAddress>0x8001C000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x510</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>DIGCTL_DEBUG_TRAP</name>
        <value>47</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL</name>
          <description>DIGCTL 控制寄存器，包含熵锁存、JTAG 防护、USB/SY 时钟门控、调试禁用、地址陷阱、串行 JTAG、SAIF/UART 环回、BIST 启动与时钟使能、测试模式、24MHz 晶振门控等控制位。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>LATCH_ENTROPY</name>
              <description>置位后锁存当前 ENTROPY 寄存器值到 ENTROPY_LATCHED 寄存器。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>JTAG_SHIELD</name>
              <description>JTAG 防护使能：NORMAL=正常模式，SHIELDS_UP=屏蔽模式（禁止外部 JTAG 访问）。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NORMAL</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SHIELDS_UP</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>USB_CLKGATE</name>
              <description>USB 控制器时钟门控：RUN=时钟运行，NO_CLKS=关闭时钟以节省功耗。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RUN</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NO_CLKS</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DEBUG_DISABLE</name>
              <description>置位后禁用片上调试功能。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TRAP_ENABLE</name>
              <description>使能地址陷阱功能，当访问落在陷阱范围内时触发异常。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TRAP_IN_RANGE</name>
              <description>置位表示陷阱范围有效（在 LOW/HIGH 地址之间），清零表示仅匹配单一地址。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>USE_SERIAL_JTAG</name>
              <description>JTAG 接口选择：OLD_JTAG=传统 JTAG 接口，SERIAL_JTAG=串行 JTAG 接口。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>OLD_JTAG</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SERIAL_JTAG</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SY_CLKGATE</name>
              <description>SY 模块时钟门控控制位。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SY_SFTRST</name>
              <description>SY 模块软复位控制位。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SY_ENDIAN</name>
              <description>SY 模块字节序选择控制位。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SAIF_ALT_BITCLK_SEL</name>
              <description>SAIF 备用位时钟选择控制位。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SAIF_CLKMST_SEL</name>
              <description>SAIF 主时钟源选择：SAIF1_MST=SAIF1 作主控，SAIF2_MST=SAIF2 作主控。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SAIF1_MST</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SAIF2_MST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SAIF_CLKMUX_SEL</name>
              <description>SAIF 时钟多路选择：MBL_CLK_OUT/BL_CLK_OUT/M_CLK_OUT_BL_CLK_IN/BL_CLK_IN。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>MBL_CLK_OUT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BL_CLK_OUT</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>M_CLK_OUT_BL_CLK_IN</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BL_CLK_IN</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SAIF_LOOPBACK</name>
              <description>SAIF 环回模式：NORMAL=正常传输，LOOPIT=内部环回测试。</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NORMAL</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LOOPIT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>UART_LOOPBACK</name>
              <description>UART 环回模式：NORMAL=正常传输，LOOPIT=内部环回测试。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NORMAL</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LOOPIT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>ARM_BIST_START</name>
              <description>置位启动 ARM 内核 BIST（内置自测试）。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DIGITAL_TESTMODE</name>
              <description>数字测试模式使能控制位。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ANALOG_TESTMODE</name>
              <description>模拟测试模式使能控制位。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>USB_TESTMODE</name>
              <description>USB 测试模式使能控制位。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ARM_BIST_CLKEN</name>
              <description>ARM BIST 测试时钟使能控制位。</description>
              <bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DCP_BIST_START</name>
              <description>置位启动 DCP（显示协处理器）BIST。</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DCP_BIST_CLKEN</name>
              <description>DCP BIST 测试时钟使能控制位。</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LCD_BIST_START</name>
              <description>置位启动 LCD 控制器 BIST。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LCD_BIST_CLKEN</name>
              <description>LCD BIST 测试时钟使能控制位。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CACHE_BIST_TMODE</name>
              <description>Cache BIST 测试模式选择控制位。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TRAP_IRQ</name>
              <description>地址陷阱中断状态/触发位。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>XTAL24M_GATE</name>
              <description>24MHz 晶振时钟门控控制位，置位关闭 XTAL24M 输出。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STATUS</name>
          <description>DIGCTL 状态寄存器，反映芯片封装类型、JTAG 占用状态、LCD/DCP BIST 结果及 USB 设备/主机/OTG/HS 存在性标志。</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>WRITTEN</name>
              <description>芯片是否已被写入过（如熔丝/ROM 配置已写入）标志位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PACKAGE_TYPE</name>
              <description>芯片封装类型标识编码。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>JTAG_IN_USE</name>
              <description>JTAG 接口当前正在被使用标志位。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LCD_BIST_DONE</name>
              <description>LCD BIST 测试完成标志位。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LCD_BIST_PASS</name>
              <description>LCD BIST 测试通过标志位。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LCD_BIST_FAIL</name>
              <description>LCD BIST 测试失败标志位。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DCP_BIST_DONE</name>
              <description>DCP BIST 测试完成标志位。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DCP_BIST_PASS</name>
              <description>DCP BIST 测试通过标志位。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DCP_BIST_FAIL</name>
              <description>DCP BIST 测试失败标志位。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>USB_DEVICE_PRESENT</name>
              <description>USB Device 功能存在标志位。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>USB_HOST_PRESENT</name>
              <description>USB Host 功能存在标志位。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>USB_OTG_PRESENT</name>
              <description>USB OTG 功能存在标志位。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>USB_HS_PRESENT</name>
              <description>USB High-Speed 功能存在标志位。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>HCLKCOUNT</name>
          <description>HCLK 自由运行计数器，提供 32 位 AHB 总线时钟周期计数。</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>COUNT</name>
              <description>HCLK 自由运行计数值，每拍递增，自然回绕。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RAMCTRL</name>
          <description>片内 RAM 控制寄存器，包含 RAM 修复使能与速度档位选择。</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>RAM_REPAIR_EN</name>
              <description>片内 RAM 修复功能使能控制位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SPEED_SELECT</name>
              <description>片内 RAM 速度档位选择，用于调整时序裕量。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RAMREPAIR</name>
          <description>片内 RAM 修复地址寄存器，指定需要修复的 RAM 地址。</description>
          <addressOffset>0x40</addressOffset>
          <fields>
            <field>
              <name>ADDR</name>
              <description>RAM 修复目标地址。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ROMCTRL</name>
          <description>片内 ROM 控制寄存器，用于调整 ROM 读时序。</description>
          <addressOffset>0x50</addressOffset>
          <fields>
            <field>
              <name>RD_MARGIN</name>
              <description>ROM 读操作裕量（延迟/边距）设置值。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>WRITEONCE</name>
          <description>软件一次性写寄存器，写入后不可再次修改（仅能在复位后重写）。</description>
          <addressOffset>0x60</addressOffset>
          <fields>
            <field>
              <name>BITS</name>
              <description>32 位一次性写入数据位域。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ENTROPY</name>
          <description>熵寄存器，提供来自物理噪声源的随机数值。</description>
          <addressOffset>0x90</addressOffset>
          <fields>
            <field>
              <name>VALUE</name>
              <description>实时熵值（随机数），由片上物理噪声源生成。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ENTROPY_LATCHED</name>
          <description>熵锁存寄存器，保存由 LATCH_ENTROPY 触发锁存时的熵值。</description>
          <addressOffset>0xA0</addressOffset>
          <fields>
            <field>
              <name>VALUE</name>
              <description>锁存后的熵值快照，供软件读取固定随机数。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SJTAGDBG</name>
          <description>串行 JTAG 调试寄存器，提供 SJTAG 接口的调试访问、状态监控与手动控制。</description>
          <addressOffset>0xB0</addressOffset>
          <fields>
            <field>
              <name>SJTAG_DEBUG_OE</name>
              <description>SJTAG 调试数据输出使能控制位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
