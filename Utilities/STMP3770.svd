        <value>10</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>AUDIOOUT</name>
      <description>音频 DAC 输出(耳机/线路输出的音量、滤波与 DMA 控制)</description>
      <groupName>Audio</groupName>
      <baseAddress>0x80048000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x210</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>HEADPHONE_SHORT</name>
        <value>4</value>
      </interrupt>
      <interrupt>
        <name>DAC_DMA</name>
        <value>5</value>
      </interrupt>
      <interrupt>
        <name>DAC_ERROR</name>
        <value>6</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL</name>
          <description>AUDIOOUT Control Register</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>RUN</name>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_ERROR_IRQ_EN</name>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_OVERFLOW_IRQ</name>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_UNDERFLOW_IRQ</name>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LOOPBACK</name>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DAC_ZERO_ENABLE</name>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WORD_LENGTH</name>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SS3D_EFFECT</name>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>INVERT_1BIT</name>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EDGE_SYNC</name>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LR_SWAP</name>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAWAIT_COUNT</name>
              <bitOffset>16</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
