                <enumeratedValue>
                  <name>MSM_RDCMP</name>
                  <value>9</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MSM_DONE</name>
                  <value>10</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>PIN_STATE</name>
              <description>引脚状态机状态：PSM_IDLE~PSM_DONE，反映外部引脚时序状态。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>3</bitWidth>
              <enumeratedValues>
