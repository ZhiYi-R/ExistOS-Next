                </enumeratedValue>
                <enumeratedValue>
                  <name>REQUEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>NO_SLAVE_ACK_IRQ_SUMMARY</name>
              <description>无从机应答中断汇总：0=无请求，1=有请求。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_REQUEST</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>REQUEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DATA_ENGINE_CMPLT_IRQ_SUMMARY</name>
              <description>数据引擎完成中断汇总：0=无请求，1=有请求。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_REQUEST</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>REQUEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>BUS_FREE_IRQ_SUMMARY</name>
              <description>总线空闲中断汇总：0=无请求，1=有请求。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_REQUEST</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>REQUEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SLAVE_BUSY</name>
              <description>从机引擎忙状态：0=空闲，1=忙。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUSY</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DATA_ENGINE_BUSY</name>
              <description>数据引擎忙状态：0=空闲，1=忙。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUSY</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CLK_GEN_BUSY</name>
              <description>时钟生成器忙状态：0=空闲，1=忙。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUSY</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>BUS_BUSY</name>
              <description>总线忙状态：0=空闲，1=忙。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUSY</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DATA_ENGINE_DMA_WAIT</name>
              <description>数据引擎 DMA 等待状态：0=继续，1=等待 DMA。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>CONTINUE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>WAITING</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SLAVE_SEARCHING</name>
              <description>从机地址搜索状态：0=空闲，1=正在搜索。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ACTIVE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SLAVE_FOUND</name>
              <description>从机地址匹配结果：0=空闲，1=已匹配并等待。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>WAITING</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SLAVE_ADDR_EQ_ZERO</name>
              <description>接收到的从机地址是否为 0：0=未匹配到 0，1=地址为 0。</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ZERO_NOT_MATCHED</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>WAS_ZERO</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>RCVD_SLAVE_ADDR</name>
              <description>接收到的从机地址字节（8 位）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>GOT_A_NAK</name>
              <description>检测到 NAK 标志：0=未检测到，1=检测到 NAK。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_NAK</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DETECTED_NAK</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>ANY_ENABLED_IRQ</name>
              <description>任意已使能中断请求：0=无请求，1=至少有一个中断请求。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_REQUESTS</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>AT_LEAST_ONE_REQUEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SLAVE_PRESENT</name>
              <description>从机功能存在标志：0=不可用，1=可用。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>UNAVAILABLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>AVAILABLE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>MASTER_PRESENT</name>
              <description>主机功能存在标志：0=不可用，1=可用。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>UNAVAILABLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>AVAILABLE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
          <description>I2C 数据寄存器，用于 PIO 模式下读写传输数据，或作为 DMA 数据接口。</description>
          <addressOffset>0x60</addressOffset>
          <fields>
            <field>
              <name>DATA</name>
              <description>PIO/DMA 数据读写端口（32 位），写操作发送数据，读操作接收数据。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG0</name>
          <description>I2C 调试寄存器 0，提供从机状态机、DMA 状态机、各类事件翻转位及 DMA 控制信号的调试可见性。</description>
          <addressOffset>0x70</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>SLAVE_STATE</name>
              <description>从机状态机当前状态（10 位）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>SLAVE_HOLD_CLK</name>
              <description>从机时钟保持状态：0=未保持，1=正在保持 SCL 低电平。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TESTMODE</name>
              <description>测试模式使能，用于芯片测试时的特殊模式。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CHANGE_TOGGLE</name>
              <description>CHANGE 事件翻转位，用于调试时观察状态变化事件。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>GRAB_TOGGLE</name>
              <description>GRAB 事件翻转位，用于调试时观察总线占用事件。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>STOP_TOGGLE</name>
              <description>STOP 事件翻转位，用于调试时观察 STOP 条件事件。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>START_TOGGLE</name>
              <description>START 事件翻转位，用于调试时观察 START 条件事件。</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMA_STATE</name>
              <description>DMA 状态机当前状态（10 位）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>TBD</name>
              <description>保留位（2 位），供未来扩展或内部测试使用。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DMATERMINATE</name>
              <description>DMA 终止信号，用于调试时观察 DMA 传输终止状态。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAKICK</name>
              <description>DMA 启动信号，用于调试时观察 DMA 传输启动状态。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAENDCMD</name>
              <description>DMA 结束命令信号，用于调试时观察 DMA 命令结束状态。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAREQ</name>
              <description>DMA 请求信号，用于调试时观察 DMA 请求状态。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG1</name>
          <description>I2C 调试寄存器 1，提供强制信号注入、从机测试模式、时钟生成器状态、DMA 字节使能及 I2C 引脚输入状态的调试可见性。</description>
          <addressOffset>0x80</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>FORCE_I2C_CLK_OE</name>
              <description>强制 I2C 时钟输出使能，用于调试时手动控制 SCL 输出。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FORCE_I2C_DATA_OE</name>
              <description>强制 I2C 数据输出使能，用于调试时手动控制 SDA 输出。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FORCE_RCV_ACK</name>
              <description>强制接收 ACK，用于调试时手动注入 ACK 信号。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FORCE_ARB_LOSS</name>
              <description>强制仲裁丢失，用于调试时模拟仲裁丢失场景。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FORCE_CLK_ON</name>
              <description>强制时钟开启，用于调试时强制使能时钟生成器。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LOCAL_SLAVE_TEST</name>
              <description>本地从机测试模式使能，用于芯片测试时启用内部从机测试逻辑。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LST_MODE</name>
              <description>从机监听传输模式：0=广播，1=本机写，2=本机读，3=非本机。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BCAST</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MY_WRITE</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MY_READ</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NOT_ME</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CLK_GEN_STATE</name>
              <description>时钟生成器状态机当前状态（8 位）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>DMA_BYTE_ENABLES</name>
              <description>DMA 字节使能掩码（4 位），指示当前 DMA 传输中哪些字节有效。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>I2C_DATA_IN</name>
              <description>I2C 数据输入引脚（SDA）的当前电平状态。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>I2C_CLK_IN</name>
              <description>I2C 时钟输入引脚（SCL）的当前电平状态。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>I2C 版本寄存器，记录 IP 核的主版本、次版本和步进版本号。</description>
          <addressOffset>0x90</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>步进版本号（16 位），标识当前 IP 的修订步进。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>次版本号（8 位）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>主版本号（8 位）。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>RTC</name>
      <description>STMP3770 RTC (Real-Time Clock) 外设寄存器与位域中文描述</description>
      <groupName>Timer</groupName>
      <baseAddress>0x8005C000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0xE0</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>RTC_ALARM</name>
        <value>22</value>
      </interrupt>
      <interrupt>
        <name>RTC_1MSEC</name>
        <value>48</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL</name>
          <description>实时时钟控制寄存器，用于配置中断使能、看门狗、强制更新及模块时钟/复位控制。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>ALARM_IRQ_EN</name>
              <description>闹钟中断使能，置位后允许 ALARM 匹配时产生中断。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ONEMSEC_IRQ_EN</name>
              <description>1毫秒中断使能，置位后允许每 1ms 产生一次中断。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ALARM_IRQ</name>
              <description>闹钟中断状态标志，硬件在 ALARM 匹配时置位，写 1 清除。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ONEMSEC_IRQ</name>
              <description>1毫秒中断状态标志，硬件每 1ms 置位一次，写 1 清除。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WATCHDOGEN</name>
              <description>看门狗使能，置位后启动 WATCHDOG 计数器。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FORCE_UPDATE</name>
              <description>强制更新，置位后强制将数字域寄存器值写入模拟域。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SUPPRESS_COPY2ANALOG</name>
              <description>抑制写回模拟域，置位后阻止数字域寄存器值拷贝到模拟域。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>时钟门控，置位后关闭 RTC 模块时钟以节能。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SFTRST</name>
              <description>软复位，置位后对 RTC 模块执行软件复位。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STAT</name>
          <description>实时时钟状态寄存器，反映寄存器同步状态及硬件功能存在性标志。</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>NEW_REGS</name>
              <description>新值待生效标志，位图中置 1 的位表示对应寄存器有新值尚未同步到模拟域。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>STALE_REGS</name>
              <description>写入未完成标志，位图中置 1 的位表示对应寄存器写入模拟域尚未完成。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>XTAL32768_PRESENT</name>
              <description>32.768kHz 晶振存在标志，置位表示该晶振已连接并可用。</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>XTAL32000_PRESENT</name>
              <description>32.000kHz 晶振存在标志，置位表示该晶振已连接并可用。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WATCHDOG_PRESENT</name>
              <description>看门狗功能存在标志，置位表示 RTC 集成看门狗硬件。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ALARM_PRESENT</name>
              <description>闹钟功能存在标志，置位表示 RTC 集成闹钟硬件。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RTC_PRESENT</name>
              <description>RTC 模块存在标志，置位表示 RTC 硬件存在。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MILLISECONDS</name>
          <description>实时时钟毫秒计数器，32 位自由运行毫秒计数。</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>COUNT</name>
              <description>毫秒计数值，32 位自由运行计数器，每 1ms 递增。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SECONDS</name>
          <description>实时时钟秒计数器，32 位自由运行秒计数。</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>COUNT</name>
              <description>秒计数值，32 位自由运行计数器，每 1 秒递增。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ALARM</name>
          <description>实时时钟闹钟寄存器，用于设置秒级闹钟比较值。</description>
          <addressOffset>0x40</addressOffset>
          <fields>
            <field>
              <name>VALUE</name>
              <description>闹钟比较值，当 SECONDS.COUNT 等于该值时触发闹钟事件。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>WATCHDOG</name>
          <description>看门狗定时器寄存器，用于配置看门狗倒计数初值。</description>
          <addressOffset>0x50</addressOffset>
          <fields>
            <field>
              <name>COUNT</name>
              <description>看门狗倒计数值，写入后递减，减至 0 时触发看门狗复位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PERSISTENT0</name>
          <description>掉电保持状态寄存器 0，保存系统级持久控制位，掉电后由备用电源维持。</description>
          <addressOffset>0x60</addressOffset>
          <fields>
            <field>
              <name>CLOCKSOURCE</name>
              <description>RTC 时钟源选择，0 表示 32.768kHz 晶振，1 表示 32.000kHz 晶振。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ALARM_WAKE_EN</name>
              <description>闹钟唤醒使能，置位后允许闹钟事件将系统从低功耗状态唤醒。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ALARM_EN</name>
              <description>闹钟功能使能，置位后启用 RTC 闹钟比较功能。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LCK_SECS</name>
              <description>秒计数器锁定，置位后锁定 SECONDS 寄存器防止误写。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>XTAL24MHZ_PWRUP</name>
              <description>24MHz 晶振上电控制，置位后给 24MHz 晶振电路上电。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>XTAL32KHZ_PWRUP</name>
              <description>32kHz 晶振上电控制，置位后给 32kHz 晶振电路上电。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>XTAL32_FREQ</name>
              <description>32kHz 晶振频率选择，0 表示 32.768kHz，1 表示 32.000kHz。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ALARM_WAKE</name>
              <description>闹钟唤醒标志，置位表示系统由闹钟事件唤醒。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MSEC_RES</name>
              <description>毫秒分辨率配置，5 位字段用于设置毫秒计数器的分辨率。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>DISABLE_XTALOK</name>
              <description>禁用 XTAL 正常指示，置位后关闭晶振起振 OK 检测。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LOWERBIAS</name>
              <description>降低偏置电流配置，2 位字段用于调节模拟偏置电流以降低功耗。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DISABLE_PSWITCH</name>
              <description>禁用 PSWITCH 功能，置位后关闭电源开关检测。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AUTO_RESTART</name>
              <description>自动重启使能，置位后系统在特定条件下自动重新启动。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SPARE_ANALOG</name>
              <description>模拟域备用位，14 位保留给模拟电路使用的备用配置字段。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>14</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PERSISTENT1</name>
          <description>掉电保持状态寄存器 1，32 位通用持久存储，可用于保存系统标志。</description>
          <addressOffset>0x70</addressOffset>
          <fields>
            <field>
              <name>GENERAL</name>
              <description>通用 32 位持久数据，掉电保持，可存储系统标志(如 USB 启动模式、OTG 角色等)。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ENUMERATE_500MA_TWICE</name>
                  <value>4096</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>USB_BOOT_PLAYER_MODE</name>
                  <value>2048</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SKIP_CHECKDISK</name>
                  <value>1024</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>USB_LOW_POWER_MODE</name>
                  <value>512</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OTG_HNP_BIT</name>
                  <value>256</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OTG_ATL_ROLE_BIT</name>
                  <value>128</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>PERSISTENT2</name>
          <description>掉电保持状态寄存器 2，32 位通用持久存储。</description>
          <addressOffset>0x80</addressOffset>
          <fields>
            <field>
              <name>GENERAL</name>
              <description>通用 32 位持久数据，掉电保持，由软件自由使用。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PERSISTENT3</name>
          <description>掉电保持状态寄存器 3，32 位通用持久存储。</description>
          <addressOffset>0x90</addressOffset>
          <fields>
            <field>
              <name>GENERAL</name>
              <description>通用 32 位持久数据，掉电保持，由软件自由使用。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PERSISTENT4</name>
          <description>掉电保持状态寄存器 4，32 位通用持久存储。</description>
          <addressOffset>0xA0</addressOffset>
          <fields>
            <field>
              <name>GENERAL</name>
              <description>通用 32 位持久数据，掉电保持，由软件自由使用。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PERSISTENT5</name>
          <description>掉电保持状态寄存器 5，32 位通用持久存储。</description>
          <addressOffset>0xB0</addressOffset>
          <fields>
            <field>
              <name>GENERAL</name>
              <description>通用 32 位持久数据，掉电保持，由软件自由使用。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG</name>
          <description>实时时钟调试寄存器，用于控制看门狗复位行为。</description>
          <addressOffset>0xC0</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>WATCHDOG_RESET</name>
              <description>看门狗复位标志，置位表示看门狗已触发复位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WATCHDOG_RESET_MASK</name>
              <description>看门狗复位屏蔽，置位后屏蔽看门狗产生的系统复位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>实时时钟版本寄存器，反映 RTC 模块的硬件版本信息。</description>
          <addressOffset>0xD0</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>步进版本号，16 位字段表示当前硬件的步进版本。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>次版本号，8 位字段表示当前硬件的次要版本。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>主版本号，8 位字段表示当前硬件的主要版本。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>PWM</name>
      <description>脉宽调制控制器(多通道 PWM 输出,可用于背光/蜂鸣等)</description>
      <groupName>Timer</groupName>
      <baseAddress>0x80064000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0xC0</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>CTRL</name>
          <description>PWM Control and Status Register</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>PWM0_ENABLE</name>
              <description>Bit 0. Enables PWM channel 0 to begin cycling when set to 1.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PWM1_ENABLE</name>
              <description>Bit 1. Enables PWM channel 1 to begin cycling when set to 1.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PWM2_ENABLE</name>
              <description>Bit 2. Enables PWM channel 2 to begin cycling when set to 1.</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PWM3_ENABLE</name>
              <description>Bit 3. Enables PWM channel 3 to begin cycling when set to 1.</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PWM4_ENABLE</name>
              <description>Bit 4. Enables PWM channel 4 to begin cycling when set to 1.</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PWM2_ANA_CTRL_ENABLE</name>
              <description>Bit 5. Setting to 1 enables PWM Channel 2 output to be enabled by analog circuitry outside this block.</description><bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OUTPUT_CUTOFF_EN</name>
              <description>输出截止使能，超出有效周期后强制输出无效态。</description><bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PWM0_PRESENT</name>
              <description>Bit 25. Read-only. 0 = PWM0 is not present in this product.</description><bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PWM1_PRESENT</name>
              <description>Bit 26. Read-only. 0 = PWM1 is not present in this product.</description><bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PWM2_PRESENT</name>
              <description>Bit 27. Read-only. 0 = PWM2 is not present in this product.</description><bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PWM3_PRESENT</name>
              <description>Bit 28. Read-only. 0 = PWM3 is not present in this product.</description><bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PWM4_PRESENT</name>
              <description>Bit 29. Read-only. 0 = PWM4 is not present in this product.</description><bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>Bit 30. Must be cleared to 0 for normal operation. When set to 1, gates off the clocks to the block.</description><bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SFTRST</name>
              <description>Bit 31. Must be cleared to 0 for normal operation. When set to 1, forces a block-wide reset.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>5</dim>
          <dimIncrement>0x20</dimIncrement>
          <dimIndex>0-4</dimIndex>
          <name>ACTIVE%s</name>
          <description>ACTIVE</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>ACTIVE</name>
              <description>PWM通道有效周期计数值（以分频后晶振周期为单位）。</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>INACTIVE</name>
              <description>PWM通道无效周期计数值（以分频后晶振周期为单位）。</description><bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>5</dim>
          <dimIncrement>0x20</dimIncrement>
          <dimIndex>0-4</dimIndex>
          <name>PERIOD%s</name>
          <description>PERIOD</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>PERIOD</name>
              <description>PWM通道周期计数值（周期 = PERIOD+1 个分频时钟）。</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>ACTIVE_STATE</name>
              <description>有效状态电平选择：0=高阻，2=低电平，3=高电平。</description><bitOffset>16</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>HI_Z</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_0</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_1</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>INACTIVE_STATE</name>
              <description>无效状态电平选择：0=高阻，2=低电平，3=高电平。</description><bitOffset>18</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>HI_Z</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_0</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_1</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CDIV</name>
              <description>时钟分频比选择：1/2/4/8/16/64/256/1024。</description><bitOffset>20</bitOffset>
              <bitWidth>3</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DIV_1</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV_2</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV_4</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV_8</name>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV_16</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV_64</name>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV_256</name>
                  <value>6</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV_1024</name>
                  <value>7</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>MATT</name>
              <description>多芯片连接模式，将24MHz晶振时钟输出到PWM引脚。</description><bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MATT_SEL</name>
              <description>多芯片连接模式选择。</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>PWM Version Register</description>
          <addressOffset>0xB0</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>Bits 15:0. Read-only. Fixed value reflecting the stepping of the RTL version. Reset: 0x0000.</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>Bits 23:16. Read-only. Fixed value reflecting the MINOR field of the RTL version. Reset: 0x01.</description><bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>Bits 31:24. Read-only. Fixed value reflecting the MAJOR field of the RTL version. Reset: 0x01.</description><bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>TIMROT</name>
      <description>STMP3770 TIMROT 外设：定时器与旋钮解码器。包含 4 个通用定时器（Timer0~3）和 1 个旋钮解码器，支持 PWM、晶振及旋钮输入等多种时钟源，可配置预分频、自动重载、中断等功能。ROTCTRL 控制旋钮解码器输入源、极性、过采样率及分频等；ROTCOUNT 保存旋钮旋转产生的计数值。各定时器通过 TIMCTRLn/TIMCOUNTn 寄存器组独立控制与计数。</description>
      <groupName>Timer</groupName>
      <baseAddress>0x80068000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0xB0</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>TIMER0</name>
        <value>28</value>
      </interrupt>
      <interrupt>
        <name>TIMER1</name>
        <value>29</value>
      </interrupt>
      <interrupt>
        <name>TIMER2</name>
        <value>30</value>
      </interrupt>
      <interrupt>
        <name>TIMER3</name>
        <value>31</value>
      </interrupt>
      <registers>
        <register>
          <name>ROTCTRL</name>
          <description>旋钮解码器控制寄存器，配置输入源选择、极性、过采样率、相对模式、分频系数，以及各定时器/旋钮存在性标志、时钟门控和软复位。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>SELECT_A</name>
              <description>旋钮 A 输入源选择：NEVER_TICK=不选；PWM0~4=对应 PWM 通道；ROTARYA/B=旋钮 A/B 输入。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NEVER_TICK</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PWM0</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PWM1</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PWM2</name>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PWM3</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PWM4</name>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ROTARYA</name>
                  <value>6</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ROTARYB</name>
                  <value>7</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SELECT_B</name>
              <description>旋钮 B 输入源选择：NEVER_TICK=不选；PWM0~4=对应 PWM 通道；ROTARYA/B=旋钮 A/B 输入。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>3</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NEVER_TICK</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PWM0</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PWM1</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PWM2</name>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PWM3</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PWM4</name>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ROTARYA</name>
                  <value>6</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ROTARYB</name>
                  <value>7</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>POLARITY_A</name>
              <description>旋钮 A 输入极性控制位。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>POLARITY_B</name>
              <description>旋钮 B 输入极性控制位。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OVERSAMPLE</name>
              <description>旋钮过采样率选择：8X/4X/2X/1X。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>_8X</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_4X</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_2X</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_1X</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>RELATIVE</name>
              <description>旋钮相对模式使能，置位后计数器按相对变化量累加或递减。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DIVIDER</name>
              <description>旋钮输入时钟分频系数，6 位无符号值。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>STATE</name>
              <description>旋钮解码器当前状态，3 位只读状态值。</description>
              <bitOffset>22</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TIM0_PRESENT</name>
              <description>Timer0 存在性标志，只读，1 表示该定时器存在。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TIM1_PRESENT</name>
              <description>Timer1 存在性标志，只读，1 表示该定时器存在。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TIM2_PRESENT</name>
              <description>Timer2 存在性标志，只读，1 表示该定时器存在。</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TIM3_PRESENT</name>
              <description>Timer3 存在性标志，只读，1 表示该定时器存在。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ROTARY_PRESENT</name>
              <description>旋钮解码器存在性标志，只读，1 表示该模块存在。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>时钟门控控制位，用于控制 TIMROT 模块时钟以节省功耗。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SFTRST</name>
              <description>软复位控制位，置位时对整个 TIMROT 模块执行软件复位。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ROTCOUNT</name>
          <description>旋钮解码器上下计数寄存器，保存旋钮旋转产生的计数值。</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>UPDOWN</name>
              <description>旋钮上下计数值，16 位，反映旋钮旋转的方向与幅度。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>4</dim>
          <dimIncrement>0x20</dimIncrement>
          <dimIndex>0-3</dimIndex>
          <name>TIMCTRL%s</name>
          <description>定时器控制寄存器（数组，4 个实例），配置时钟源、预分频、自动重载、更新触发、极性、中断使能及中断状态。</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>SELECT</name>
              <description>定时器时钟源选择：NEVER_TICK=不选；PWM0~4=对应 PWM 通道；ROTARYA/B=旋钮输入；32KHZ_XTAL/8KHZ_XTAL/4KHZ_XTAL/1KHZ_XTAL=对应晶振；TICK_ALWAYS=始终滴答。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NEVER_TICK</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PWM0</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PWM1</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PWM2</name>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PWM3</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PWM4</name>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ROTARYA</name>
                  <value>6</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ROTARYB</name>
                  <value>7</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_32KHZ_XTAL</name>
                  <value>8</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_8KHZ_XTAL</name>
                  <value>9</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_4KHZ_XTAL</name>
                  <value>10</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_1KHZ_XTAL</name>
                  <value>11</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TICK_ALWAYS</name>
                  <value>12</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>PRESCALE</name>
              <description>定时器预分频选择：DIV_BY_1=1 分频；DIV_BY_2=2 分频；DIV_BY_4=4 分频；DIV_BY_8=8 分频。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DIV_BY_1</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV_BY_2</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV_BY_4</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV_BY_8</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>RELOAD</name>
              <description>自动重载使能，计数到零后自动从 FIXED_COUNT 重新加载并继续计数。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>UPDATE</name>
              <description>更新控制位，置位后刷新计数值并使能计数器。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>POLARITY</name>
              <description>定时器极性控制位。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DUTY_CYCLE</name>
              <description>占空比测量模式使能(仅TIMCTRL3)，置位时进入占空比测量模式，TIMCOUNT3记录高电平宽度。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DUTY_VALID</name>
              <description>占空比数据有效标志(仅TIMCTRL3)，只读，硬件置位表示TIMCOUNT3中占空比数据有效。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>TEST_SIGNAL</name>
              <description>被测信号源选择(仅TIMCTRL3占空比模式)，枚举值与SELECT字段相同。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>IRQ_EN</name>
              <description>定时器中断使能控制位，置位时允许计数到零产生中断。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>IRQ</name>
              <description>定时器中断状态标志，计数到零时置位。</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>4</dim>
          <dimIncrement>0x20</dimIncrement>
          <dimIndex>0-3</dimIndex>
          <name>TIMCOUNT%s</name>
          <description>定时器计数寄存器（数组，4 个实例），包含重载初值与当前递减计数值。</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>FIXED_COUNT</name>
              <description>定时器重载初值，计数器归零时从此值重新加载（需 RELOAD 使能）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>RUNNING_COUNT</name>
              <description>定时器当前递减计数值，16 位只读，计数过程中实时递减。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>TIMROT 版本寄存器，保存模块的步进、次要和主要版本号。</description>
          <addressOffset>0xA0</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>步进版本号，16 位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>次要版本号，8 位。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>主要版本号，8 位。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>UARTAPP</name>
      <description>应用 UART(高速 UART,支持 DMA 收发,区别于调试用 UARTDBG)</description>
      <groupName>UART</groupName>
      <baseAddress>0x8006C000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0xB0</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>UARTAPP_TX_DMA</name>
        <value>23</value>
      </interrupt>
      <interrupt>
        <name>UARTAPP_INTERNAL</name>
        <value>24</value>
      </interrupt>
      <interrupt>
        <name>UARTAPP_RX_DMA</name>
        <value>25</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL0</name>
          <description>CTRL0</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>XFER_COUNT</name>
              <description>Number of bytes to receive [15:0]. Must be a multiple of 4.</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>RXTIMEOUT</name>
              <description>Receive Time-Out Counter Value [10:0]. Number of 8-bit-time to wait before asserting time-out on the RX input. 7-bit-time is added to the programmed value; default 0x3 (31-bit-time).</description><bitOffset>16</bitOffset>
              <bitWidth>11</bitWidth>
            </field>
            <field>
              <name>RXTO_ENABLE</name>
              <description>RXTIMEOUT Enable. 0 = Receive time-out will not affect receive DMA operation. 1 = Receive time-out will cause the receive DMA logic to terminate.</description><bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RX_SOURCE</name>
              <description>Source of Receive Data. If set to 1, the status register will be the source of the DMA; otherwise RX data will be the source.</description><bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RUN</name>
              <description>Tell the UART to execute the RX DMA command. The UART will clear this bit at the end of receive execution.</description><bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>Clock gate. Clear to 0 for normal operation. Setting to 1 (default) gates all block-level clocks off to minimize AC energy consumption.</description><bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SFTRST</name>
              <description>Soft reset. Clear to 0 for normal operation. When set to 1 (default), the entire block is held in its reset state.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL1</name>
          <description>CTRL1</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>XFER_COUNT</name>
              <description>Number of bytes to transmit [15:0].</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>RUN</name>
              <description>Tell the UART to execute the TX DMA command. The UART will clear this bit at the end of transmit execution.</description><bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL2</name>
          <description>CTRL2</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>UARTEN</name>
              <description>UART Enable. If set to 1, the UART is enabled. Completes current character before stopping when disabled mid-transmission or reception.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SIREN</name>
              <description>SIR Enable. Unsupported.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SIRLP</name>
              <description>IrDA SIR Low Power Mode. Unsupported.</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>USE_LCR2</name>
              <description>If set to 1, the Line Control 2 Register values are used.</description><bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LBE</name>
              <description>Loopback Enable. If set to 1, UARTTXD is fed through to UARTRXD. Modem outputs are also fed through to modem inputs.</description><bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXE</name>
              <description>Transmit Enable. If set to 1, the transmit section of the UART is enabled. Completes current character before stopping when disabled mid-transmission.</description><bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXE</name>
              <description>Receive Enable. If set to 1, the receive section of the UART is enabled. Completes current character before stopping when disabled mid-reception.</description><bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DTR</name>
              <description>Data Transmit Ready. Complement of nUARTDTR modem status output. Unsupported.</description><bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RTS</name>
              <description>Request To Send. Software can manually control nUARTRTS via this bit when RTSEN=0. Complement of nUARTRTS output.</description><bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OUT1</name>
              <description>Complement of the UART Out1 (nUARTOut1) modem status output. Unsupported.</description><bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OUT2</name>
              <description>Complement of the UART Out2 (nUARTOut2) modem status output. Unsupported.</description><bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RTSEN</name>
              <description>RTS Hardware Flow Control Enable. If set to 1, RTS hardware flow control is enabled; data is only requested when there is space in the receive FIFO.</description><bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTSEN</name>
              <description>CTS Hardware Flow Control Enable. If set to 1, CTS hardware flow control is enabled; data is only transmitted when nUARTCTS is asserted.</description><bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXIFLSEL</name>
              <description>Transmit Interrupt FIFO Level Select [2:0]. Trigger points: 0=EMPTY (no entries), 1=ONE_QUARTER (&lt;4), 2=ONE_HALF (&lt;8), 3=THREE_QUARTERS (&lt;12), 4=SEVEN_EIGHTHS (&lt;14), 5-7=Reserved.</description><bitOffset>16</bitOffset>
              <bitWidth>3</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>EMPTY</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ONE_QUARTER</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ONE_HALF</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>THREE_QUARTERS</name>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SEVEN_EIGHTHS</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>INVALID5</name>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>INVALID6</name>
                  <value>6</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>INVALID7</name>
                  <value>7</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>RXIFLSEL</name>
              <description>Receive Interrupt FIFO Level Select [2:0]. Trigger points: 0=NOT_EMPTY (&gt;=1 of 16), 1=ONE_QUARTER (&gt;=4), 2=ONE_HALF (&gt;=8), 3=THREE_QUARTERS (&gt;=12), 4=SEVEN_EIGHTHS (&gt;=14), 5-7=Reserved.</description><bitOffset>20</bitOffset>
              <bitWidth>3</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOT_EMPTY</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ONE_QUARTER</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ONE_HALF</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>THREE_QUARTERS</name>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SEVEN_EIGHTHS</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>INVALID5</name>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>INVALID6</name>
                  <value>6</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>INVALID7</name>
                  <value>7</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>RXDMAE</name>
              <description>Receive DMA Enable. Data Register can contain up to 4 bytes per read. RXFIFO must be enabled in RXDMA mode.</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXDMAE</name>
              <description>Transmit DMA Enable. Data Register can be loaded with up to 4 bytes per write. TXFIFO must be enabled in TXDMA mode.</description><bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAONERR</name>
              <description>DMA On Error. If set to 1, receive DMA will terminate on error (cmd_end signal may not be asserted when this occurs).</description><bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RTS_SEMAPHORE</name>
              <description>If set to 1, RTS is deasserted when the semaphore threshold is less than 2.</description><bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>INVERT_RX</name>
              <description>Invert RX signal. If set to 1, the RX input is inverted before sampled.</description><bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>INVERT_TX</name>
              <description>Invert TX signal. If set to 1, the TX output is inverted before transmitted.</description><bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>INVERT_CTS</name>
              <description>Invert CTS signal. If set to 1, the CTS input is inverted before sampled.</description><bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>INVERT_RTS</name>
              <description>Invert RTS signal. If set to 1, the RTS output is inverted before transmitted.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>LINECTRL</name>
          <description>LINECTRL</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>BRK</name>
              <description>Send Break. If set to 1, a low-level is continually output on UARTTXD after completing current character. Must be set for at least two complete frames. Normal use: cleared to 0.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PEN</name>
              <description>Parity Enable. 1 = parity checking and generation enabled. 0 = parity disabled, no parity bit added.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EPS</name>
              <description>Even Parity Select. 1 = even parity generation and checking. 0 = odd parity. No effect when PEN=0.</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>STP2</name>
              <description>Two Stop Bits Select. If set to 1, two stop bits are transmitted at end of frame. Receive logic does not check for two stop bits.</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FEN</name>
              <description>Enable FIFOs. 1 = FIFO mode enabled. 0 = FIFOs disabled (character mode, 1-byte-deep holding registers).</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WLEN</name>
              <description>Word Length [1:0]. 11=8 bits, 10=7 bits, 01=6 bits, 00=5 bits.</description><bitOffset>5</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SPS</name>
              <description>Stick Parity Select. When bits 1,2,7 are set, parity is transmitted/checked as 0. When bits 1 and 7 set, bit 2 clear, parity is transmitted/checked as 1. Cleared = stick parity disabled.</description><bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BAUD_DIVFRAC</name>
              <description>Baud Rate Fraction [5:0]. The fractional baud rate divisor.</description><bitOffset>8</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>BAUD_DIVINT</name>
              <description>Baud Rate Integer [15:0]. The integer baud rate divisor.</description><bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>LINECTRL2</name>
          <description>LINECTRL2</description>
          <addressOffset>0x40</addressOffset>
          <fields>
            <field>
              <name>PEN</name>
              <description>Parity Enable. 1 = parity checking/generation enabled. 0 = disabled.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EPS</name>
              <description>Even Parity Select. 1 = even parity. 0 = odd parity. No effect when PEN=0.</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>STP2</name>
              <description>Two Stop Bits Select. Same behavior as HW_UARTAPP_LINECTRL.STP2.</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FEN</name>
              <description>Enable FIFOs. 1 = FIFO mode enabled. 0 = FIFOs disabled (character mode).</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WLEN</name>
              <description>Word Length [1:0]. 00=5 bits, 01=6 bits, 10=7 bits, 11=8 bits.</description><bitOffset>5</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SPS</name>
              <description>Stick Parity Select. Same behavior as HW_UARTAPP_LINECTRL.SPS.</description><bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BAUD_DIVFRAC</name>
              <description>Baud Rate Fraction [5:0]. The fractional baud rate divisor.</description><bitOffset>8</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>BAUD_DIVINT</name>
              <description>Baud Rate Integer [15:0]. The integer baud rate divisor.</description><bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>INTR</name>
          <description>INTR</description>
          <addressOffset>0x50</addressOffset>
          <fields>
            <field>
              <name>RIMIS</name>
              <description>nUARTRI Modem Interrupt Status. Unsupported.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTSMIS</name>
              <description>nUARTCTS Modem Interrupt Status. Clear by writing bit-clear address with bit set to 1.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DCDMIS</name>
              <description>nUARTDCD Modem Interrupt Status. Unsupported.</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DSRMIS</name>
              <description>nUARTDSR Modem Interrupt Status. Unsupported.</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXIS</name>
              <description>Receive Interrupt Status. Clear by writing bit-clear address with bit set to 1.</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXIS</name>
              <description>Transmit Interrupt Status. Clear by writing bit-clear address with bit set to 1.</description><bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RTIS</name>
              <description>Receive Time-Out Interrupt Status. Clear by writing bit-clear address with bit set to 1.</description><bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FEIS</name>
              <description>Framing Error Interrupt Status. Clear by writing bit-clear address with bit set to 1.</description><bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PEIS</name>
              <description>Parity Error Interrupt Status. Clear by writing bit-clear address with bit set to 1.</description><bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BEIS</name>
              <description>Break Error Interrupt Status. Clear by writing bit-clear address with bit set to 1.</description><bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OEIS</name>
              <description>Overrun Error Interrupt Status. Clear by writing bit-clear address with bit set to 1.</description><bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RIMIEN</name>
              <description>nUARTRI Modem Interrupt Enable. Unsupported.</description><bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTSMIEN</name>
              <description>nUARTCTS Modem Interrupt Enable.</description><bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DCDMIEN</name>
              <description>nUARTDCD Modem Interrupt Enable. Unsupported.</description><bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DSRMIEN</name>
              <description>nUARTDSR Modem Interrupt Enable. Unsupported.</description><bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXIEN</name>
              <description>Receive Interrupt Enable.</description><bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXIEN</name>
              <description>Transmit Interrupt Enable.</description><bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RTIEN</name>
              <description>Receive Time-Out Interrupt Enable.</description><bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FEIEN</name>
              <description>Framing Error Interrupt Enable.</description><bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PEIEN</name>
              <description>Parity Error Interrupt Enable.</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BEIEN</name>
              <description>Break Error Interrupt Enable.</description><bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OEIEN</name>
              <description>Overrun Error Interrupt Enable.</description><bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
          <description>DATA</description>
          <addressOffset>0x60</addressOffset>
          <fields>
            <field>
              <name>DATA</name>
              <description>Receive/Transmit data [31:0]. In DMA mode, up to 4 characters accessed at a time. In PIO mode, only one character at a time.</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STAT</name>
          <description>STAT</description>
          <addressOffset>0x70</addressOffset>
          <fields>
            <field>
              <name>RXCOUNT</name>
              <description>Number of bytes received during a receive DMA command [15:0].</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>FERR</name>
              <description>Framing Error. For PIO mode: last character read. For DMA mode: set if any received character had a Framing Error. Clear by writing 0.</description><bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PERR</name>
              <description>Parity Error. For PIO mode: last character read. For DMA mode: set if any received character had a Parity Error. Clear by writing 0.</description><bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BERR</name>
              <description>Break Error. For PIO mode: last character read from data register. For DMA mode: set if any received character had a Break Error. Clear by writing 0.</description><bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OERR</name>
              <description>Overrun Error. Set if data received and FIFO already full. Cleared by any write to the Status Register.</description><bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXBYTE_INVALID</name>
              <description>Invalid state of last read of Receive Data [3:0]. Each bit corresponds to one byte of RX data. 1=invalid.</description><bitOffset>20</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>RXFE</name>
              <description>Receive FIFO Empty.</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXFF</name>
              <description>Transmit FIFO Full.</description><bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXFF</name>
              <description>Receive FIFO Full.</description><bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXFE</name>
              <description>Transmit FIFO Empty. With FIFO disabled: set when transmit holding register is empty. With FIFO enabled: set when transmit FIFO is empty.</description><bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTS</name>
              <description>Clear To Send.</description><bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BUSY</name>
              <description>UART Busy.</description><bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HISPEED</name>
              <description>Indicates high-speed function is present when reads back 1. 0=HISPEED not present, 1=HISPEED present.</description><bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>UNAVAILABLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>AVAILABLE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>PRESENT</name>
              <description>Indicates UARTAPP is present when reads back 1. 0=UARTAPP not present, 1=UARTAPP present.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>UNAVAILABLE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>AVAILABLE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG</name>
          <description>DEBUG</description>
          <addressOffset>0x80</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>RXDMARQ</name>
              <description>DMA Request Status. Reflects state of toggle signal for UART_RXDMAREQ. RX burst request not supported.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXDMARQ</name>
              <description>DMA Request Status. Reflects state of toggle signal for UART_TXDMAREQ. TX burst request not supported.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXCMDEND</name>
              <description>DMA Command End Status. Reflects state of toggle signal for UART_RXCMDEND.</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXCMDEND</name>
              <description>DMA Command End Status. Reflects state of toggle signal for UART_TXCMDEND.</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXDMARUN</name>
              <description>DMA Command Run Status. Reflects state of toggle signal for RXDMARUN.</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXDMARUN</name>
              <description>DMA Command Run Status. Reflects state of toggle signal for TXDMARUN.</description><bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXFBAUD_DIV</name>
              <description>接收波特率分频整数部分（调试用）。</description><bitOffset>10</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>RXIBAUD_DIV</name>
              <description>接收波特率分频小数部分（调试用）。</description><bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>VERSION</description>
          <addressOffset>0x90</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>Fixed read-only value reflecting the stepping of RTL version [15:0].</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>Fixed read-only value reflecting the MINOR field of RTL version [7:0].</description><bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>Fixed read-only value reflecting the MAJOR field of RTL version [7:0].</description><bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>AUTOBAUD</name>
          <description>AUTOBAUD</description>
          <addressOffset>0xA0</addressOffset>
          <fields>
            <field>
              <name>BAUD_DETECT_ENABLE</name>
              <description>波特率检测使能，置位时UART自动检测接收数据的波特率。</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>START_BAUD_DETECT</name>
              <description>启动波特率检测，写1开始自动波特率测量。</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>START_WITH_RUNBIT</name>
              <description>检测到RUN位时启动波特率检测。</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TWO_REF_CHARS</name>
              <description>使用两个参考字符进行波特率检测。</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>UPDATE_TX</name>
              <description>将检测到的波特率同时更新到发送通道。</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>REFCHAR0</name>
              <description>波特率检测参考字符0，用于测量接收波特率。</description><bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>REFCHAR1</name>
              <description>波特率检测参考字符1，用于双字符模式。</description><bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>UARTDBG</name>
      <description>STMP3770 UARTDBG 调试串口外设（ARM PrimeCell PL011 兼容），基地址 0x80070000，用于内核调试输出。包含数据收发、接收状态/错误清除、标志、红外低功耗计数、整数/小数波特率分频、线控、控制、FIFO 中断触发水平、中断屏蔽、原始中断状态、屏蔽后中断状态、中断清除及 DMA 控制等寄存器。</description>
      <groupName>UART</groupName>
      <baseAddress>0x80070000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x50</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>DEBUG_UART</name>
        <value>0</value>
      </interrupt>
      <registers>
        <register>
          <name>DR</name>
          <description>UART 数据寄存器，读写收发字节并附带接收错误标志。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>DATA</name>
              <description>收发数据字节（8 位），写入时送入发送 FIFO，读取时返回接收 FIFO 数据。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>FE</name>
              <description>接收帧错误标志（Frame Error），读取时反映最近接收字节的帧错误状态。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PE</name>
              <description>接收校验错误标志（Parity Error），读取时反映最近接收字节的校验错误状态。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BE</name>
              <description>接收 Break 错误标志（Break Error），读取时反映最近接收字节是否检测到 Break 条件。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OE</name>
              <description>接收溢出错误标志（Overrun Error），读取时反映 FIFO 溢出状态。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>UNAVAILABLE</name>
              <description>未实现位，读取值未定义。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RSR_ECR</name>
          <description>UART 接收状态寄存器（读）/ 错误清除寄存器（写），读取时返回接收错误状态，写入时向 EC 字段写值以清除错误标志。</description>
          <addressOffset>0x4</addressOffset>
          <fields>
            <field>
              <name>FE</name>
              <description>帧错误状态（Frame Error）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PE</name>
              <description>校验错误状态（Parity Error）。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BE</name>
              <description>Break 错误状态（Break Error）。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OE</name>
              <description>溢出错误状态（Overrun Error）。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EC</name>
              <description>错误清除（Error Clear），写入时向该 4 位字段写值以清除接收错误标志。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>UNAVAILABLE</name>
              <description>未实现位，读取值未定义。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>24</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>FR</name>
          <description>UART 标志寄存器（只读），反映 UART 当前状态与 FIFO 状态。</description>
          <addressOffset>0x18</addressOffset>
          <fields>
            <field>
              <name>CTS</name>
              <description>CTS 调制解调器状态输入（Clear To Send）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DSR</name>
              <description>DSR 调制解调器状态输入（Data Set Ready）。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DCD</name>
              <description>DCD 调制解调器状态输入（Data Carrier Detect）。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BUSY</name>
              <description>发送忙标志，表示 UART 正在发送数据。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXFE</name>
              <description>接收 FIFO 空标志（Receive FIFO Empty）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXFF</name>
              <description>发送 FIFO 满标志（Transmit FIFO Full）。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXFF</name>
              <description>接收 FIFO 满标志（Receive FIFO Full）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXFE</name>
              <description>发送 FIFO 空标志（Transmit FIFO Empty）。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RI</name>
              <description>RI 调制解调器状态输入（Ring Indicator）。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>UNAVAILABLE</name>
              <description>未实现位，读取值未定义。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ILPR</name>
