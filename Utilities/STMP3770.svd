    </peripheral>
    <peripheral>
      <name>LCDIF</name>
      <description>STMP3770 LCDIF (eLCDIF) 显示控制器，支持 MPU/8080 并行接口、VSYNC 模式与 DOTCLK 模式，集成 DMA 帧缓冲、RGB-to-YCbCr 4:2:2 CSC 转换、DVI 输出及引脚共享仲裁。基地址 0x80030000。</description>
      <groupName>Display</groupName>
      <baseAddress>0x80030000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x210</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>LCDIF_DMA</name>
        <value>45</value>
      </interrupt>
      <interrupt>
        <name>LCDIF_ERROR</name>
        <value>46</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL</name>
          <description>LCDIF 通用控制寄存器，控制数据传输启动、数据格式、接口模式、字节序、移位及复位等全局行为。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>COUNT</name>
              <description>LCD 数据格式选择，编码像素数据输出位宽（0=16 位，1=8 位，2=18 位，3=24 位）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>_16_BIT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_8_BIT</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_18_BIT</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_24_BIT</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>RUN</name>
              <description>启动 LCDIF 数据传输，写 1 使能传输引擎运行。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>_16_BIT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_8_BIT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>WORD_LENGTH</name>
              <description>像素字长选择，0=16 位，1=24 位。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_SWAP</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BIG_ENDIAN_SWAP</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DATA_SELECT</name>
              <description>MPU/8080 接口命令/数据选择，0=命令模式，1=数据模式。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>CMD_MODE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DATA_MODE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DOTCLK_MODE</name>
              <description>DOTCLK 接口模式使能，1 表示使用同步 DOTCLK 时序驱动 RGB 屏。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VSYNC_MODE</name>
              <description>VSYNC 接口模式使能，1 表示使用 VSYNC 同步模式。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DATA_SWIZZLE</name>
              <description>输入数据字节序调整（Swizzle），控制 32 位字内各字节的排列顺序。</description>
              <bitOffset>21</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>BYPASS_COUNT</name>
              <description>旁路内部行列计数器，1 时由外部逻辑或 DMA 直接控制传输终止。</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DVI_MODE</name>
              <description>DVI 输出模式使能，1 时启用 DVI/数字视频接口输出。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SHIFT_NUM_BITS</name>
              <description>数据移位的位数（0-3），指定像素数据在输出前左/右移的位数。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DATA_SHIFT_DIR</name>
              <description>数据移位方向，0=左移，1=右移。</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>TXDATA_SHIFT_LEFT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TXDATA_SHIFT_RIGHT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>WAIT_FOR_VSYNC_EDGE</name>
              <description>等待 VSYNC 边沿后再启动帧传输，用于帧同步对齐。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>READ_WRITEB</name>
              <description>读写方向控制，0=写（发送），1=读（接收）。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>时钟门控，1 时关闭 LCDIF 内部时钟以节省功耗。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SFTRST</name>
              <description>软复位，写 1 对 LCDIF 模块进行软件复位。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL1</name>
          <description>LCDIF 通用控制寄存器 1，包含 LCD 复位、接口子模式、中断状态/使能及字节打包格式。</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>RESET</name>
              <description>LCD 面板硬件复位信号控制，0=低电平复位，1=高电平释放。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>LCDRESET_LOW</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LCDRESET_HIGH</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>MODE86</name>
              <description>MPU 接口子模式选择，0=8080 模式，1=6800 模式。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>_8080_MODE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>_6800_MODE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>BUSY_ENABLE</name>
              <description>BUSY 信号检测使能，1 时 LCDIF 在 MPU 读/写期间检测外部 BUSY 信号。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BUSY_DISABLED</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUSY_ENABLED</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>LCD_CS_CTRL</name>
              <description>LCD 片选信号控制，直接控制 CS 引脚输出电平。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIRST_READ_DUMMY</name>
              <description>首次读虚拟周期请求，1 时在读序列开头插入一个虚拟读周期。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_REQUEST</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>REQUEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>READ_MODE_NUM_PACKED_SUBWORDS</name>
              <description>读模式下每字内打包的子字数量，决定一次 32 位读操作中包含的有效像素子字数。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>VSYNC_EDGE_IRQ</name>
              <description>VSYNC 边沿中断状态，1 表示检测到 VSYNC 边沿中断请求。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_REQUEST</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>REQUEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CUR_FRAME_DONE_IRQ</name>
              <description>当前帧完成中断状态，1 表示当前帧传输完成中断请求。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_REQUEST</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>REQUEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>UNDERFLOW_IRQ</name>
              <description>下溢中断状态，1 表示 TXFIFO 下溢中断请求。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_REQUEST</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>REQUEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>OVERFLOW_IRQ</name>
              <description>溢出中断状态，1 表示 RXFIFO/TXFIFO 溢出中断请求。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_REQUEST</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>REQUEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>VSYNC_EDGE_IRQ_EN</name>
              <description>VSYNC 边沿中断使能，1 时允许 VSYNC_EDGE_IRQ 产生中断。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CUR_FRAME_DONE_IRQ_EN</name>
              <description>当前帧完成中断使能，1 时允许 CUR_FRAME_DONE_IRQ 产生中断。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>UNDERFLOW_IRQ_EN</name>
              <description>下溢中断使能，1 时允许 UNDERFLOW_IRQ 产生中断。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OVERFLOW_IRQ_EN</name>
              <description>溢出中断使能，1 时允许 OVERFLOW_IRQ 产生中断。</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BYTE_PACKING_FORMAT</name>
              <description>字节打包格式，32 位字内各字节通道的有效/无效掩码，用于非 32 位对齐像素格式。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TRANSFER_COUNT</name>
          <description>LCDIF 有效数据传输计数寄存器，定义一帧内水平与垂直方向的像素数量。</description>
          <alternateRegister>TIMING</alternateRegister>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>H_COUNT</name>
              <description>水平方向有效像素计数（每行像素数）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>V_COUNT</name>
              <description>垂直方向有效像素计数（行数）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TIMING</name>
          <description>LCD 接口时序寄存器，配置 MPU/8080 并行接口的命令与数据建立/保持周期。</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>DATA_SETUP</name>
              <description>数据写操作的建立周期数（DATA 有效到 WR 有效之间的等待时钟数）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>DATA_HOLD</name>
              <description>数据写操作的保持周期数（WR 无效后 DATA 保持有效的时钟数）。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>CMD_SETUP</name>
              <description>命令写操作的建立周期数（CMD 有效到 WR 有效之间的等待时钟数）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>CMD_HOLD</name>
              <description>命令写操作的保持周期数（WR 无效后 CMD 保持有效的时钟数）。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CUR_BUF</name>
          <description>LCD 接口当前帧缓冲地址寄存器，存储 DMA 当前正在传输的帧数据物理地址。</description>
          <alternateRegister>VDCTRL1</alternateRegister>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>ADDR</name>
              <description>当前帧缓冲在系统内存中的 32 位物理地址。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VDCTRL1</name>
          <description>LCDIF VSYNC/DOTCLK 模式控制寄存器 1，定义 VSYNC 周期（帧总周期）。</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>VSYNC_PERIOD</name>
              <description>VSYNC 周期值，表示一帧的总时钟周期数（含有效与消隐区）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>NEXT_BUF</name>
          <description>LCD 接口下一帧缓冲地址寄存器，存储 DMA 下一帧待传输的帧数据物理地址。</description>
          <alternateRegister>VDCTRL2</alternateRegister>
          <addressOffset>0x40</addressOffset>
          <fields>
            <field>
              <name>ADDR</name>
              <description>下一帧缓冲在系统内存中的 32 位物理地址，硬件在当前帧完成后自动切换。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VDCTRL2</name>
          <description>LCDIF VSYNC/DOTCLK 模式控制寄存器 2，定义 HSYNC 周期与脉冲宽度。</description>
          <addressOffset>0x40</addressOffset>
          <fields>
            <field>
              <name>HSYNC_PERIOD</name>
              <description>HSYNC 周期值，表示一行的总时钟周期数（含有效与消隐区）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>18</bitWidth>
            </field>
            <field>
              <name>HSYNC_PULSE_WIDTH</name>
              <description>HSYNC 脉冲宽度，表示水平同步脉冲持续的有效时钟周期数。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PAGETABLE</name>
          <description>LCDIF 页表寄存器，使能 DMA 页表寻址并配置页表基地址。</description>
          <alternateRegister>VDCTRL3</alternateRegister>
          <addressOffset>0x50</addressOffset>
          <fields>
            <field>
              <name>ENABLE</name>
              <description>页表机制使能，1 时 DMA 通过页表进行分散/聚集式地址转换。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FLUSH</name>
              <description>页表刷新，写 1 强制刷新内部页表缓存。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BASE</name>
              <description>页表基地址的高 18 位（以 16KB 对齐），指向内存中的页表起始位置。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>18</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VDCTRL3</name>
          <description>LCDIF VSYNC/DOTCLK 模式控制寄存器 3，配置行列等待计数及同步信号复用。</description>
          <addressOffset>0x50</addressOffset>
          <fields>
            <field>
              <name>VERTICAL_WAIT_CNT</name>
              <description>垂直等待计数，表示 VSYNC 有效后到首行有效数据前的行等待周期数。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>HORIZONTAL_WAIT_CNT</name>
              <description>水平等待计数，表示 HSYNC 有效后到首像素有效数据前的时钟等待周期数。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
            <field>
              <name>VSYNC_ONLY</name>
              <description>仅 VSYNC 模式，1 时关闭 DOTCLK 输出，仅使用 VSYNC 同步。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MUX_SYNC_SIGNALS</name>
              <description>同步信号复用使能，1 时将 VSYNC/HSYNC/ENABLE 信号复用输出。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VDCTRL4</name>
          <description>LCDIF VSYNC/DOTCLK 模式控制寄存器 4，配置水平有效数据计数及同步信号强制输出。</description>
          <addressOffset>0x60</addressOffset>
          <fields>
            <field>
              <name>DOTCLK_H_VALID_DATA_CNT</name>
              <description>DOTCLK 模式下每行有效数据像素计数。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>18</bitWidth>
            </field>
            <field>
              <name>SYNC_SIGNALS_ON</name>
              <description>强制同步信号输出使能，1 时持续输出 HSYNC/VSYNC/ENABLE 波形。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VDCTRL0</name>
          <description>LCDIF VSYNC/DOTCLK 模式控制寄存器 0，配置 VSYNC 脉冲宽度、极性、半行模式及同步信号属性。</description>
          <addressOffset>0x70</addressOffset>
          <fields>
            <field>
              <name>VSYNC_PULSE_WIDTH</name>
              <description>VSYNC 脉冲宽度，表示垂直同步脉冲持续的有效时钟周期数。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>18</bitWidth>
            </field>
            <field>
              <name>HALF_LINE_MODE</name>
              <description>半行模式使能，1 时每帧按半行粒度进行扫描时序控制。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HALF_LINE</name>
              <description>半行指示，当前处于半行扫描状态标志（只读）。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VSYNC_PULSE_WIDTH_UNIT</name>
              <description>VSYNC 脉冲宽度单位，0=以像素时钟为单位，1=以行为单位。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VSYNC_PERIOD_UNIT</name>
              <description>VSYNC 周期单位，0=以像素时钟为单位，1=以行为单位。</description>
              <bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE_POL</name>
              <description>数据使能信号（ENABLE/DE）极性，0=低电平有效，1=高电平有效。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DOTCLK_POL</name>
              <description>DOTCLK 像素时钟极性，0=上升沿采样，1=下降沿采样。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HSYNC_POL</name>
              <description>HSYNC 水平同步极性，0=低电平有效，1=高电平有效。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VSYNC_POL</name>
              <description>VSYNC 垂直同步极性，0=低电平有效，1=高电平有效。</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE_PRESENT</name>
              <description>数据使能信号（ENABLE/DE）存在标志，1 表示接口使用 DE 信号。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VSYNC_OEB</name>
              <description>VSYNC 引脚方向控制，0=输出（内部产生 VSYNC），1=输入（外部接收 VSYNC）。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>VSYNC_OUTPUT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>VSYNC_INPUT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>DVICTRL0</name>
          <description>数字视频接口控制寄存器 0，配置 DVI 输出时视频帧的行数、水平消隐与有效像素。</description>
          <alternateRegister>VDCTRL0</alternateRegister>
          <addressOffset>0x70</addressOffset>
          <fields>
            <field>
              <name>V_LINES_CNT</name>
              <description>每帧有效视频行数（垂直方向总行数）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>H_BLANKING_CNT</name>
              <description>水平消隐期像素计数（每行中无效像素时钟数）。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>H_ACTIVE_CNT</name>
              <description>水平有效像素计数（每行中有效像素数）。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>11</bitWidth>
            </field>
            <field>
              <name>START_TRS</name>
              <description>DVI 传输启动，写 1 开始 DVI 数据流输出。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DVICTRL1</name>
          <description>数字视频接口控制寄存器 1，配置隔行扫描时场 1 与场 2 的起止行位置。</description>
          <alternateRegister>VDCTRL0</alternateRegister>
          <addressOffset>0x70</addressOffset>
          <fields>
            <field>
              <name>F2_START_LINE</name>
              <description>场 2（F2）起始行号，定义隔行扫描第二场的第一有效行。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>F1_END_LINE</name>
              <description>场 1（F1）结束行号，定义隔行扫描第一场的最后一有效行。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>F1_START_LINE</name>
              <description>场 1（F1）起始行号，定义隔行扫描第一场的第一有效行。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DVICTRL2</name>
          <description>数字视频接口控制寄存器 2，配置场 1 垂直消隐及场 2 结束行位置。</description>
          <addressOffset>0x80</addressOffset>
          <fields>
            <field>
              <name>V1_BLANK_END_LINE</name>
              <description>场 1 垂直消隐结束行号，定义第一场消隐期结束、有效视频开始的行。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>V1_BLANK_START_LINE</name>
              <description>场 1 垂直消隐开始行号，定义第一场有效视频结束、消隐开始的行。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>F2_END_LINE</name>
              <description>场 2（F2）结束行号，定义隔行扫描第二场的最后一有效行。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DVICTRL3</name>
          <description>数字视频接口控制寄存器 3，配置场 2 垂直消隐起止行位置。</description>
          <addressOffset>0x90</addressOffset>
          <fields>
            <field>
              <name>V2_BLANK_END_LINE</name>
              <description>场 2 垂直消隐结束行号，定义第二场消隐期结束、有效视频开始的行。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>V2_BLANK_START_LINE</name>
              <description>场 2 垂直消隐开始行号，定义第二场有效视频结束、消隐开始的行。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DVICTRL4</name>
          <description>数字视频接口控制寄存器 4，配置 DVI 水平填充计数及 YCbCr 填充值。</description>
          <addressOffset>0xA0</addressOffset>
          <fields>
            <field>
              <name>H_FILL_CNT</name>
              <description>水平填充像素计数，定义每行消隐期插入的填充像素数。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>CR_FILL_VALUE</name>
              <description>Cr 色度填充值，消隐期输出的 Cr 分量默认值。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>CB_FILL_VALUE</name>
              <description>Cb 色度填充值，消隐期输出的 Cb 分量默认值。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>Y_FILL_VALUE</name>
              <description>Y 亮度填充值，消隐期输出的 Y 分量默认值。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
          <description>LCD 接口数据寄存器，用于 PIO 方式直接写入 4 字节像素数据到 TXFIFO。</description>
          <addressOffset>0xB0</addressOffset>
          <fields>
            <field>
              <name>DATA_ZERO</name>
              <description>字节 0 数据，32 位字中最低有效字节对应的像素数据。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>DATA_ONE</name>
              <description>字节 1 数据，32 位字中次低字节对应的像素数据。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>DATA_TWO</name>
              <description>字节 2 数据，32 位字中次高字节对应的像素数据。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>DATA_THREE</name>
              <description>字节 3 数据，32 位字中最高有效字节对应的像素数据。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>BM_ERROR_STAT</name>
          <description>总线主设备错误状态寄存器，记录 DMA 传输发生总线错误时的出错地址。</description>
          <alternateRegister>STAT</alternateRegister>
          <addressOffset>0xC0</addressOffset>
          <fields>
            <field>
              <name>ADDR</name>
              <description>DMA 总线错误发生时的 32 位出错内存地址。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STAT</name>
          <description>LCD 接口状态寄存器，反映当前运行状态、FIFO 状态及 DMA 请求标志。</description>
          <addressOffset>0xC0</addressOffset>
          <fields>
            <field>
              <name>DVI_CURRENT_FIELD</name>
              <description>DVI 当前场指示，0=场 1，1=场 2（隔行输出时）。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BUSY</name>
              <description>忙标志，1 表示 LCDIF 正在执行数据传输或时序生成。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXFIFO_EMPTY</name>
              <description>发送 FIFO 空标志，1 表示 TXFIFO 已空。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXFIFO_FULL</name>
              <description>发送 FIFO 满标志，1 表示 TXFIFO 已满。</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXFIFO_EMPTY</name>
              <description>接收 FIFO 空标志，1 表示 RXFIFO 已空。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXFIFO_FULL</name>
              <description>接收 FIFO 满标志，1 表示 RXFIFO 已满。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMA_REQ</name>
              <description>DMA 请求标志，1 表示 LCDIF 正在向 DMA 控制器请求数据传输。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PRESENT</name>
              <description>模块存在标志，1 表示 LCDIF 硬件模块已集成并可用。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>LCD 接口版本寄存器，读取硬件版本号（主/次/步进）。</description>
          <addressOffset>0xD0</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>步进版本号（STEP），标识当前硬件的修订步进。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>次版本号（MINOR），标识当前硬件的次要版本。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>主版本号（MAJOR），标识当前硬件的主要版本。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG0</name>
          <description>LCD 接口调试寄存器 0，提供内部状态机、握手信号及同步信号的实时快照。</description>
          <addressOffset>0xE0</addressOffset>
          <fields>
            <field>
              <name>LCDIF_GPMI_GRANT</name>
              <description>GPMI 对 LCDIF 的引脚共享授权信号，1 表示 GPMI 已授权 LCDIF 使用共享引脚。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>GPMI_LCDIF_REQ</name>
              <description>GPMI 向 LCDIF 发出的引脚共享请求信号。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LCDIF_PXP_B1_DONE</name>
              <description>LCDIF 到 PXP 的 Buffer 1 完成信号，1 表示 LCDIF 已完成 Buffer 1 的像素处理。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PXP_LCDIF_B1_READY</name>
              <description>PXP 到 LCDIF 的 Buffer 1 就绪信号，1 表示 PXP 已准备好 Buffer 1 数据供 LCDIF 读取。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LCDIF_PXP_B0_DONE</name>
              <description>LCDIF 到 PXP 的 Buffer 0 完成信号，1 表示 LCDIF 已完成 Buffer 0 的像素处理。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PXP_LCDIF_B0_READY</name>
              <description>PXP 到 LCDIF 的 Buffer 0 就绪信号，1 表示 PXP 已准备好 Buffer 0 数据供 LCDIF 读取。</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CUR_STATE</name>
              <description>当前状态机状态码，反映 LCDIF 内部控制状态机的当前状态编号。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>EMPTY_WORD</name>
              <description>空字标志，1 表示当前 TXFIFO 输出为空字（填充数据）。</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CUR_FRAME_TX</name>
              <description>当前帧传输中标志，1 表示 LCDIF 正在传输当前帧数据。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VSYNC</name>
              <description>内部 VSYNC 信号实时状态。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HSYNC</name>
              <description>内部 HSYNC 信号实时状态。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE</name>
              <description>内部 ENABLE/DE 数据使能信号实时状态。</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMACMDKICK</name>
              <description>DMA 命令触发（Kick）信号，1 表示 DMA 命令已被触发执行。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SYNC_SIGNALS_ON_REG</name>
              <description>同步信号强制输出寄存器位的实时状态，反映 VDCTRL4.SYNC_SIGNALS_ON 的生效状态。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WAIT_FOR_VSYNC_EDGE_OUT</name>
              <description>WAIT_FOR_VSYNC_EDGE 输出的实时状态，反映 CTRL 中该位的内部生效状态。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>STREAMING_END_DETECTED</name>
              <description>流结束检测标志，1 表示 LCDIF 检测到数据流传输结束。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CSC_COEFF0</name>
          <description>RGB 到 YCbCr 4:2:2 色彩空间转换系数寄存器 0，配置色度子采样滤波器及 CSC 矩阵系数 C0。</description>
          <addressOffset>0x110</addressOffset>
          <fields>
            <field>
              <name>CSC_SUBSAMPLE_FILTER</name>
              <description>色度子采样滤波器模式选择，0=采样保持，2=间插式，3=共位式。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SAMPLE_AND_HOLD</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RSRVD</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>INTERSTITIAL</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>COSITED</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>C0</name>
              <description>CSC 转换矩阵系数 C0（10 位有符号定点数），用于 RGB 到 YCbCr 的线性变换。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CSC_COEFF1</name>
          <description>RGB 到 YCbCr 4:2:2 色彩空间转换系数寄存器 1，配置 CSC 矩阵系数 C1 与 C2。</description>
          <addressOffset>0x120</addressOffset>
          <fields>
            <field>
              <name>C1</name>
              <description>CSC 转换矩阵系数 C1（10 位有符号定点数）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>C2</name>
              <description>CSC 转换矩阵系数 C2（10 位有符号定点数）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CSC_COEFF2</name>
          <description>RGB 到 YCbCr 4:2:2 色彩空间转换系数寄存器 2，配置 CSC 矩阵系数 C3 与 C4。</description>
          <addressOffset>0x130</addressOffset>
          <fields>
            <field>
              <name>C3</name>
              <description>CSC 转换矩阵系数 C3（10 位有符号定点数）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>C4</name>
              <description>CSC 转换矩阵系数 C4（10 位有符号定点数）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CSC_COEFF3</name>
          <description>RGB 到 YCbCr 4:2:2 色彩空间转换系数寄存器 3，配置 CSC 矩阵系数 C5 与 C6。</description>
          <addressOffset>0x140</addressOffset>
          <fields>
            <field>
              <name>C5</name>
              <description>CSC 转换矩阵系数 C5（10 位有符号定点数）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>C6</name>
              <description>CSC 转换矩阵系数 C6（10 位有符号定点数）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CSC_COEFF4</name>
          <description>RGB 到 YCbCr 4:2:2 色彩空间转换系数寄存器 4，配置 CSC 矩阵系数 C7 与 C8。</description>
          <addressOffset>0x150</addressOffset>
          <fields>
            <field>
              <name>C7</name>
              <description>CSC 转换矩阵系数 C7（10 位有符号定点数）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>C8</name>
              <description>CSC 转换矩阵系数 C8（10 位有符号定点数）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CSC_OFFSET</name>
          <description>RGB 到 YCbCr 4:2:2 色彩空间转换偏移寄存器，配置 Y 与 CbCr 的亮度/色度偏移量。</description>
          <addressOffset>0x160</addressOffset>
          <fields>
            <field>
              <name>Y_OFFSET</name>
              <description>Y 亮度分量偏移量（9 位有符号数），用于 CSC 转换后的亮度平移。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>9</bitWidth>
            </field>
            <field>
              <name>CBCR_OFFSET</name>
              <description>Cb/Cr 色度分量偏移量（9 位有符号数），用于 CSC 转换后的色度平移。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>9</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CSC_LIMIT</name>
          <description>RGB 到 YCbCr 4:2:2 色彩空间转换限幅寄存器，配置 Y 与 CbCr 的输出上下限。</description>
          <addressOffset>0x170</addressOffset>
          <fields>
            <field>
              <name>Y_MAX</name>
              <description>Y 亮度分量输出最大值（上限限幅值）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>Y_MIN</name>
              <description>Y 亮度分量输出最小值（下限限幅值）。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>CBCR_MAX</name>
              <description>Cb/Cr 色度分量输出最大值（上限限幅值）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>CBCR_MIN</name>
              <description>Cb/Cr 色度分量输出最小值（下限限幅值）。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PIN_SHARING_CTRL0</name>
          <description>引脚共享控制寄存器 0，使能 LCDIF 与 GPMI 的引脚共享仲裁，并配置中断与复用覆盖。</description>
          <addressOffset>0x180</addressOffset>
          <fields>
            <field>
              <name>PIN_SHARING_ENABLE</name>
              <description>引脚共享机制使能，1 时允许 LCDIF 与 GPMI 通过仲裁共享外部数据总线引脚。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PIN_SHARING_IRQ</name>
              <description>引脚共享中断状态，1 表示引脚共享仲裁事件产生中断请求。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_REQUEST</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>REQUEST</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>PIN_SHARING_IRQ_EN</name>
              <description>引脚共享中断使能，1 时允许 PIN_SHARING_IRQ 产生中断。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MUX_OVERRIDE</name>
              <description>引脚复用覆盖选择，0=无覆盖，2=强制 LCDIF 使用，3=强制 GPMI 使用。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_OVERRIDE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RSRVD</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LCDIF_SEL</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>GPMI_SEL</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>PIN_SHARING_CTRL1</name>
          <description>引脚共享控制寄存器 1，配置引脚共享仲裁阈值 1（GPMI 优先阈值或时间窗口）。</description>
          <addressOffset>0x190</addressOffset>
          <fields>
            <field>
              <name>THRESHOLD1</name>
              <description>引脚共享仲裁阈值 1，用于控制 LCDIF 与 GPMI 之间的总线占用时间分配。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PIN_SHARING_CTRL2</name>
          <description>引脚共享控制寄存器 2，配置引脚共享仲裁阈值 2（LCDIF 优先阈值或时间窗口）。</description>
          <addressOffset>0x1A0</addressOffset>
          <fields>
            <field>
              <name>THRESHOLD2</name>
              <description>引脚共享仲裁阈值 2，用于控制 LCDIF 与 GPMI 之间的总线占用时间分配。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG1</name>
          <description>LCD 接口调试寄存器 1，提供内部垂直与水平像素计数器的实时值。</description>
          <addressOffset>0x200</addressOffset>
          <fields>
            <field>
              <name>V_DATA_COUNT</name>
              <description>垂直数据计数器，当前帧已传输的行数（有效数据行计数）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>H_DATA_COUNT</name>
              <description>水平数据计数器，当前行已传输的像素数（有效数据像素计数）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral derivedFrom="SSP1">
      <name>SSP2</name>
      <baseAddress>0x80034000</baseAddress>
      <interrupt>
        <name>SSP2_ERROR</name>
        <value>2</value>
      </interrupt>
      <interrupt>
        <name>SSP2_DMA</name>
        <value>20</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>CLKCTRL</name>
      <description>STMP3770 时钟控制单元 (CLKCTRL)，管理 480MHz USB PLL、CPU/HBUS/XBUS 总线分频、各外设时钟门控与分数分频器、时钟源旁路选择及系统软复位。</description>
      <groupName>Clock</groupName>
      <baseAddress>0x80040000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x150</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>PLLCTRL0</name>
          <description>480MHz USB PLL 控制寄存器 0，控制 PLL 电源、USB 时钟输出使能及环路参数。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>POWER</name>
              <description>PLL 电源使能，置位后启动 PLL 电路供电。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EN_USB_CLKS</name>
              <description>USB 时钟输出使能，置位后向 USB 模块提供 PLL 时钟。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DIV_SEL</name>
              <description>PLL 反馈分频选择，枚举值：DEFAULT=默认分频，LOWER=较低分频，LOWEST=最低分频，UNDEFINED=未定义。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DEFAULT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LOWER</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LOWEST</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>UNDEFINED</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CP_SEL</name>
              <description>PLL 电荷泵电流选择，枚举值：DEFAULT=默认电流，TIMES_2=2 倍电流，TIMES_05=0.5 倍电流，UNDEFINED=未定义。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DEFAULT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TIMES_2</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TIMES_05</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>UNDEFINED</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>LFR_SEL</name>
              <description>PLL 低频电阻选择，枚举值：DEFAULT=默认阻值，TIMES_2=2 倍阻值，TIMES_05=0.5 倍阻值，UNDEFINED=未定义。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DEFAULT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TIMES_2</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TIMES_05</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>UNDEFINED</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>PLLCTRL1</name>
          <description>PLL 控制寄存器 1，保留寄存器，反映 PLL 锁定状态与锁定计数。</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>LOCK_COUNT</name>
              <description>PLL 锁定计数器值，反映 PLL 从启动到锁定经历的计数周期。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>FORCE_LOCK</name>
              <description>强制锁定指示，置位后强制声明 PLL 锁定状态。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LOCK</name>
              <description>PLL 锁定状态标志，只读，为 1 表示 PLL 已稳定锁定。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CPU</name>
          <description>CPU 时钟控制寄存器，配置 CPU 主时钟与晶振参考时钟的分频比。</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>DIV_CPU</name>
              <description>CPU 时钟整数分频值，用于 PLL/分数时钟源路径的分频。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>DIV_CPU_FRAC_EN</name>
              <description>CPU 时钟分数分频使能，置位后启用 CPU 分数分频模式。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>INTERRUPT_WAIT</name>
              <description>中断等待模式使能，置位后 CPU 在时钟切换时等待中断完成。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DIV_XTAL</name>
              <description>晶振参考时钟整数分频值，用于 XTAL 旁路路径的分频。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>DIV_XTAL_FRAC_EN</name>
              <description>晶振参考时钟分数分频使能，置位后启用 XTAL 路径分数分频模式。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BUSY_REF_CPU</name>
              <description>CPU 参考时钟分频忙标志，为 1 表示 DIV_CPU 分频器正在更新。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BUSY_REF_XTAL</name>
              <description>晶振参考时钟分频忙标志，为 1 表示 DIV_XTAL 分频器正在更新。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>HBUS</name>
          <description>AHB/APBH 总线时钟控制寄存器，配置 HBUS 分频及自动降速策略。</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>DIV</name>
              <description>AHB 总线整数分频值，决定 HBUS 相对于参考源的时钟频率。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>DIV_FRAC_EN</name>
              <description>AHB 总线分数分频使能，置位后启用 HBUS 分数分频模式。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLOW_DIV</name>
              <description>AHB 总线慢速分频选择，枚举值：BY1=1 分频，BY2=2 分频，BY4=4 分频，BY8=8 分频，BY16=16 分频，BY32=32 分频。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>3</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BY1</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BY2</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BY4</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BY8</name>
