              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXR</name>
              <description>RX 端点数据切换复位（写 1 复位数据切换序列为 DATA0）</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXE</name>
              <description>RX 端点使能（1=使能 RX 端点）</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXS</name>
              <description>TX 端点 STALL（1=TX 端点发送 STALL 握手）</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXD</name>
              <description>TX 端点数据切换（只读，反映当前数据切换状态）</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXT</name>
              <description>TX 端点类型（00=控制/01=等时/10=批量/11=中断）</description>
              <bitOffset>18</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>CONTROL</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ISO</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BULK</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>INT</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>TXI</name>
              <description>TX 端点数据切换禁止（写 1 禁止硬件自动数据切换）</description>
              <bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXR</name>
              <description>TX 端点数据切换复位（写 1 复位数据切换序列为 DATA0）</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXE</name>
