              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_UNDRFLW</name>
              <description>FIFO Underflow has occurred. Bits[4] RO Reset=0x0</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
