                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>REPEAT</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>GPTRST</name>
              <description>通用定时器 1 复位（0=无操作，1=加载 GPTLD 到计数器）</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOACTION</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LOADCOUNTER</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>GPTRUN</name>
              <description>通用定时器 1 运行控制（0=停止 STOP，1=运行 RUN）</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>STOP</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RUN</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>SBUSCFG</name>
          <description>System Bus Configuration (Non-EHCI-Compliant) Register</description>
          <addressOffset>0x90</addressOffset>
          <fields>
            <field>
              <name>AHBBRST</name>
              <description>AHB 总线突发传输模式（INCR/INCR4/INCR8/INCR16 等）</description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>U_INCR</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>S_INCR4</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>S_INCR8</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>S_INCR16</name>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RESERVED</name>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>U_INCR4</name>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>U_INCR8</name>
                  <value>6</value>
