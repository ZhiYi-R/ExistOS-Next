    <peripheral>
      <name>DRAM</name>
      <description>DRAM 控制器(mDDR/SDRAM 时序、刷新与校准配置寄存器)</description>
      <groupName>Memory</groupName>
      <baseAddress>0x800E0000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0xB0</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>CTL00</name>
          <description>DRAM Control Register 00</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>ADDR_CMP_EN</name>
              <description>Addr Cmp En，1位读写字段。</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AHB0_FIFO_TYPE_REG</name>
              <description>Ahb0 Fifo Type Reg，1位读写字段。</description><bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AHB0_R_PRIORITY</name>
              <description>Ahb0 R Priority，1位读写字段。</description><bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AHB0_W_PRIORITY</name>
              <description>Ahb0 W Priority，1位读写字段。</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CTL01</name>
          <description>DRAM Control Register 01</description>
          <addressOffset>0x4</addressOffset>
          <fields>
