              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>ETCE</name>
              <description>TX 端点传输完成（5 位，每 bit 对应一个端点，写 1 清零）</description>
              <bitOffset>16</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>8</dim>
          <dimIncrement>0x4</dimIncrement>
          <dimIndex>0-7</dimIndex>
          <name>ENDPTCTRL%s</name>
          <description>ENDPTCTRL</description>
          <addressOffset>0x1C0</addressOffset>
          <fields>
            <field>
              <name>RXS</name>
