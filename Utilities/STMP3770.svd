            </field>
            <field>
              <name>BANK0_PIN13</name>
              <description>Bank 0 引脚 13 的复用功能选择（2 位，0~3）。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>BANK0_PIN14</name>
              <description>Bank 0 引脚 14 的复用功能选择（2 位，0~3）。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>BANK0_PIN15</name>
              <description>Bank 0 引脚 15 的复用功能选择（2 位，0~3）。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
          </fields>
        </register>
