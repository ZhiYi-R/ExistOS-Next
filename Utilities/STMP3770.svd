    <peripheral>
      <name>TIMROT</name>
      <description>STMP3770 TIMROT 外设：定时器与旋钮解码器。包含 4 个通用定时器（Timer0~3）和 1 个旋钮解码器，支持 PWM、晶振及旋钮输入等多种时钟源，可配置预分频、自动重载、中断等功能。ROTCTRL 控制旋钮解码器输入源、极性、过采样率及分频等；ROTCOUNT 保存旋钮旋转产生的计数值。各定时器通过 TIMCTRLn/TIMCOUNTn 寄存器组独立控制与计数。</description>
      <groupName>Timer</groupName>
      <baseAddress>0x80068000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0xB0</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>TIMER0</name>
        <value>28</value>
      </interrupt>
      <interrupt>
        <name>TIMER1</name>
        <value>29</value>
      </interrupt>
      <interrupt>
        <name>TIMER2</name>
        <value>30</value>
      </interrupt>
      <interrupt>
        <name>TIMER3</name>
        <value>31</value>
      </interrupt>
