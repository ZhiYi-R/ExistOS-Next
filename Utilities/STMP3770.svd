              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>READY0</name>
              <description>设备 0 的就绪(READY)信号输入状态。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>READY1</name>
              <description>设备 1 的就绪(READY)信号输入状态。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>READY2</name>
              <description>设备 2 的就绪(READY)信号输入状态。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>READY3</name>
              <description>设备 3 的就绪(READY)信号输入状态。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>GPMI 版本寄存器，记录模块的硬件版本号。</description>
          <addressOffset>0xD0</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>步进版本号，标识当前硬件的步进修订。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>次版本号。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>主版本号。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG2</name>
          <description>GPMI 调试信息寄存器 2，提供读数据采样 DLL 抽头、同步器握手与字节使能等调试信号。</description>
          <addressOffset>0xE0</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>RDN_TAP</name>
              <description>读数据采样 DLL 抽头值，反映当前 DLL 延时链的抽头位置。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>UPDATE_WINDOW</name>
              <description>DLL 更新窗口标志，指示 DLL 是否处于允许更新的时间窗口。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VIEW_DELAYED_RDN</name>
              <description>延时读数据采样视图使能，用于观察经 DLL 延时后的读数据采样信号。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SYND2GPMI_READY</name>
              <description>Syndrome 到 GPMI 的 READY 握手信号状态。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SYND2GPMI_VALID</name>
              <description>Syndrome 到 GPMI 的 VALID 握手信号状态。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>GPMI2SYND_READY</name>
              <description>GPMI 到 Syndrome 的 READY 握手信号状态。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>GPMI2SYND_VALID</name>
              <description>GPMI 到 Syndrome 的 VALID 握手信号状态。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SYND2GPMI_BE</name>
              <description>Syndrome 到 GPMI 的字节使能信号，指示有效字节位置。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG3</name>
          <description>GPMI 调试信息寄存器 3，提供设备侧与 APB 侧的字计数器。</description>
          <addressOffset>0xF0</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>DEV_WORD_CNTR</name>
              <description>设备侧已传输字数计数器，反映与 NAND 设备之间传输的字数。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>APB_WORD_CNTR</name>
              <description>APB 侧已传输字数计数器，反映 APB 总线侧传输的字数。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
