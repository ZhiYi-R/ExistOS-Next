              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DEVEP</name>
              <description>支持的 Device 端点数量（只读）</description>
              <bitOffset>1</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>HWTXBUF</name>
          <description>TX Buffer Hardware Parameters Register</description>
          <addressOffset>0x10</addressOffset>
