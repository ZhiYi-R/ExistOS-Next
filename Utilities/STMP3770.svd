        </register>
        <register>
          <name>DEBUG</name>
          <description>IR Debug Register</description>
          <addressOffset>0x90</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>RXDMAREQ</name>
              <description>接收DMA请求状态。</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXDMAREQ</name>
              <description>发送DMA请求状态。</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXDMAEND</name>
              <description>接收DMA结束。</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXDMAEND</name>
              <description>发送DMA结束。</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXDMAKICK</name>
              <description>接收DMA触发。</description><bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXDMAKICK</name>
              <description>发送DMA触发。</description><bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>IR Version Register</description>
          <addressOffset>0xA0</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>IR模块修订步进号，只读。</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>IR模块次版本号，只读。</description><bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>IR模块主版本号，只读。</description><bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>USBPHY</name>
      <description>USB 2.0 收发 PHY 寄存器，包含电源关断、发送器/接收器控制、通用控制、状态、调试及 IP 版本等寄存器。</description>
      <groupName>USB</groupName>
      <baseAddress>0x8007C000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0xA0</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>PWD</name>
          <description>USB PHY 各路电源关断控制寄存器，写 0 上电、写 1 掉电。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>TXPWDFS</name>
              <description>全速发送器掉电控制位，写 1 掉电、写 0 上电。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXPWDIBIAS</name>
              <description>发送器偏置电流源掉电控制位，写 1 掉电、写 0 上电。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXPWDV2I</name>
              <description>发送器压流转换器掉电控制位，写 1 掉电、写 0 上电。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXPWDENV</name>
              <description>接收器包络检测器掉电控制位，写 1 掉电、写 0 上电。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXPWD1PT1</name>
              <description>1.1V 接收器掉电控制位，写 1 掉电、写 0 上电。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXPWDDIFF</name>
              <description>差分接收器掉电控制位，写 1 掉电、写 0 上电。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXPWDRX</name>
              <description>整个接收器掉电控制位，写 1 掉电、写 0 上电。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          <field><name>TXPWDVBG</name><description>发送器带隙参考掉电控制位，写1掉电、写0上电。STMP3770中此位无功能。PDF标记为未使用。</description><bitOffset>13</bitOffset><bitWidth>1</bitWidth></field><field><name>TXPWDCOMP</name><description>发送器比较器掉电控制位，写1掉电、写0上电。此位不使用，应保持置位。PDF标记。</description><bitOffset>14</bitOffset><bitWidth>1</bitWidth></field></fields>
        </register>
        <register>
          <name>TX</name>
          <description>USB PHY 发送器控制寄存器，负责驱动校准与端接电阻校准。</description>
          <addressOffset>0x10</addressOffset>
          <fields>
            <field>
              <name>D_CAL</name>
              <description>D+/D- 输出驱动电流校准值，4 位无符号数。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>TXCAL45DN</name>
              <description>D- 线 45Ω 端接电阻校准值，4 位无符号数。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>TXENCAL45DN</name>
              <description>D- 线 45Ω 端接电阻校准使能位，写 1 使能。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXCAL45DP</name>
              <description>D+ 线 45Ω 端接电阻校准值，4 位无符号数。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>TXENCAL45DP</name>
              <description>D+ 线 45Ω 端接电阻校准使能位，写 1 使能。</description>
              <bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>USBPHY_TX_SYNC_MUX</name>
              <description>发送同步多路选择控制位。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>USBPHY_TX_SYNC_INVERT</name>
              <description>发送同步信号反相控制位，写 1 反相。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>USBPHY_TX_EDGECTRL</name>
              <description>发送边沿控制字段，3 位数值，用于调整输出边沿速率。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
          <field><name>TXCALIBRATE</name><description>发送器校准控制位。此位不使用，必须保持清零。</description><bitOffset>7</bitOffset><bitWidth>1</bitWidth></field><field><name>TXCMPOUT_STATUS</name><description>发送器比较器输出状态，只读。此位不使用。</description><bitOffset>23</bitOffset><bitWidth>1</bitWidth></field></fields>
        </register>
        <register>
          <name>RX</name>
          <description>USB PHY 接收器控制寄存器，负责包络检测与断开检测阈值调整。</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>ENVADJ</name>
              <description>接收器包络检测阈值调整值，3 位数值。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DISCONADJ</name>
              <description>断开检测阈值调整值，3 位数值。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>RXDBYPASS</name>
              <description>接收器数据旁路控制位，写 1 绕过同步/解码逻辑直接输出原始数据。</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL</name>
          <description>USB PHY 通用控制寄存器，包含检测使能、中断、UTMI 挂起、时钟门控及软复位控制。</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>ENHOSTDISCONDETECT</name>
              <description>主机断开检测使能位，写 1 使能 Host 模式下设备断开检测。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENIRQHOSTDISCON</name>
              <description>主机断开中断使能位，写 1 允许主机断开事件触发中断。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HOSTDISCONDETECT_IRQ</name>
              <description>主机断开中断状态位，写 1 清除中断标志。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENDEVPLUGINDETECT</name>
              <description>设备插入检测使能位，写 1 使能设备插入检测。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DEVPLUGIN_POLARITY</name>
              <description>设备插入检测极性选择位。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENOTGIDDETECT</name>
              <description>OTG ID 检测使能位，写 1 使能 OTG ID 引脚状态检测。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENIRQRESUMEDETECT</name>
              <description>远程唤醒中断使能位，写 1 允许 USB 远程唤醒事件触发中断。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RESUME_IRQ</name>
              <description>远程唤醒中断状态位，写 1 清除中断标志。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENIRQDEVPLUGIN</name>
              <description>设备插入中断使能位，写 1 允许设备插入事件触发中断。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DEVPLUGIN_IRQ</name>
              <description>设备插入中断状态位，写 1 清除中断标志。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DATA_ON_LRADC</name>
              <description>LRADC 数据映射使能位，写 1 将 USB 数据信号映射到低分辨率 ADC 采样。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HOST_FORCE_LS_SE0</name>
              <description>主机强制低速 SE0 控制位，写 1 在 Host 模式下强制输出低速 SE0 状态。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>UTMI_SUSPENDM</name>
              <description>UTMI 挂起控制位，写 1 将 PHY 置于 UTMI 挂起状态。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>时钟门控控制位，写 1 关闭 USB PHY 时钟以节省功耗，写 0 解除门控。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SFTRST</name>
              <description>软复位控制位，写 1 触发 USB PHY 软复位，写 0 释放复位。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STATUS</name>
          <description>USB PHY 状态寄存器，只读，反映主机断开、设备插入、OTG ID 及远程唤醒等事件状态。</description>
          <addressOffset>0x40</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>HOSTDISCONDETECT_STATUS</name>
              <description>主机断开检测状态位，只读，1 表示 Host 模式下设备已断开。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DEVPLUGIN_STATUS</name>
              <description>设备插入状态位，只读，1 表示检测到 USB 设备已插入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OTGID_STATUS</name>
              <description>OTG ID 状态位，只读，反映 OTG ID 引脚当前电平状态。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RESUME_STATUS</name>
              <description>远程唤醒状态位，只读，1 表示检测到 USB 远程唤醒信号。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG</name>
          <description>USB PHY 调试寄存器，用于调试模式下控制 OTG ID 锁定、接口保持、主机下拉、发送转接收计数及静噪复位等功能。</description>
          <addressOffset>0x50</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>OTGIDPIOLOCK</name>
              <description>OTG ID PIO 锁定控制位，写 1 锁定 OTG ID 状态到 PIO 采样值。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DEBUG_INTERFACE_HOLD</name>
              <description>调试接口保持控制位，写 1 保持 UTMI 调试接口处于保持状态。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HSTPULLDOWN</name>
              <description>主机下拉电阻控制字段，2 位数值，分别控制 D+/D- 线上的主机下拉电阻。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>ENHSTPULLDOWN</name>
              <description>主机下拉电阻使能字段，2 位数值，分别使能 D+/D- 线上的主机下拉电阻。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TX2RXCOUNT</name>
              <description>发送转接收计数器阈值，4 位数值，定义发送完成后切换到接收模式的延迟计数值。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>ENTX2RXCOUNT</name>
              <description>发送转接收计数使能位，写 1 使能 TX2RXCOUNT 计数器功能。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SQUELCHRESETCOUNT</name>
              <description>静噪复位计数器阈值，5 位数值，定义检测到静噪后触发复位的计数值。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>ENSQUELCHRESET</name>
              <description>静噪复位使能位，写 1 使能静噪检测复位功能。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SQUELCHRESETLENGTH</name>
              <description>静噪复位脉冲长度，4 位数值，定义静噪复位信号的持续时间。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>HOST_RESUME_DEBUG</name>
              <description>主机恢复调试控制位，写 1 使能主机恢复调试模式。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>调试时钟门控控制位，写 1 关闭调试模块时钟，写 0 解除门控。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG0_STATUS</name>
          <description>UTMI 调试状态寄存器 0，只读，反映环回测试、接收错误及静噪检测的计数状态。</description>
          <addressOffset>0x60</addressOffset>
          <fields>
            <field>
              <name>LOOP_BACK_FAIL_COUNT</name>
              <description>环回测试失败计数，16 位数值，记录环回测试过程中失败的次数。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>UTMI_RXERROR_FAIL_COUNT</name>
              <description>UTMI 接收错误失败计数，10 位数值，记录 UTMI 接收错误检测的累计次数。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>SQUELCH_COUNT</name>
              <description>静噪计数，6 位数值，反映当前静噪检测器的状态计数值。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG1</name>
          <description>UTMI 调试寄存器 1，用于配置调试地址、发送环回及尾码调整电压等调试功能。</description>
          <addressOffset>0x70</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>DBG_ADDRESS</name>
              <description>调试地址字段，4 位数值，选择当前访问的 UTMI 内部调试寄存器地址。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>ENTX2TX</name>
              <description>发送环回使能位，写 1 使能发送器到发送器的内部环回路径。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENTAILADJVD</name>
              <description>尾码调整电压控制字段，2 位数值，用于调整发送器尾码电流的电压偏置。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>UTMI RTL 版本寄存器，只读，反映当前 USB PHY IP 的 RTL 版本号。</description>
          <addressOffset>0x80</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>步进版本号，16 位数值，表示 RTL 的步进版本。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>次版本号，8 位数值，表示 RTL 的次要版本。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>主版本号，8 位数值，表示 RTL 的主要版本。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>IP</name>
          <description>USB PHY IP 块控制寄存器，包含 PLL 电源、USB 时钟使能、模拟测试模式及 PLL 环路参数选择。</description>
          <addressOffset>0x90</addressOffset>
          <fields>
            <field>
              <name>PLL_POWER</name>
              <description>PLL 电源控制位，写 1 为 USB PHY PLL 上电，写 0 掉电。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PLL_LOCKED</name>
              <description>PLL 锁定状态位，只读，1 表示 USB PHY PLL 已锁定。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EN_USB_CLKS</name>
              <description>USB 时钟使能位，写 1 使能 USB PHY 内部时钟输出到控制器。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ANALOG_TESTMODE</name>
              <description>模拟测试模式使能位，写 1 使能 USB PHY 模拟电路测试模式。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TSTI_TX_DM</name>
              <description>模拟测试输入 D- 控制位，写 1 将测试信号驱动到 D- 线。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TSTI_TX_DP</name>
              <description>模拟测试输入 D+ 控制位，写 1 将测试信号驱动到 D+ 线。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CP_SEL</name>
              <description>电荷泵电流选择字段，2 位枚举：DEFAULT(默认)、TIMES_2(2 倍)、TIMES_05(0.5 倍)、UNDEFINED(未定义)。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DEFAULT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TIMES_2</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TIMES_05</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>UNDEFINED</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>LFR_SEL</name>
              <description>环路滤波电阻选择字段，2 位枚举：DEFAULT(默认)、TIMES_2(2 倍)、TIMES_05(0.5 倍)、UNDEFINED(未定义)。</description>
              <bitOffset>21</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DEFAULT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TIMES_2</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TIMES_05</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>UNDEFINED</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DIV_SEL</name>
              <description>PLL 分频比选择字段，2 位枚举：DEFAULT(默认)、LOWER(较低)、LOWEST(最低)、UNDEFINED(未定义)。</description>
              <bitOffset>23</bitOffset>
              <bitWidth>2</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DEFAULT</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LOWER</name>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LOWEST</name>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>UNDEFINED</name>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>USBCTRL</name>
      <description>ChipIdea/MXS USB 2.0 OTG 控制器（EHCI 兼容扩展），HP39GII 工作于 Device 模式。包含 EHCI 能力寄存器、USB 命令/状态/中断控制、端点队列管理（QH）、端口状态控制、OTG 状态控制及端点控制寄存器组。</description>
      <groupName>USB</groupName>
      <baseAddress>0x80080000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x1F0</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>USB_CTRL</name>
        <value>11</value>
      </interrupt>
      <interrupt>
        <name>USB_WAKEUP</name>
        <value>12</value>
      </interrupt>
