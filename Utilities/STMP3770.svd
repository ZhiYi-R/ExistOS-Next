            <field>
              <name>RXDMAE</name>
              <description>接收 DMA 使能（Receive DMA Enable），置位时允许接收 FIFO 触发 DMA 请求。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXDMAE</name>
              <description>发送 DMA 使能（Transmit DMA Enable），置位时允许发送 FIFO 触发 DMA 请求。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAONERR</name>
              <description>错误时停止 DMA（DMA On Error），置位时接收错误时禁止 DMA 请求。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>UNAVAILABLE</name>
              <description>未实现位，读取值未定义。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>DRI</name>
