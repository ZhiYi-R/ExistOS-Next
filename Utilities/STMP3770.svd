              <description>Cryptodcp，1位读写字段。</description><bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HWSW_SHADOW</name>
              <description>Hwsw Shadow，1位读写字段。</description><bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CUSTCAP_SHADOW</name>
              <description>Custcap Shadow，1位读写字段。</description><bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HWSW</name>
              <description>Hwsw，1位读写字段。</description><bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CUSTCAP</name>
              <description>Custcap，1位读写字段。</description><bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ROM_SHADOW</name>
              <description>Rom Shadow，1位读写字段。</description><bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>UNALLOCATED</name>
              <description>Unallocated，5位读写字段。</description><bitOffset>11</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>UN0</name>
              <description>Un0，1位读写字段。</description><bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>UN1</name>
              <description>Un1，1位读写字段。</description><bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>UN2</name>
              <description>Un2，1位读写字段。</description><bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OPS</name>
              <description>Ops，1位读写字段。</description><bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PIN</name>
              <description>Pin，1位读写字段。</description><bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRYPTOKEY_ALT</name>
              <description>Cryptokey Alt，1位读写字段。</description><bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRYPTODCP_ALT</name>
              <description>Cryptodcp Alt，1位读写字段。</description><bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HWSW_SHADOW_ALT</name>
              <description>Hwsw Shadow Alt，1位读写字段。</description><bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ROM0</name>
              <description>Rom0，1位读写字段。</description><bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ROM1</name>
              <description>Rom1，1位读写字段。</description><bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ROM2</name>
              <description>Rom2，1位读写字段。</description><bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ROM3</name>
              <description>Rom3，1位读写字段。</description><bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ROM4</name>
              <description>Rom4，1位读写字段。</description><bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ROM5</name>
              <description>Rom5，1位读写字段。</description><bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ROM6</name>
              <description>Rom6，1位读写字段。</description><bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ROM7</name>
              <description>Rom7，1位读写字段。</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>4</dim>
          <dimIncrement>0x10</dimIncrement>
          <dimIndex>0-3</dimIndex>
          <name>OPS%s</name>
          <description>OPS</description>
          <addressOffset>0x130</addressOffset>
          <fields>
            <field>
              <name>BITS</name>
              <description>Bits，32位读写字段。</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>3</dim>
          <dimIncrement>0x10</dimIncrement>
          <dimIndex>0-2</dimIndex>
          <name>UN%s</name>
          <description>UN</description>
          <addressOffset>0x170</addressOffset>
          <fields>
            <field>
              <name>BITS</name>
              <description>Bits，32位读写字段。</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>8</dim>
          <dimIncrement>0x10</dimIncrement>
          <dimIndex>0-7</dimIndex>
          <name>ROM%s</name>
          <description>ROM</description>
          <addressOffset>0x1A0</addressOffset>
          <fields>
            <field>
              <name>BITS</name>
              <description>Bits，32位读写字段。</description><bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VERSION</name>
          <description>OTP Controller Version Register</description>
          <addressOffset>0x220</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>Step，16位读写字段。</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>Minor，8位读写字段。</description><bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>MAJOR</name>
              <description>Major，8位读写字段。</description><bitOffset>24</bitOffset>
