                </enumeratedValue>
                <enumeratedValue>
                  <name>AVAILABLE</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG</name>
