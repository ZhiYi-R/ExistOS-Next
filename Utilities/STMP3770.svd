        </register>
        <register>
          <name>VERSION</name>
          <description>APBX Bridge Version Register</description>
          <addressOffset>0x800</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>STEP</name>
              <description>Step，16位读写字段。</description><bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>MINOR</name>
              <description>Minor，8位读写字段。</description><bitOffset>16</bitOffset>
