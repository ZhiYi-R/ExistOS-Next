    <peripheral>
      <name>ECC8</name>
      <description>NAND ECC8/BCH 硬件纠错加速器(配合 GPMI 对 NAND 数据做 ECC 编解码)</description>
      <groupName>NAND</groupName>
      <baseAddress>0x80008000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0xB0</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>ECC8_IRQ</name>
        <value>21</value>
      </interrupt>
      <registers>
        <register>
          <name>CTRL</name>
          <description>Hardware ECC Accelerator Control Register</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>COMPLETE_IRQ</name>
              <description>Complete IRQ. RW, Reset=0x0. External Interrupt Line Status. Write 1 to SCT clear address to clear. ECC completions held off while set. Read STATUS0/1 before clearing.</description><bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DEBUG_WRITE_IRQ</name>
              <description>Debug Write IRQ. RW, Reset=0x0. Debug Write Interrupt Status. Write 1 to SCT clear address to clear.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DEBUG_STALL_IRQ</name>
              <description>Debug Stall IRQ. RW, Reset=0x0. Debug Stall Interrupt Status. Write 1 to SCT clear address to clear.</description><bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BM_ERROR_IRQ</name>
              <description>Bus Master Error IRQ. RW, Reset=0x0. AHB Bus Interface Error Interrupt Status. Write 1 to SCT clear address to clear.</description><bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>COMPLETE_IRQ_EN</name>
              <description>Complete Interrupt Enable. RW, Reset=0x0. 1=Interrupt on completion of correction is enabled.</description><bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DEBUG_WRITE_IRQ_EN</name>
              <description>Debug Write Interrupt Enable. RW, Reset=0x0. 1=IRQ on debug write mode enabled, raised on every transfer. No correction in this mode.</description><bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DEBUG_STALL_IRQ_EN</name>
              <description>Debug Stall Interrupt Enable. RW, Reset=0x0. 1=IRQ on debug stall mode enabled, raised on every block.</description><bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>THROTTLE</name>
              <description>AHB Throttle. RW, Reset=0x0. Non-zero values hold off that number of HCLKs between successive burst requests on AHB.</description><bitOffset>24</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>AHBM_SFTRST</name>
              <description>AHB Master Soft Reset. RW, Reset=0x1. Resets the AHB state machine. 0=Normal, 1=Reset. Not for normal device soft-resets.</description><bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RUN</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RESET</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CLKGATE</name>
              <description>Clock Gate. RW, Reset=0x1. Must be 0 for normal operation. When 1, gates off clocks to minimize power consumption.</description><bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RUN</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NO_CLKS</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SFTRST</name>
              <description>Soft Reset. RW, Reset=0x1. 0=Normal ECC8 operation. 1=Hold ECC8 in reset (lowest power) state. Resets all state machines except AHB master.</description><bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RUN</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RESET</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
