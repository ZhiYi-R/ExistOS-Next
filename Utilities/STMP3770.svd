    </peripheral>
    <peripheral>
      <name>UARTDBG</name>
      <description>STMP3770 UARTDBG 调试串口外设（ARM PrimeCell PL011 兼容），基地址 0x80070000，用于内核调试输出。包含数据收发、接收状态/错误清除、标志、红外低功耗计数、整数/小数波特率分频、线控、控制、FIFO 中断触发水平、中断屏蔽、原始中断状态、屏蔽后中断状态、中断清除及 DMA 控制等寄存器。</description>
      <groupName>UART</groupName>
      <baseAddress>0x80070000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x50</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>DEBUG_UART</name>
        <value>0</value>
      </interrupt>
      <registers>
        <register>
          <name>DR</name>
          <description>UART 数据寄存器，读写收发字节并附带接收错误标志。</description>
          <addressOffset>0x0</addressOffset>
          <fields>
            <field>
              <name>DATA</name>
              <description>收发数据字节（8 位），写入时送入发送 FIFO，读取时返回接收 FIFO 数据。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>FE</name>
              <description>接收帧错误标志（Frame Error），读取时反映最近接收字节的帧错误状态。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PE</name>
              <description>接收校验错误标志（Parity Error），读取时反映最近接收字节的校验错误状态。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BE</name>
              <description>接收 Break 错误标志（Break Error），读取时反映最近接收字节是否检测到 Break 条件。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OE</name>
              <description>接收溢出错误标志（Overrun Error），读取时反映 FIFO 溢出状态。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>UNAVAILABLE</name>
              <description>未实现位，读取值未定义。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RSR_ECR</name>
          <description>UART 接收状态寄存器（读）/ 错误清除寄存器（写），读取时返回接收错误状态，写入时向 EC 字段写值以清除错误标志。</description>
          <addressOffset>0x4</addressOffset>
          <fields>
            <field>
              <name>FE</name>
              <description>帧错误状态（Frame Error）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PE</name>
              <description>校验错误状态（Parity Error）。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BE</name>
              <description>Break 错误状态（Break Error）。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OE</name>
              <description>溢出错误状态（Overrun Error）。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EC</name>
              <description>错误清除（Error Clear），写入时向该 4 位字段写值以清除接收错误标志。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>UNAVAILABLE</name>
              <description>未实现位，读取值未定义。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>24</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>FR</name>
          <description>UART 标志寄存器（只读），反映 UART 当前状态与 FIFO 状态。</description>
          <addressOffset>0x18</addressOffset>
          <fields>
            <field>
              <name>CTS</name>
              <description>CTS 调制解调器状态输入（Clear To Send）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DSR</name>
              <description>DSR 调制解调器状态输入（Data Set Ready）。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DCD</name>
              <description>DCD 调制解调器状态输入（Data Carrier Detect）。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BUSY</name>
              <description>发送忙标志，表示 UART 正在发送数据。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXFE</name>
              <description>接收 FIFO 空标志（Receive FIFO Empty）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXFF</name>
              <description>发送 FIFO 满标志（Transmit FIFO Full）。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXFF</name>
              <description>接收 FIFO 满标志（Receive FIFO Full）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXFE</name>
              <description>发送 FIFO 空标志（Transmit FIFO Empty）。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RI</name>
              <description>RI 调制解调器状态输入（Ring Indicator）。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>UNAVAILABLE</name>
              <description>未实现位，读取值未定义。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ILPR</name>
          <description>UART IrDA 低功耗计数寄存器，配置低功耗分频值。</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>ILPDVSR</name>
              <description>IrDA 低功耗分频值（IrDA Low-Power Divisor），用于 IrDA SIR 低功耗模式的波特率生成。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>UNAVAILABLE</name>
              <description>未实现位，读取值未定义。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>24</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>IBRD</name>
          <description>UART 整数波特率分频寄存器，设置波特率整数分频值。</description>
          <addressOffset>0x24</addressOffset>
          <fields>
            <field>
              <name>BAUD_DIVINT</name>
              <description>波特率整数分频值（Baud Rate Integer Divisor），与 FBRD 共同决定 UART 波特率。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>UNAVAILABLE</name>
              <description>未实现位，读取值未定义。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>FBRD</name>
          <description>UART 小数波特率分频寄存器，设置波特率小数分频值。</description>
          <addressOffset>0x28</addressOffset>
          <fields>
            <field>
              <name>BAUD_DIVFRAC</name>
              <description>波特率小数分频值（Baud Rate Fractional Divisor），与 IBRD 共同决定 UART 波特率。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>UNAVAILABLE</name>
              <description>未实现位，读取值未定义。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>24</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>LCR_H</name>
          <description>UART 线控寄存器（高字节），配置数据格式、校验、停止位及 FIFO 使能。</description>
          <addressOffset>0x2C</addressOffset>
          <fields>
            <field>
              <name>BRK</name>
              <description>发送 Break 控制，置位时强制 UART 输出低电平 Break 条件。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PEN</name>
              <description>校验使能（Parity Enable），置位时启用奇偶校验。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EPS</name>
              <description>偶校验选择（Even Parity Select），置位时选择偶校验，清零时选择奇校验。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>STP2</name>
              <description>双停止位使能（Two Stop Bits），置位时发送两个停止位。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FEN</name>
              <description>FIFO 使能（FIFO Enable），置位时启用发送/接收 FIFO。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WLEN</name>
              <description>字长选择（Word Length），00=5 位、01=6 位、10=7 位、11=8 位。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SPS</name>
              <description>Stick 校验选择（Stick Parity Select），置位时强制校验位为固定值。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>UNAVAILABLE</name>
              <description>未实现位，读取值未定义。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CR</name>
          <description>UART 控制寄存器，使能 UART、收发方向、环回及调制解调器控制。</description>
          <addressOffset>0x30</addressOffset>
          <fields>
            <field>
              <name>UARTEN</name>
              <description>UART 使能（UART Enable），置位时启动 UART 模块。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SIREN</name>
              <description>IrDA SIR 模式使能（SIR Enable），置位时启用 IrDA SIR 编码/解码。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SIRLP</name>
              <description>IrDA SIR 低功耗模式使能（SIR Low-Power），置位时启用 IrDA 低功耗模式。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LBE</name>
              <description>环回使能（Loopback Enable），置位时内部将发送输出连接到接收输入用于自测。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXE</name>
              <description>发送使能（Transmit Enable），置位时允许 UART 发送数据。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXE</name>
              <description>接收使能（Receive Enable），置位时允许 UART 接收数据。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DTR</name>
              <description>DTR 调制解调器输出控制（Data Terminal Ready）。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
