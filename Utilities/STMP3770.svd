            </field>
            <field>
              <name>BANK0_PIN09</name>
              <description>Bank 0 引脚 9 的复用功能选择（2 位，0~3）。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
