            </field>
            <field>
              <name>BANK0_PIN07</name>
              <description>Bank 0 引脚 7 的复用功能选择（2 位，0~3）。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
