              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EPS</name>
              <description>偶校验选择（Even Parity Select），置位时选择偶校验，清零时选择奇校验。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>STP2</name>
              <description>双停止位使能（Two Stop Bits），置位时发送两个停止位。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
