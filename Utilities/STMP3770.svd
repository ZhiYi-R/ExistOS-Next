              <description>Ch1，2位读写字段。</description><bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>CH2</name>
              <description>Ch2，2位读写字段。</description><bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>CH3</name>
              <description>Ch3，2位读写字段。</description><bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
