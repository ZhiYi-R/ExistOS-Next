            </field>
            <field>
              <name>FORCE_CLK_IDLE</name>
              <description>强制 SCL 空闲，用于调试时强制时钟线进入空闲状态。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FORCE_DATA_IDLE</name>
              <description>强制 SDA 空闲，用于调试时强制数据线进入空闲状态。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ACK_MODE</name>
              <description>ACK 模式：0=在时钟保持低后应答，1=在时钟保持低前应答。</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ACK_AFTER_HOLD_LOW</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ACK_BEFORE_HOLD_LOW</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CLR_GOT_A_NAK</name>
              <description>清除 GOT_A_NAK 标志：0=无操作，1=清除标志。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DO_NOTHING</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CLEAR</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>STAT</name>
          <description>I2C 状态寄存器，反映各类中断汇总、总线/引擎/时钟忙状态、从机搜索状态及接收到的从机地址等信息。</description>
          <addressOffset>0x50</addressOffset>
          <fields>
            <field>
              <name>SLAVE_IRQ_SUMMARY</name>
