              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>PRE_SEND_START</name>
              <description>传输前是否发送 START 条件：0=不发，1=发送 START。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_START</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SEND_START</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>POST_SEND_STOP</name>
              <description>传输后是否发送 STOP 条件：0=不发，1=发送 STOP。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_STOP</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SEND_STOP</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>RETAIN_CLOCK</name>
              <description>保持 SCL 低电平：0=释放，1=保持低电平。</description>
              <bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RELEASE</name>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>HOLD_LOW</name>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CLOCK_HELD</name>
              <description>时钟保持状态：0=释放，1=保持低电平。</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
