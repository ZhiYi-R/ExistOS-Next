            </field>
            <field>
              <name>ATTENTION_IRQ</name>
              <description>Attention interrupt pending. Attention bit detected in DRI frame. Write 1 to SET/CLR to clear. 0=NO_REQUEST, 1=REQUEST. Default 0x0.</description><bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_REQUEST</name>
                  <value>0</value>
